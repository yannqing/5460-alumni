<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cmswe.alumni.service.association.mapper.AlumniAssociationMapper">

    <resultMap id="BaseResultMap" type="com.cmswe.alumni.common.entity.AlumniAssociation">
        <id property="associationId" column="association_id" jdbcType="BIGINT"/>
        <result property="associationName" column="association_name" jdbcType="VARCHAR"/>
        <result property="schoolId" column="school_id" jdbcType="BIGINT"/>
        <result property="platformId" column="platform_id" jdbcType="BIGINT"/>
        <result property="contactInfo" column="contact_info" jdbcType="VARCHAR"/>
        <result property="location" column="location" jdbcType="VARCHAR"/>
        <result property="memberCount" column="member_count" jdbcType="INTEGER"/>
        <result property="logo" column="logo" jdbcType="VARCHAR"/>
        <result property="bgImg" column="bg_img" jdbcType="VARCHAR"/>
        <result property="status" column="status" jdbcType="TINYINT"/>
        <result property="role" column="role" jdbcType="TINYINT"/>
        <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
        <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
        <result property="isDelete" column="is_delete" jdbcType="TINYINT"/>
    </resultMap>

    <sql id="Base_Column_List">
        association_id, association_name, school_id, platform_id,
        contact_info, location, member_count, logo, bg_img, status, role, create_time, update_time, is_delete
    </sql>

    <update id="updateMemberCount">
        UPDATE alumni_association
        SET member_count = member_count + #{delta}
        WHERE alumni_association_id = #{alumniAssociationId}
          AND is_delete = 0
    </update>

    <!-- 与业务统计口径一致：成员 status=1，且未逻辑删除 -->
    <update id="reconcileMemberCountsFromMemberTable">
        UPDATE alumni_association aa
            LEFT JOIN (
                SELECT alumni_association_id, COUNT(*) AS actual_count
                FROM alumni_association_member
                WHERE status = 1
                  AND is_delete = 0
                GROUP BY alumni_association_id
            ) m ON aa.alumni_association_id = m.alumni_association_id
        SET aa.member_count  = IFNULL(m.actual_count, 0),
            aa.update_time   = NOW()
        WHERE aa.is_delete = 0
          AND IFNULL(aa.member_count, 0) != IFNULL(m.actual_count, 0)
    </update>

</mapper>
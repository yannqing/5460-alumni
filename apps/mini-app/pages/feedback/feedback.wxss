/* pages/feedback/feedback.wxss */

.feedback-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 60rpx;
}

/* 顶部提示区域 */
.tip-section {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #4A8BF5 0%, #6BA3F7 100%);
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
}

.tip-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.icon-text {
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
}

.tip-content {
  flex: 1;
}

.tip-title {
  display: block;
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.tip-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 表单区域 */
.form-section {
  background-color: #fff;
  margin: 0 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.form-label.required::before {
  content: '*';
  color: #ff4d4f;
  margin-right: 8rpx;
}

.optional-hint {
  font-size: 24rpx;
  color: #999;
  font-weight: normal;
  margin-left: 8rpx;
}

/* 反馈类型选择器 */
.type-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.type-option {
  padding: 16rpx 28rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  background-color: #fff;
  transition: all 0.3s;
}

.type-option.active {
  border-color: #4A8BF5;
  background-color: #f0f7ff;
}

.type-text {
  font-size: 26rpx;
  color: #666;
}

.type-option.active .type-text {
  color: #4A8BF5;
  font-weight: 500;
}

/* 输入框 */
.input-wrapper {
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  background-color: #fafafa;
  display: flex;
  align-items: center;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.input-placeholder {
  color: #ccc;
  font-size: 28rpx;
}

.char-count {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* 文本域 */
.textarea-wrapper {
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  background-color: #fafafa;
  position: relative;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.textarea-wrapper .char-count {
  position: absolute;
  bottom: 16rpx;
  right: 20rpx;
}

/* 提交按钮 */
.submit-section {
  margin: 40rpx 20rpx 0;
  padding: 0 10rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  transition: all 0.3s;
}

.submit-btn::after {
  border: none;
}

.submit-btn.active {
  background-color: #4A8BF5;
  color: #fff;
}

.submit-btn.disabled {
  background-color: #e8e8e8;
  color: #ccc;
}

/* 底部说明 */
.footer-tip {
  text-align: center;
  margin-top: 30rpx;
  padding: 0 40rpx;
}

.footer-tip text {
  font-size: 24rpx;
  color: #999;
}

<!--pages/merchant/list/list.wxml-->
<!-- 消息通知组件 -->
<message-notification />

<view class="container">
  <!-- 固定顶部背景 -->
  <view class="fixed-top-bg"></view>
  <!-- 自定义导航栏 -->
  <custom-nav-bar showBack="{{true}}" backgroundColor="#3F61CA" showImage="{{false}}"></custom-nav-bar>
  <!-- 顶部图片 -->
  <view class="top-image-container">
    <image class="top-image" src="{{topImageUrl}}" mode="aspectFit" />
  </view>

  <!-- 搜索栏和筛选条件容器 -->
  <view class="header-container">
    <!-- 搜索栏 -->
    <view class="search-bar">
      <view class="search-input-wrap">
        <image class="search-left-icon" src="../../../assets/icons/magnifying glass.png" mode="aspectFit" />
        <input class="search-input" type="text" placeholder="搜索商铺名称" placeholder-style="color:rgba(255,255,255,0.7);font-family:'PingFang SC',sans-serif;" value="{{keyword}}" bindinput="onSearchInput" bindconfirm="onSearch" />
        <view class="search-button" bindtap="onSearch">搜索</view>
      </view>
    </view>

    <!-- 筛选栏 -->
    <view class="filter-bar">
      <!-- 条件筛选（推荐/我的关注/经营类目/全部） -->
      <view class="filter-item">
        <picker mode="multiSelector" bindcolumnchange="onConditionColumnChange" bindchange="onConditionChange" range="{{conditionData}}" value="{{conditionIndex}}">
          <text>{{conditionDisplayText}}</text>
        </picker>
        <text class="filter-arrow">▾</text>
      </view>
      <!-- 城市筛选 -->
      <view class="filter-item">
        <picker mode="multiSelector" bindcolumnchange="onRegionColumnChange" bindchange="onRegionChange" range="{{regionData}}" value="{{regionIndex}}">
          <text>{{regionDisplayText}}</text>
        </picker>
        <text class="filter-arrow">▾</text>
      </view>
      <!-- 排序筛选 -->
      <view class="filter-item">
        <picker mode="multiSelector" bindchange="onSortFilterChange" range="{{sortFilterOptions}}" value="{{sortFilterIndex}}">
          <text>{{sortDisplayText}}</text>
        </picker>
        <text class="filter-arrow">▾</text>
      </view>
    </view>
  </view>

  <!-- 商户列表 -->
  <view class="merchant-list">
    <merchant-card
      wx:for="{{merchantList}}"
      wx:key="merchantId"
      item="{{item}}"
      iconCategory="{{iconCategory}}"
      bind:tap="onMerchantTap"
      bind:coupontap="onCouponTap"
    />

    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading-text">加载中...</view>

    <!-- 空状态 -->
    <view wx:if="{{!loading && merchantList.length === 0}}" class="empty-state">
      <text>暂无数据</text>
    </view>
  </view>
</view>
<!--pages/merchant/edit-apply/edit-apply.wxml-->
<custom-nav-bar showBack="{{true}}" useAuditStyle="{{true}}" auditTitle="编辑商户申请">
<view class="page">
  <view class="group_7">
    <scroll-view class="scroll-list" scroll-y enable-back-to-top show-scrollbar="{{false}}">
    <!-- 申请状态提示 -->
    <view class="status-card card">
      <view class="status-icon">⏳</view>
      <view class="status-title">编辑待审核申请</view>
      <view class="status-desc">您正在编辑已提交的商户入驻申请</view>
    </view>
    
    <!-- 商户信息 -->
    <view class="section-card card">
      <view class="section-title">商户信息</view>
      
      <view class="form-item">
        <view class="label">商户名称 <text class="required">*</text></view>
        <input class="input" placeholder="请输入商户名称" value="{{form.merchantName}}" data-field="merchantName" bindinput="handleInput" />
      </view>
      
      <view class="form-item">
        <view class="label">统一社会信用代码 <text class="required">*</text></view>
        <input class="input" maxlength="18" placeholder="请输入统一社会信用代码" value="{{form.unifiedSocialCreditCode}}" data-field="unifiedSocialCreditCode" bindinput="handleInput" />
      </view>
    </view>

    <!-- 法人信息 -->
    <view class="section-card card">
      <view class="section-title">法人信息</view>
      
      <view class="form-item">
        <view class="label">法人姓名 <text class="required">*</text></view>
        <input class="input" placeholder="请输入法人姓名" value="{{form.legalPerson}}" data-field="legalPerson" bindinput="handleInput" />
      </view>
      
      <view class="form-item">
        <view class="label">法人个人联系方式 <text class="required">*</text></view>
        <input class="input" maxlength="11" placeholder="请输入11位手机号" value="{{form.phone}}" data-field="phone" bindinput="handleInput" />
      </view>
    </view>

      <!-- 底部留白 -->
      <view class="bottom-space"></view>
      
      <!-- 提交按钮 -->
      <view class="bottom-action">
        <button class="btn btn-primary" loading="{{submitting}}" bindtap="submitEdit">保存修改</button>
      </view>
    </scroll-view>
  </view>
</view>
</custom-nav-bar>

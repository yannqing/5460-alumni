<!--pages/merchant/my-merchant/my-merchant.wxml-->
<!-- 自定义导航栏 -->
<custom-nav-bar showBack="{{true}}" useAuditStyle="{{true}}" auditTitle="我的商户">
<view class="page">
  <view class="group_7">
    <scroll-view class="scroll-list" scroll-y enable-back-to-top show-scrollbar="{{false}}">
      <!-- 加载中状态 -->
      <view class="loading-state" wx:if="{{loading}}">
        <text>加载中...</text>
      </view>
      
      <!-- 无数据状态 -->
      <view class="empty-state" wx:elif="{{!loading && merchantList.length === 0}}">
        <text>暂无商户数据</text>
      </view>
      
      <!-- 商户列表 -->
      <view class="merchant-list" wx:else>
        <view 
          class="merchant-item" 
          wx:for="{{merchantList}}" 
          wx:key="applicationId"
          bindtap="viewDetail"
          data-id="{{item.applicationId}}"
        >
          <view class="certification-badge" wx:if="{{item.reviewStatus === 1}}">
            <text>已发布</text>
          </view>
          <view class="certification-badge review" wx:elif="{{item.reviewStatus === 0}}">
            <text>待审核</text>
          </view>
          <view class="certification-badge pending" wx:elif="{{item.reviewStatus === 4}}">
            <text>待发布</text>
          </view>
          <view class="merchant-info">
            <view class="merchant-name">{{item.merchantName}}</view>
            <view class="merchant-details">
              <text class="detail-item">法人姓名：{{item.legalPerson || '-'}}</text>
            </view>
            <view class="merchant-contact">
              <view class="contact-item">法人电话：{{item.phone || '-'}}</view>
              <view class="contact-item city-row">
                <text>所在城市：{{item.city || '-'}}</text>
                <view class="perfect-info-btn" wx:if="{{item.reviewStatus === 4}}" catchtap="goToPerfectInfo" data-id="{{item.applicationId}}">
                  完善基本信息并发布
                </view>
                <view class="perfect-info-btn admin-btn" wx:if="{{item.reviewStatus === 1 && hasAdminPermission}}" catchtap="goToAdmin" data-id="{{item.applicationId}}">
                  管理商户
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
      
      <!-- 申请商户按钮 -->
      <view class="btn-group">
        <view class="apply-merchant-btn" bindtap="goToApplyMerchant">
          <text>申请商户</text>
        </view>
        <view class="join-association-btn" bindtap="goToJoinAssociation">
          <text>加入校友会</text>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
</custom-nav-bar>

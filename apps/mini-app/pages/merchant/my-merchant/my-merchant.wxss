/* pages/merchant/my-merchant/my-merchant.wxss */
.page {
  background-color: transparent;
  position: relative;
  width: 750rpx;
  height: 100%;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.group_7 {
  width: 714rpx;
  flex: 1;
  background-color: #FFFFFF;
  border-radius: 28.99rpx;
  display: flex;
  flex-direction: column;
  margin: 34rpx 0 20rpx 18rpx;
  padding: 30rpx 30rpx 30rpx 30rpx;
  box-sizing: border-box;
  overflow: hidden;
  position: relative;
  z-index: 1;
}

.scroll-list {
  flex: 1;
  width: 100%;
  min-height: 0;
  position: relative;
  z-index: 0;
}

/* 隐藏滚动条 */
.scroll-list ::-webkit-scrollbar {
  width: 0;
  height: 0;
  color: transparent;
  display: none;
}



.loading-state {
  padding: 80rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.empty-state {
  padding: 80rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.merchant-list {
  margin-bottom: 0;
}

.merchant-item {
  position: relative;
  padding: 30rpx;
  background-color: #F9F9F9;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.certification-badge {
  position: absolute;
  top: 0;
  right: 0;
  background-color: #52c41a;
  color: #fff;
  font-size: 12px;
  padding: 4px 12px;
  border-radius: 0 8px 0 8px;
  font-weight: 500;
  z-index: 1;
}

.certification-badge.pending {
  background-color: #fa8c16;
}

.certification-badge.review {
  background-color: #1890ff;
}

.merchant-item:hover {
  box-shadow: 0 4px 8px rgba(0,0,0,0.1);
}

.merchant-info {
  width: 100%;
}

.merchant-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.merchant-details {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  line-height: 1.5;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.status-tag {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
  background-color: #e6f7ff;
  color: #1890ff;
}

.status-tag.pending {
  background-color: #fff7e6;
  color: #fa8c16;
}

.perfect-info-btn {
  background-color: #3759C7;
  color: #fff;
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.perfect-info-btn:active {
  opacity: 0.8;
}

.merchant-contact {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.contact-item {
  display: block;
}

.city-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.merchant-scope-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}

.merchant-scope {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 0;
  line-height: 1.6;
  flex: 1;
  min-width: 0;
}

.scope-label {
  font-weight: 500;
}

.scope-content {
  display: inline-block;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  vertical-align: bottom;
}

/* 按钮组样式 */
.btn-group {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 申请商户按钮样式 */
.apply-merchant-btn {
  padding: 24rpx;
  background: linear-gradient(180deg, #3759C7 0%, #5273D2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(55, 89, 199, 0.3);
  transition: all 0.3s ease;
}

.apply-merchant-btn:active {
  background: linear-gradient(180deg, #2d4ab3 0%, #4562c0 100%);
  transform: scale(0.98);
}

/* 加入校友会按钮样式 */
.join-association-btn {
  padding: 24rpx;
  background: #FFFFFF;
  color: #3759C7;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  border-radius: 16rpx;
  border: 2rpx solid #3759C7;
  transition: all 0.3s ease;
}

.join-association-btn:active {
  background-color: #f0f4ff;
  transform: scale(0.98);
}



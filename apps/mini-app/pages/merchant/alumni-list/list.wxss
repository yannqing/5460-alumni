/* 布局尺寸与排列参考 pages/alumni-activity/list/list */
.activity-list-page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.activity-scroll {
  height: 100vh;
  box-sizing: border-box;
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 20rpx;
}

.activity-card {
  position: relative;
  gap: 20rpx;
  display: flex;
  padding: 20rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.activity-cover-wrapper {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
  border-radius: 12rpx;
  overflow: hidden;
}

.activity-cover {
  width: 100%;
  height: 100%;
  background: #f5f5f5;
}

.activity-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 8rpx 0;
  transform: translateY(3rpx);
  min-width: 0;
  overflow: hidden;
}

.activity-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  padding-right: 56rpx;
}

.association-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
}

.association-avatar {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background-color: #f0f0f0;
}

.association-name {
  font-size: 22rpx;
  color: #666;
  max-width: 350rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.coupon-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
}

.coupon-name {
  font-size: 22rpx;
  color: #666;
  max-width: 350rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.coupon-type {
  flex-shrink: 0;
  font-size: 18rpx;
  color: #fff;
  background: #6F8BE6;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.activity-time {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
}

.info-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.info-text {
  font-size: 24rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.loading-more {
  text-align: center;
  padding: 30rpx;
  font-size: 26rpx;
  color: #999;
}

.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
  font-size: 30rpx;
  color: #333;
}

.no-more {
  text-align: center;
  padding: 30rpx;
  font-size: 26rpx;
  color: #999;
}


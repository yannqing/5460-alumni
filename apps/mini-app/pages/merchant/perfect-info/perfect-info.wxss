.page {
  background-color: transparent;
  position: relative;
  width: 750rpx;
  height: 100%;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.loading-wrap {
  padding: 120rpx 40rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
}

.group_7 {
  width: 714rpx;
  flex: 1;
  background-color: #ffffff;
  border-radius: 28.99rpx;
  margin: 34rpx 0 20rpx 18rpx;
  padding: 30rpx;
  box-sizing: border-box;
  overflow: hidden;
  position: relative;
  z-index: 1;
}

.scroll-list {
  flex: 1;
  width: 100%;
  min-height: 0;
  position: relative;
  z-index: 0;
}

.scroll-list ::-webkit-scrollbar {
  width: 0;
  height: 0;
  color: transparent;
  display: none;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.required {
  color: #ff4d4f;
}

.form-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background-color: #fafafa;
}

.form-picker {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background-color: #fafafa;
  color: #333;
  line-height: 80rpx;
}

.picker-placeholder {
  color: #999;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background-color: #fafafa;
}

.merchant-readonly {
  width: 100%;
  min-height: 80rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  background-color: #f5f5f5;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  word-break: break-all;
}

.association-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
  border: 1rpx solid #e8e8e8;
  box-sizing: border-box;
}

.association-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background-color: #eee;
}

.association-avatar-ph {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #3759c7 0%, #5273d2 100%);
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
}

.association-meta {
  flex: 1;
  margin-left: 24rpx;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.association-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  word-break: break-all;
}

.image-upload-container {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.uploaded-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.license-wrap {
  width: 100%;
}

.uploaded-image {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  border-radius: 8rpx;
  overflow: hidden;
  border: 1rpx solid #e5e5e5;
}

.uploaded-image.bg-thumb {
  width: 200rpx;
  height: 200rpx;
}

.license-box {
  width: 100%;
  max-width: 100%;
  height: auto;
  min-height: 160rpx;
}

.license-img {
  width: 100%;
  display: block;
}

.image-preview {
  width: 100%;
  height: 100%;
}

.image-delete {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 36rpx;
  height: 36rpx;
  background-color: rgba(0, 0, 0, 0.6);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.upload-btn {
  margin: 0;
  padding: 0 40rpx;
  min-width: 200rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  font-weight: 400;
  color: #fff;
  background-color: #1677ff;
  border: 1rpx solid #1677ff;
  border-radius: 8rpx;
  box-sizing: border-box;
  text-align: center;
}

.upload-btn::after {
  border: none;
}

.upload-btn-hover {
  opacity: 0.9;
  background-color: #0958d9 !important;
  border-color: #0958d9 !important;
}

.submit-btn {
  width: 100%;
  margin-top: 24rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
  background-color: #1aad19;
  color: #fff;
}

.submit-btn::after {
  border: none;
}

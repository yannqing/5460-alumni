<custom-nav-bar showBack="{{true}}" useAuditStyle="{{true}}" auditTitle="完善商户信息">
  <view class="loading-wrap" wx:if="{{detailLoading}}">
    <text>加载中...</text>
  </view>
  <view class="page" wx:else>
    <!-- 申请信息（只读部分） -->
    <view class="form-card info-card">
      <view class="card-header">
        <text class="card-title">申请信息</text>
      </view>
      <view class="info-grid">
        <view class="info-item">
          <text class="info-label">商家名称</text>
          <text class="info-value">{{formData.merchantName || '—'}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">商家类型</text>
          <text class="info-value">{{formData.merchantType === 1 ? '校友商铺' : '普通商铺'}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">关联校友会</text>
          <view class="info-value" wx:if="{{formData.alumniAssociationId}}">
            <image wx:if="{{associationLogoUrl}}" class="info-avatar" src="{{associationLogoUrl}}" mode="aspectFill" />
            <text>{{associationDisplayName || '校友会'}}</text>
          </view>
          <text class="info-value" wx:else>未关联校友会</text>
        </view>
        <view class="info-item">
          <text class="info-label">统一社会信用代码</text>
          <text class="info-value">{{formData.unifiedSocialCreditCode || '—'}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">法人姓名</text>
          <text class="info-value">{{formData.legalPerson || '—'}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">法人联系电话</text>
          <text class="info-value">{{formData.phone || '—'}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">所在城市</text>
          <text class="info-value">{{formData.city || '—'}}</text>
        </view>
      </view>
    </view>

    <!-- 商户信息（可编辑部分） -->
    <view class="form-card">
      <view class="card-header">
        <text class="card-title">商户信息</text>
      </view>
      <form bindsubmit="submitForm">
        <view class="form-item">
          <text class="form-label">联系电话 <text class="required">*</text></text>
          <input class="form-input" type="number" placeholder="请输入11位手机号" value="{{formData.contactPhone}}" bindinput="onInputChange" data-field="contactPhone" maxlength="11" />
        </view>

        <view class="form-item">
          <text class="form-label">联系邮箱</text>
          <input class="form-input" placeholder="请输入联系邮箱" value="{{formData.contactEmail}}" bindinput="onInputChange" data-field="contactEmail" />
        </view>

        <view class="form-item">
          <text class="form-label">经营类目</text>
          <picker
            mode="selector"
            range="{{categoryOptions}}"
            range-key="name"
            value="{{categoryIndex}}"
            bindchange="onCategoryChange"
          >
            <view class="form-picker {{categoryIndex < 0 ? 'picker-placeholder' : ''}}">
              {{categoryIndex >= 0 ? categoryOptions[categoryIndex].name : '请选择经营类目'}}
            </view>
          </picker>
        </view>

        <view class="form-item">
          <text class="form-label">经营范围</text>
          <picker
            mode="selector"
            range="{{serviceOptions}}"
            range-key="name"
            value="{{serviceIndex}}"
            bindchange="onServiceChange"
            disabled="{{!formData.businessCategoryId}}"
          >
            <view class="form-picker {{serviceIndex < 0 ? 'picker-placeholder' : ''}}">
              {{serviceIndex >= 0 ? serviceOptions[serviceIndex].name : (formData.businessCategoryId ? '请选择经营范围' : '请先选择经营类目')}}
            </view>
          </picker>
        </view>

        <view class="form-item">
          <text class="form-label">商家 Logo</text>
          <view class="image-upload-container">
            <view class="uploaded-images">
              <view class="uploaded-image" wx:if="{{logoPreview}}">
                <image src="{{logoPreview}}" mode="aspectFill" class="image-preview" />
                <view class="image-delete" bindtap="clearLogo">×</view>
              </view>
            </view>
            <button class="upload-btn" bindtap="chooseLogo" hover-class="upload-btn-hover">上传 Logo</button>
          </view>
        </view>

        <view class="form-item">
          <text class="form-label">营业执照 <text class="required">*</text></text>
          <view class="image-upload-container">
            <view class="uploaded-images license-wrap">
              <view class="uploaded-image license-box" wx:if="{{licensePreview}}">
                <image src="{{licensePreview}}" mode="widthFix" class="license-img" />
                <view class="image-delete" bindtap="clearLicense">×</view>
              </view>
            </view>
            <button class="upload-btn" bindtap="chooseLicense" hover-class="upload-btn-hover">上传营业执照</button>
          </view>
        </view>

        <view class="form-item">
          <text class="form-label">商家背景图（可选）</text>
          <text class="form-hint">可上传多张，用于商家详情轮播，最多 9 张</text>
          <view class="image-upload-container">
            <view class="uploaded-images bg-images">
              <view
                class="uploaded-image bg-thumb"
                wx:for="{{backgroundImagePreviewUrls}}"
                wx:key="index"
              >
                <image src="{{item}}" mode="aspectFill" class="image-preview" />
                <view class="image-delete" bindtap="removeBackgroundImage" data-index="{{index}}">×</view>
              </view>
            </view>
            <button class="upload-btn" bindtap="chooseBackgroundImage" hover-class="upload-btn-hover">添加背景图</button>
          </view>
        </view>

        <view class="form-item">
          <text class="form-label">商户详情图片（可选）</text>
          <text class="form-hint">可上传多张，用于商家详情页展示，最多 9 张</text>
          <view class="image-upload-container">
            <view class="uploaded-images bg-images">
              <view
                class="uploaded-image bg-thumb"
                wx:for="{{detailImagePreviewUrls}}"
                wx:key="index"
              >
                <image src="{{item}}" mode="aspectFill" class="image-preview" />
                <view class="image-delete" bindtap="removeDetailImage" data-index="{{index}}">×</view>
              </view>
            </view>
            <button class="upload-btn" bindtap="chooseDetailImage" hover-class="upload-btn-hover">添加详情图</button>
          </view>
        </view>

        <button class="submit-btn" form-type="submit" loading="{{submitting}}" disabled="{{submitting}}">完善信息并发布</button>
      </form>
    </view>
  </view>
</custom-nav-bar>
/* pages/index/index.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f8f8f8;
  overflow: hidden;
}

.main-scroller {
  flex: 1;
  height: 100%;
  width: 100%;
}

/* 顶部 Banner */
.header-banner {
  height: 450rpx;
  position: relative;
  z-index: 10;
  background-color: #f8f8f8; /* 兜底背景色，防止图片加载时透明 */
}

.banner-swiper {
  width: 100%;
  height: 100%;
}

.banner-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.banner-default-bg {
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, #40B2E6 0%, #6BC5ED 100%);
}

.banner-content {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  padding-top: env(safe-area-inset-top);
  box-sizing: border-box;
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 1;
  pointer-events: none;
}

.platform-tag {
  pointer-events: auto;
}

/* 轮播图指示器样式 */
.banner-swiper .wx-swiper-dot {
  width: 12rpx;
  height: 12rpx;
  background-color: rgba(255, 255, 255, 0.5);
}

.banner-swiper .wx-swiper-dot-active {
  background-color: rgba(255, 255, 255, 1);
}

.platform-tag {
  position: fixed;
  left: 30rpx;
  background-color: transparent;
  border-radius: 30rpx;
  z-index: 1000; /* 确保在所有内容（包括吸顶菜单）之上 */
}


.platform-logo {
  width: 130rpx;
  height: 60rpx;
  display: block;
}

/* 核心吸顶包裹容器：为内部的 sticky 元素提供边界 */
.sticky-wrapper {
  position: relative;
  width: 100%;
}

/* 把 Banner 和 Nav 组合在一起的容器 */
.sticky-header-group {
  width: 100%;
  pointer-events: none; /* 穿透到内部元素 */
  background-color: #f8f8f8; /* 关键：吸顶组合增加实体背景，防止滚动穿透 */
}

.sticky-header-group > view {
  pointer-events: auto; /* 内部元素恢复交互 */
}

/* 导航区域 */
.nav-container {
  margin: -120rpx 15rpx 0;
  background-color: #fff;
  border-top-left-radius: 20rpx;
  border-top-right-radius: 20rpx;
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
  padding: 60rpx 20rpx 35rpx;
  /* 显式提升层级，确保在轮播图之上 */
  position: relative;
  z-index: 20;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
  transition: all 0.25s ease-out;
  background-color: #fff; /* 确保背景不透明 */
}

/* 导航区域被吸顶时的状态 (已取消扩展示效，保持卡片感) */
.nav-container.fixed {
  margin-left: 15rpx;
  margin-right: 15rpx;
  border-top-left-radius: 20rpx;
  border-top-right-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
  background-color: #fff;
}

.scroll-sentinel {
  height: 1rpx;
  width: 100%;
  visibility: hidden;
}

.nav-header {
  position: absolute;
  top: 0;
  left: 0;
}

.nav-title-tag {
  background-color: #38C7D4; /* 青蓝色，与主题色协调 */
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 20rpx 0 20rpx 0;
  box-shadow: 2rpx 2rpx 4rpx rgba(0,0,0,0.1);
}

.nav-grid {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.nav-item[data-disabled="true"] {
  pointer-events: none;
}

.nav-icon-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  width: 80rpx;
  height: 80rpx;
  /* background-color: #f9f9f9; */
  border-radius: 50%;
}

.nav-construction-tag {
  position: absolute;
  top: -12rpx;
  left: 50%;
  transform: translateX(10%);
  width: 67rpx;
  height: 27rpx;
  background: linear-gradient(90deg, #FF6B00 0%, #FFB800 100%);
  border: 1rpx solid #FFFFFF;
  border-radius: 13.5rpx;
  color: rgba(255, 255, 255, 1);
  font-size: 16rpx;
  font-family: PingFangSC-Semibold;
  font-weight: 600;
  line-height: 27rpx;
  text-align: center;
  opacity: 1;
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.nav-text {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

/* 手动下拉刷新 */
.manual-refresher {
  width: 100%;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f8f8f8;
  transition: height 0.2s ease-out, opacity 0.2s;
}

.dot-container {
  display: flex;
  gap: 12rpx;
  padding: 20rpx 0;
}


.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #38C7D4;
}

.dot.animating {
  animation: dot-pulse 1s infinite ease-in-out;
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}

.dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes dot-pulse {
  0%, 100% { transform: scale(1); opacity: 0.3; }
  50% { transform: scale(1.5); opacity: 1; }
}

/* 文章列表容器 */
.article-list {
  background-color: #f8f8f8;
  margin-top: 0;
  position: relative;
  z-index: 5;
  min-height: calc(100vh - 200rpx);
  padding: 0 0 100rpx 0;
}


.article-item {
  background-color: #fff;
  padding: 30rpx;
  margin: 0 15rpx 20rpx;
  display: flex;
  flex-direction: column;
  border-radius: 8rpx;
}

.article-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.article-body {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.user-avatar-wrapper {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  border: 1rpx solid #f0f0f0;
  overflow: hidden;
  flex-shrink: 0;
}

.user-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.user-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}

.publish-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.article-content {
  width: 100%;
  padding-left: 0;
}

.article-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #000;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.article-desc {
  font-size: 30rpx;
  color: #555;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.article-cover-wrapper {
  width: 100%;
  height: 350rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
  overflow: hidden;
  position: relative;
}

.article-cover {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
  object-fit: cover;
}

/* 有子文章时，图片上的标题覆盖层 */
.article-cover-wrapper.with-title-overlay .article-cover {
  filter: brightness(0.7);
}

.cover-title-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 30rpx 30rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.7), transparent);
}

.overlay-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1.4;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

/* 子文章列表 */
.children-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.child-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  transition: all 0.3s;
}

.child-item:active {
  background: #f0f0f0;
  transform: scale(0.98);
}

.child-content {
  flex: 1;
  min-width: 0;
}

.child-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.child-cover-wrapper {
  width: 120rpx;
  height: 90rpx;
  border-radius: 6rpx;
  background: #e0e0e0;
  overflow: hidden;
  flex-shrink: 0;
}

.child-cover {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.loading-more, .no-more, .empty-state {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* ========== 热门活动组件样式 ========== */
.hot-activity-section {
  padding: 0;
  margin-bottom: 20rpx;
  margin-top: 20rpx;
}

.hot-activity-box {
  background: transparent;
  border-radius: 20rpx;
  overflow: visible;
}

/* 顶部Banner图片 */
.hot-activity-banner,
.hot-shop-banner {
  width: 100%;
  display: block;
  position: relative;
}

.banner-img {
  width: 100%;
  display: block;
}

.banner-title {
  position: absolute;
  left: 24rpx;
  top: 30%;
  transform: translateY(-50%);
  height: 50rpx;
}

.banner-more {
  position: absolute;
  right: 34rpx;
  top: 22%;
  transform: translateY(-50%);
  font-size: 18rpx;
  color: #701FFF;
}

/* 活动列表 */
.hot-activity-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 20rpx;
  margin-top: -70rpx;
  background: #fff;
  border-radius: 0 0 20rpx 20rpx;
}

/* 活动卡片 */
.activity-card {
  position: relative;
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.activity-card:active {
  background: rgba(0, 0, 0, 0.03);
  transform: scale(0.99);
}

/* 右上角状态标签 */
.status-tag {
  position: absolute;
  top: 0;
  right: 0;
  width: 104rpx;
  height: 104rpx;
  transform: translateY(-40rpx);
  z-index: 10;
}

/* 活动封面 */
.activity-cover-wrapper {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.activity-cover {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 活动类型标签 */
.activity-type-tag {
  position: absolute;
  bottom: 12rpx;
  left: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 83rpx;
  height: 33rpx;
  background: #4A64C7;
  border-radius: 11rpx;
}

.type-text {
  font-size: 20rpx;
  color: #fff;
  line-height: 1;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  font-weight: 600;
}

/* 活动信息 */
.activity-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 8rpx 0;
  transform: translateY(3rpx);
  overflow: hidden;
}

.activity-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  padding-right: 56rpx;
}

/* 主办方信息 */
.activity-organizer {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
}

.organizer-avatar {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background-color: #f0f0f0;
}

.organizer-name {
  font-size: 22rpx;
  color: #666;
  max-width: 350rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.organizer-type {
  font-size: 18rpx;
  color: #fff;
  background: #6F8BE6;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.activity-time,
.activity-address {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
}

.info-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.info-text {
  font-size: 24rpx;
  color: #666;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 价格标签 */
.activity-price-tag {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
}

.price-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #ff4d4f;
}

.price-text.free {
  color: #52c41a;
}

/* 空状态 */
.hot-activity-empty,
.hot-shop-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 24rpx 40rpx;
  margin-top: -70rpx;
  gap: 16rpx;
  background: #fff;
  border-radius: 0 0 20rpx 20rpx;
}

.empty-img {
  width: 100%;
}

.empty-icon {
  font-size: 64rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

/* 加载中 */
.hot-activity-loading,
.hot-shop-loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx 24rpx;
  margin-top: -70rpx;
  background: #fff;
  border-radius: 0 0 20rpx 20rpx;
}

.loading-dots {
  display: flex;
  gap: 12rpx;
}

.loading-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #ff6b4a;
  animation: loading-dot-pulse 1s infinite ease-in-out;
}

.loading-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.loading-dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes loading-dot-pulse {
  0%, 100% { transform: scale(1); opacity: 0.4; }
  50% { transform: scale(1.3); opacity: 1; }
}

/* ========== 热门商铺组件样式 ========== */
.hot-shop-section {
  padding: 0;
  margin-bottom: 20rpx;
}

.hot-shop-box {
  background: transparent;
  border-radius: 20rpx;
  overflow: visible;
}

/* 商铺列表 */
.hot-shop-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 20rpx;
  margin-top: -70rpx;
  background: #fff;
  border-radius: 0 0 20rpx 20rpx;
}

/* 商铺卡片 */
.shop-card {
  position: relative;
  display: flex;
  gap: 20rpx;
  padding: 16rpx;
  background: transparent;
  border-radius: 16rpx;
}

.shop-card:active {
  background: rgba(0, 0, 0, 0.03);
  transform: scale(0.99);
}

/* 商铺封面 */
.shop-cover-wrapper {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.shop-cover {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 商铺类型标签 */
.shop-type-tag {
  position: absolute;
  left: 0;
  bottom: 0;
  background-color: rgba(24, 144, 255, 0.9);
  border-radius: 0 8rpx 0 12rpx;
  padding: 4rpx 12rpx;
}

.shop-type-tag .type-text {
  font-size: 18rpx;
  color: #fff;
  font-weight: 500;
}

/* 商铺信息 */
.shop-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  overflow: hidden;
  padding-top: 4rpx;
}

.shop-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #131315;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.shop-desc {
  display: flex;
  align-items: center;
}

.desc-text {
  font-size: 24rpx;
  color: #666;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.5;
}

.shop-address {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* 优惠标签 */
.shop-discount-tag {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  background: linear-gradient(135deg, #ff6b4a 0%, #ff9068 100%);
  border-radius: 16rpx;
  padding: 6rpx 16rpx;
}

.discount-text {
  font-size: 20rpx;
  font-weight: 500;
  color: #fff;
}

.loading-dot.shop {
  background-color: #1890ff;
}


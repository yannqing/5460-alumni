<!--pages/alumni-association/detail/detail.wxml-->
<custom-nav-bar showBack="{{true}}" useAuditStyle="{{true}}" auditTitle="校友会详情">
  <message-notification />

  <view class="association-detail-page">
    <scroll-view
      class="detail-scroll"
      scroll-y
      enhanced
      show-scrollbar="{{false}}"
      bindscrolltolower="onDetailScrollToLower"
      lower-threshold="120"
    >
    <view wx:if="{{associationInfo}}">
      <!-- 轮播背景图 -->
      <swiper class="cover-swiper" 
              indicator-dots="{{associationInfo.coverList.length > 1}}" 
              autoplay="{{associationInfo.coverList.length > 1}}" 
              circular="{{true}}"
              indicator-color="rgba(255, 255, 255, .3)"
              indicator-active-color="#ffffff">
        <swiper-item wx:for="{{associationInfo.coverList}}" wx:key="*this">
          <image class="cover-image" src="{{item}}" mode="aspectFill" />
        </swiper-item>
      </swiper>

      <!-- 白色内容区域 -->
      <view class="white-background-content">
        <view class="card">
          <view class="flex">
            <image class="avatar avatar-large" src="{{associationInfo.icon}}" mode="aspectFill" />
            <view class="flex-1 ml-20">
              <view class="name-row">
                <text class="text-primary text-bold">{{associationInfo.name}}</text>
                <!-- 认证等级标签 -->
                <image wx:if="{{associationInfo.certificationFlag === 1}}" class="cert-badge-img" src="{{certFirstImg}}" mode="heightFix" catchtap="goToCertificationInfo" />
                <image wx:elif="{{associationInfo.certificationFlag === 2}}" class="cert-badge-img" src="{{certSecondImg}}" mode="heightFix" catchtap="goToCertificationInfo" />
                <image wx:elif="{{associationInfo.certificationFlag === 3}}" class="cert-badge-img" src="{{certThirdImg}}" mode="heightFix" catchtap="goToCertificationInfo" />
                <view wx:else class="uncertified-tag" catchtap="goToCertificationInfo">未认证</view>
              </view>
              <view wx:if="{{associationInfo.schoolName}}" class="text-secondary mt-10 school-row">
                <view class="school-tag">{{associationInfo.schoolName}}</view>
                <view wx:if="{{associationInfo.status === 2}}" class="status-hint">（待发布）</view>
              </view>
              <view wx:if="{{associationInfo.location}}" class="text-placeholder mt-10 location-row">
                <image class="location-icon" src="{{iconLocation}}" mode="aspectFit" />
                <text>{{associationInfo.location}}</text>
              </view>
            </view>
          </view>
          <view class="mt-20">
            <view class="join-button {{associationInfo.applicationStatus === 0 ? 'pending' : ''}} {{associationInfo.applicationStatus === 1 ? 'joined' : ''}} {{associationInfo.applicationStatus === 2 ? 'rejected' : ''}}" bindtap="toggleJoin">
              <block wx:if="{{associationInfo.applicationStatus === 0}}">审核中</block>
              <block wx:elif="{{associationInfo.applicationStatus === 1}}">退出校友会</block>
              <block wx:elif="{{associationInfo.applicationStatus === 2}}">申请被拒绝</block>
              <block wx:else>加入校友会</block>
            </view>
          </view>
        </view>

        <tab-bar tabs="{{tabs}}" activeTab="{{activeTab}}" bind:tabchange="onTabChange" />

        <view wx:if="{{activeTab === 0}}" class="tab-content">
          <view class="card">
            <view class="text-bold mb-20">基本信息</view>
            <view class="basic-info-item">成员数量：{{associationInfo.memberCount || 0}}人</view>
            <view wx:if="{{associationInfo.description}}" class="basic-info-profile">
              <text class="basic-info-profile-text">简介：{{associationInfo.description}}</text>
            </view>

            <!-- 主要负责人：有 charge 信息时展示，不依赖 coreMemberList -->
            <view wx:if="{{associationInfo.chargeName || associationInfo.chargeWxId}}" class="show-members-section">
              <view class="show-members-title">主要负责人</view>
              <view class="show-members-list">
                <view class="show-member-item">
                  <view class="show-member-row-scroll">
                    <view class="show-member-row-inner">
                      <text class="show-member-role">{{associationInfo.chargeRole || '-'}}</text>
                      <view class="show-member-meta">
                        <text class="show-member-name">{{associationInfo.chargeName || '-'}}</text>
                        <text class="show-member-contact">{{associationInfo.contactInfo || '-'}}</text>
                      </view>
                    </view>
                  </view>
                </view>
              </view>
            </view>

            <!-- 其他负责人：仅展示 coreMemberList（已排除负责人/联系人，避免重复） -->
            <view wx:if="{{coreMemberList && coreMemberList.length > 0}}" class="show-members-section">
              <view class="show-members-title">其他负责人</view>
              <view class="show-members-list">
                <view class="show-member-item" wx:for="{{coreMemberList}}" wx:key="index" data-member="{{item}}">
                  <view class="show-member-row-scroll">
                    <view class="show-member-row-inner">
                      <text class="show-member-role">{{item.roleName || '-'}}</text>
                      <view class="show-member-meta">
                        <text class="show-member-name">{{item.username || '-'}}</text>
                        <text class="show-member-contact">{{item.userPhone || '-'}}</text>
                      </view>
                    </view>
                  </view>
                </view>
              </view>
            </view>

            <!-- 主要联系人（驻会代表）：有 zh 信息时展示，不依赖 coreMemberList -->
            <view wx:if="{{associationInfo.zhName || associationInfo.zhWxId}}" class="show-members-section">
              <view class="show-members-title">主要联系人</view>
              <view class="show-members-list">
                <view class="show-member-item">
                  <view class="show-member-row-scroll">
                    <view class="show-member-row-inner">
                      <text class="show-member-role">{{associationInfo.zhRole || '-'}}</text>
                      <view class="show-member-meta">
                        <text class="show-member-name">{{associationInfo.zhName || '-'}}</text>
                        <text class="show-member-contact">{{associationInfo.zhPhone || '-'}}</text>
                      </view>
                    </view>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </view>

        <!-- 组织结构标签页 -->
        <view wx:if="{{activeTab === 1}}" class="tab-content">
          <view class="card dashboard-card">
            <view class="section-header">
              <view class="section-title">
                <view class="text-bold">组织架构</view>
                <view class="section-subtitle">组织架构展示</view>
              </view>
            </view>

            <view class="role-list-section">
              <!-- 骨架屏 -->
              <view wx:if="{{organizationLoading}}" class="skeleton-role-list">
                <view class="role-item skeleton-item" wx:for="[1,2,3]" wx:key="*this">
                  <view class="role-header">
                    <view class="role-name-container">
                      <text class="expand-icon">▶</text>
                      <view class="skeleton-role-name"></view>
                    </view>
                    <view class="skeleton-role-count"></view>
                  </view>
                </view>
              </view>
              
              <!-- 空状态 -->
              <view wx:elif="{{roleList.length === 0}}" class="empty-container">
                <text class="empty-text">暂无角色数据</text>
              </view>
              
              <org-structure list="{{roleList}}" loading="{{organizationLoading}}" empty-text="暂无角色数据" />
            </view>
          </view>
        </view>

        <!-- 最新动态标签页 -->
        <view wx:if="{{activeTab === 2}}" class="tab-content">
          <!-- 活动列表 -->
          <view class="card dashboard-card" wx:if="{{activityList && activityList.length > 0}}">
            <view class="section-header">
              <view class="section-title">
                <view class="text-bold">活动</view>
                <view class="section-subtitle">近期热点校友活动</view>
              </view>
            </view>
            <view class="dashboard-list activity" wx:for="{{activityList}}" wx:key="activityId">
              <view class="dashboard-item activity-item" bindtap="viewActivityDetail" data-id="{{item.activityId}}">
                <view class="item-leading">
                  <image class="item-cover" src="{{item.coverImage}}" mode="aspectFill" />
                </view>
                <view class="item-content">
                  <view class="activity-header">
                    <view class="item-title">{{item.activityTitle}}</view>
                    <view class="activity-time">{{item.startTime}}</view>
                  </view>
                  <view class="activity-footer">
                    <view wx:if="{{item.locationText}}" class="item-desc location-row">
                      <image class="location-icon" src="{{iconLocation}}" mode="aspectFit" />
                      <text>{{item.locationText}}</text>
                    </view>
                    <view wx:if="{{item.maxParticipants !== null}}" class="activity-participants">
                      <image class="participants-icon" src="/assets/icons/people.png" mode="aspectFit" />
                      <text>{{item.currentParticipants}}/{{item.maxParticipants}}人</text>
                    </view>
                  </view>
                </view>
              </view>
            </view>
          </view>

          <!-- 资讯列表 -->
          <view class="card mt-20 dashboard-card" wx:if="{{articleList && articleList.length > 0}}">
            <view class="section-header">
              <view class="section-title">
                <view class="text-bold">资讯</view>
                <view class="section-subtitle">最新动态与通知</view>
              </view>
            </view>
            <view class="dashboard-list news">
              <view class="dashboard-item news-item" wx:for="{{articleList}}" wx:key="id" bindtap="goToArticleDetail" data-index="{{index}}">
                <view class="item-leading">
                  <image class="item-cover" src="{{item.cover}}" mode="aspectFill" />
                </view>
                <view class="item-content">
                  <view class="news-header">
                    <view class="item-title">{{item.title}}</view>
                  </view>
                  <view class="news-footer">
                    <view class="item-meta">
                      <text class="news-time">{{item.time}}</text>
                    </view>
                  </view>
                </view>
              </view>
            </view>
          </view>

          <!-- 空状态 -->
          <view class="empty-container" wx:if="{{(!activityList || activityList.length === 0) && (!articleList || articleList.length === 0)}}">
            <view class="empty-icon">📭</view>
            <view class="empty-text">暂无最新动态</view>
            <view class="empty-desc">该校友会还没有发布活动或资讯</view>
          </view>
        </view>

        <view wx:if="{{activeTab === 3}}">
          <view class="member-list">
            <!-- 骨架屏 -->
            <view wx:if="{{memberLoading && members.length === 0}}" class="skeleton-list">
              <view class="member-item skeleton-item" wx:for="[1,2,3,4,5]" wx:key="*this">
                <view class="member-avatar skeleton-avatar"></view>
                <view class="member-info">
                  <view class="member-name-row">
                    <view class="skeleton-name"></view>
                    <view class="skeleton-tag"></view>
                  </view>
                  <view class="skeleton-text"></view>
                </view>
              </view>
            </view>
            
            <!-- 成员列表 -->
            <view wx:elif="{{members.length > 0}}">
              <view class="member-item" wx:for="{{members}}" wx:key="id" bindtap="viewMemberDetail" data-id="{{item.id}}" data-name="{{item.name}}">
                <image class="member-avatar" src="{{item.avatar}}" mode="aspectFill" />
                <view class="member-info">
                  <view class="member-name-row">
                    <text class="member-name">{{item.name}}</text>
                    <view class="member-tag">{{item.role}}</view>
                  </view>
                  <view class="member-company">{{item.company}}</view>
                </view>
              </view>
              <view wx:if="{{memberLoadingMore}}" class="member-list-footer">加载中...</view>
              <view wx:elif="{{!memberHasMore}}" class="member-list-footer">没有更多了</view>
            </view>
            
            <!-- 空状态 -->
            <view wx:else class="empty-container">
              <view class="empty-icon">👥</view>
              <view class="empty-text">暂无成员数据</view>
              <view class="empty-desc">该校友会还没有成员，快来加入吧</view>
            </view>
          </view>
        </view>
      </view>
    </view>
    </scroll-view>
  </view>
</custom-nav-bar>

<!-- 悬浮添加按钮 (FAB) -->
<view class="fab-btn" wx:if="{{showFab && associationInfo.status !== 2}}" bindtap="showActionSheet">
  <view class="fab-icon">+</view>
</view>

<!-- 弹窗/动作面板 -->
<view class="action-sheet-mask {{showAction ? 'show' : ''}}" bindtap="hideActionSheet">
  <view class="action-sheet {{showAction ? 'show' : ''}}" catchtap="true">
    <view class="action-header">
      <view class="action-title">快捷管理</view>
      <view class="action-subtitle">选择您要执行的操作</view>
    </view>
    <view class="action-body">
      <view class="action-item" bindtap="navToAddActivity">
        <view class="item-icon-wrap activity-bg">
          <text class="action-emoji">🏃</text>
        </view>
        <view class="item-info">
          <text class="item-name">新增活动</text>
        </view>
      </view>
      <view class="action-item" bindtap="navToAddNews">
        <view class="item-icon-wrap news-bg">
          <text class="action-emoji">📰</text>
        </view>
        <view class="item-info">
          <text class="item-name">新增资讯</text>
        </view>
      </view>
    </view>
    <view class="action-footer" bindtap="hideActionSheet">取消</view>
  </view>
</view>

<!--pages/alumni-association/member/member.wxml-->
<custom-nav-bar showBack="{{true}}" useAuditStyle="{{true}}" auditTitle="校友会成员">
<view class="page">
  <!-- 校友会选择卡片（与城市/校促会成员管理一致，固定不滚动） -->
  <view class="group_5" wx:if="{{!hasSingleAlumniAssociation && hasAlumniAdminPermission}}">
    <text class="text_14">校友会组织</text>
    <text class="label_text">选择校友会</text>
    <view class="text-wrapper_8" bindtap="showAlumniAssociationSelector">
      <text class="text_15">{{selectedAlumniAssociationName || '请选择校友会'}}</text>
    </view>
  </view>

  <!-- 成员列表卡片（与城市成员管理一致：固定标题，仅内部 scroll-list 滚动） -->
  <view class="group_7">
    <view class="member-list-header">
      <text class="text_20">成员列表</text>
      <view class="invite-btn-wrap">
        <button class="invite-btn" bindtap="showInviteModal">+邀请加入</button>
      </view>
    </view>
    <scroll-view class="scroll-list" scroll-y enable-back-to-top enhanced show-scrollbar="{{false}}">
      <view wx:if="{{memberLoading}}" class="loading-state">
        <text>加载成员中...</text>
      </view>
      <view class="member-list" wx:else>
        <view class="member-item" wx:for="{{memberList}}" wx:key="wxId">
          <view class="member-item-left {{item.wxId ? 'clickable' : ''}}" bindtap="onMemberTap" data-member="{{item}}">
            <view class="member-avatar">
              <image class="avatar-img" src="{{item.avatarUrl || defaultUserAvatarUrl}}"></image>
            </view>
            <view class="member-text-group">
              <text class="member-name">{{item.name || item.nickname || '未命名'}}</text>
              <text class="member-gender-text" wx:if="{{item.gender}}">{{item.gender === 1 ? '男' : '女'}}</text>
            </view>
          </view>
          <view class="member-tags-group">
            <view class="member-status-tags" wx:if="{{!item.wxId || item.isShowOnHome === 1}}">
              <text class="unregistered-tag" wx:if="{{!item.wxId}}">未注册</text>
              <text class="show-on-home-tag" wx:if="{{item.isShowOnHome === 1}}">主页展示</text>
            </view>
            <view class="member-role-tag">{{item.organizeArchiRole && item.organizeArchiRole.roleOrName ? item.organizeArchiRole.roleOrName : '普通成员'}}</view>
          </view>
          <view class="member-actions">
            <view class="edit-btn" catchtap="openEditModal" data-member="{{item}}">编辑</view>
            <view class="delete-btn" catchtap="deleteMember" data-member="{{item}}">删除</view>
          </view>
        </view>
        <view class="empty-state" wx:if="{{memberList.length === 0}}">
          <text>{{selectedAlumniAssociationId ? '暂无成员数据' : '请先选择校友会'}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 校友会选择器弹窗 -->
  <view class="alumni-association-picker" wx:if="{{showAlumniAssociationPicker}}">
    <view class="picker-overlay" bindtap="cancelAlumniAssociationSelect"></view>
    <view class="picker-content">
      <view class="picker-header">
        <text class="picker-title">选择校友会</text>
        <text class="picker-cancel" bindtap="cancelAlumniAssociationSelect">取消</text>
      </view>
      <view class="picker-list">
        <view
          class="picker-item {{selectedAlumniAssociationId == item.alumniAssociationId ? 'selected' : ''}}"
          wx:for="{{alumniAssociationList}}"
          wx:key="alumniAssociationId"
          data-alumni-association-id="{{item.alumniAssociationId}}"
          data-alumni-association-name="{{item.alumniAssociationName}}"
          bindtap="selectAlumniAssociation"
        >
          <view class="picker-item-left">
            <image class="picker-item-logo" src="{{item.logo || defaultUserAvatarUrl}}" mode="aspectFill" />
            <view class="picker-item-info">
              <text class="item-name">{{item.alumniAssociationName}}</text>
              <text class="item-location" wx:if="{{item.location}}">{{item.location}}</text>
            </view>
          </view>
          <text class="item-check" wx:if="{{selectedAlumniAssociationId == item.alumniAssociationId}}">✓</text>
        </view>
        <view class="picker-empty" wx:if="{{alumniAssociationList.length === 0}}">
          <text>暂无校友会数据</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 邀请成员弹窗 -->
  <view class="invite-modal" wx:if="{{showInviteModal}}">
    <view class="modal-overlay" bindtap="hideInviteModal"></view>
    <view class="modal-content invite-modal-content">
      <view class="modal-header">
        <text class="modal-title">邀请成员加入</text>
        <text class="modal-close" bindtap="hideInviteModal">×</text>
      </view>
      <view class="modal-body">
        <!-- 邀请方式选择 -->
        <view class="invite-method-tabs">
          <view class="invite-method-tab {{inviteMethod === 'search' ? 'active' : ''}}" bindtap="switchInviteMethod" data-method="search">
            <text>搜索邀请</text>
          </view>
          <view class="invite-method-tab {{inviteMethod === 'link' ? 'active' : ''}}" bindtap="switchInviteMethod" data-method="link">
            <text>链接邀请</text>
          </view>
          <view class="invite-method-tab {{inviteMethod === 'qrcode' ? 'active' : ''}}" bindtap="switchInviteMethod" data-method="qrcode">
            <text>二维码邀请</text>
          </view>
        </view>

        <!-- 搜索邀请内容 -->
        <view class="invite-method-content" wx:if="{{inviteMethod === 'search'}}">
          <view class="alumni-name-field" catchtap="preventBubble">
            <view class="field-label">校友姓名</view>
            <view class="field-input-wrapper">
              <input
                class="field-input"
                placeholder="请输入校友姓名进行搜索"
                placeholder-class="field-placeholder"
                adjust-position="{{false}}"
                bindinput="onMemberNameInput"
                bindfocus="onMemberNameFocus"
                value="{{inviteForm.name}}"
              />
            </view>
            <scroll-view scroll-y class="alumni-search-dropdown" show-scrollbar="{{false}}" wx:if="{{showAlumniSearchResults && alumniSearchResults.length > 0}}">
              <view wx:for="{{alumniSearchResults}}" wx:key="userId" class="alumni-search-item" bindtap="selectAlumni" data-index="{{index}}">
                <image wx:if="{{item.avatarUrl}}" src="{{item.avatarUrl}}" class="alumni-avatar" mode="aspectFill" />
                <image wx:else src="{{defaultUserAvatarUrl}}" class="alumni-avatar" mode="aspectFill" />
                <view class="alumni-item-info">
                  <text class="alumni-item-name">{{item.name || item.nickname || item.realName}}</text>
                  <text class="alumni-item-school">{{item.school || '暂无学校信息'}}</text>
                </view>
              </view>
            </scroll-view>
          </view>
          <view class="invite-tip">
            <text class="invite-tip-icon">i</text>
            <text class="invite-tip-text">邀请后，用户需在通知中确认才能加入</text>
          </view>
        </view>

        <!-- 链接邀请内容 -->
        <view class="invite-method-content" wx:if="{{inviteMethod === 'link'}}">
          <view class="invite-link-section">
            <view class="invite-link-title">分享邀请</view>
            <view class="invite-link-desc">点击下方按钮，将邀请卡片分享给微信好友，好友点击即可申请加入校友会</view>
            <view class="invite-share-info">
              <text class="invite-share-name">{{selectedAlumniAssociationName || '校友会'}}</text>
              <text class="invite-share-hint">邀请您加入</text>
            </view>
            <view class="invite-tip">
              <text class="invite-tip-icon">i</text>
              <text class="invite-tip-text">好友通过分享卡片申请后，需等待管理员审核</text>
            </view>
          </view>
        </view>

        <!-- 二维码邀请内容 -->
        <view class="invite-method-content" wx:if="{{inviteMethod === 'qrcode'}}">
          <view class="invite-qrcode-section">
            <view class="invite-qrcode-title">邀请二维码</view>
            <view class="invite-qrcode-desc">好友扫描二维码即可申请加入校友会</view>
            <view class="invite-qrcode-box">
              <image class="invite-qrcode-img" src="{{inviteQrcodeUrl}}" mode="aspectFit" wx:if="{{inviteQrcodeUrl}}"></image>
              <view class="invite-qrcode-loading" wx:elif="{{qrcodeLoading}}">
                <text>生成中...</text>
              </view>
              <view class="invite-qrcode-placeholder" wx:else>
                <text>请先选择校友会</text>
              </view>
            </view>
            <view class="invite-tip">
              <text class="invite-tip-icon">i</text>
              <text class="invite-tip-text">好友扫码申请后，需等待管理员审核</text>
            </view>
          </view>
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn btn-cancel" bindtap="hideInviteModal">取消</button>
        <button class="btn btn-confirm" wx:if="{{inviteMethod === 'search'}}" bindtap="submitInvite">确定邀请</button>
        <button class="btn btn-confirm" wx:if="{{inviteMethod === 'link'}}" open-type="share">分享给好友</button>
        <button class="btn btn-confirm" wx:if="{{inviteMethod === 'qrcode'}}" bindtap="saveQrcode">保存二维码</button>
      </view>
    </view>
  </view>

  <!-- 编辑成员信息弹窗 -->
  <view class="edit-modal" wx:if="{{showEditModal}}">
    <view class="modal-overlay" bindtap="hideEditModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">编辑成员信息</text>
        <text class="modal-close" bindtap="hideEditModal">×</text>
      </view>
      <scroll-view class="modal-body" scroll-y>
        <view class="form-item">
          <text class="label">成员头像</text>
          <view class="member-info-display">
            <image class="avatar-small" src="{{editingMember.avatarUrl || defaultUserAvatarUrl}}"></image>
            <text class="member-name-display">{{editingMember.name || editingMember.nickname || '未命名'}}</text>
          </view>
        </view>
        <!-- 未注册用户才显示用户名编辑 -->
        <view class="form-item" wx:if="{{!editingMember.wxId}}">
          <text class="label">用户名</text>
          <input
            class="form-input"
            placeholder="请输入用户名"
            value="{{editingMember.editUsername}}"
            bindinput="onEditUsernameInput"
          />
        </view>
        <!-- 未注册用户才显示手机号编辑 -->
        <view class="form-item" wx:if="{{!editingMember.wxId}}">
          <text class="label">手机号</text>
          <input
            class="form-input"
            type="number"
            maxlength="11"
            placeholder="请输入手机号"
            value="{{editingMember.editUserPhone}}"
            bindinput="onEditUserPhoneInput"
          />
        </view>
        <view class="form-item">
          <text class="label">所属单位/职位</text>
          <input
            class="form-input"
            placeholder="请输入所属单位或职位"
            value="{{editingMember.editUserAffiliation}}"
            bindinput="onEditUserAffiliationInput"
          />
        </view>
        <view class="form-item form-item-switch">
          <text class="label">主页展示</text>
          <switch
            checked="{{editingMember.editIsShowOnHome === 1}}"
            bindchange="onEditIsShowOnHomeChange"
            color="#1890ff"
          />
        </view>
      </scroll-view>
      <view class="modal-footer">
        <button class="btn btn-cancel" bindtap="hideEditModal">取消</button>
        <button class="btn btn-confirm" bindtap="submitEdit">保存</button>
      </view>
    </view>
  </view>
</view>
</custom-nav-bar>

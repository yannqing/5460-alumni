/* pages/alumni-association/member/member.wxss */
/* 复用城市/校促会成员管理页样式：.page 布局，固定 group_5，仅 group_7 内 scroll-list 滚动 */
.page {
  background-color: transparent;
  position: relative;
  width: 750rpx;
  height: 100%;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.container {
  height: 100%;
  background-color: #f5f5f5;
  padding: 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.form-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.form-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 30rpx;
  color: #333;
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}

/* 校友会选择卡片（与城市成员管理一致：固定不滚动） */
.page .group_5 {
  width: 714rpx;
  min-height: auto;
  margin: 47rpx 0 0 18rpx;
  padding: 38rpx 43rpx 27rpx 43rpx;
  flex-shrink: 0;
}

.group_5 {
  background-color: #FFFFFF;
  border-radius: 28.99rpx;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  flex-shrink: 0;
}

.group_5 .text_14 {
  width: auto;
  height: 40rpx;
  overflow-wrap: break-word;
  color: rgba(0,0,0,1);
  font-size: 29rpx;
  letter-spacing: 0rpx;
  font-family: PingFangSC-Semibold, -apple-system, sans-serif;
  font-weight: 600;
  text-align: left;
  white-space: nowrap;
  line-height: 40rpx;
}

.group_5 .label_text {
  width: auto;
  height: 36rpx;
  overflow-wrap: break-word;
  color: rgba(0,0,0,0.6);
  font-size: 25rpx;
  font-family: PingFangSC-Regular, -apple-system, sans-serif;
  font-weight: normal;
  text-align: left;
  white-space: nowrap;
  line-height: 36rpx;
  margin-top: 16rpx;
  display: block;
}

.group_5 .text-wrapper_8 {
  height: 80rpx;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  border: 1rpx solid #E0E0E0;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  margin-top: 16rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  position: relative;
}

.group_5 .text_15 {
  flex: 1;
  height: 36rpx;
  overflow-wrap: break-word;
  color: rgba(0,0,0,0.85);
  font-size: 28rpx;
  font-family: PingFangSC-Regular, -apple-system, sans-serif;
  font-weight: normal;
  text-align: left;
  white-space: nowrap;
  line-height: 36rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

.group_5 .text-wrapper_8::after {
  content: '▼';
  color: #999;
  font-size: 20rpx;
  margin-left: 10rpx;
}

/* 校友会选择器弹窗（与城市成员管理一致） */
.alumni-association-picker {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10000;
}

.alumni-association-picker .picker-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.alumni-association-picker .picker-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  border-radius: 20rpx 20rpx 0 0;
  max-height: 70vh;
  overflow: hidden;
}

.alumni-association-picker .picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.alumni-association-picker .picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.alumni-association-picker .picker-cancel {
  font-size: 28rpx;
  color: #999;
}

.alumni-association-picker .picker-list {
  max-height: calc(50vh + 40px);
  overflow-y: auto;
  padding: 0 30rpx;
}

.alumni-association-picker .picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.alumni-association-picker .item-name {
  font-size: 28rpx;
  color: #333;
}

.alumni-association-picker .item-check {
  font-size: 32rpx;
  color: #52c41a;
  font-weight: 600;
}

.alumni-association-picker .picker-empty {
  padding: 60rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.list-footer {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 0 16rpx;
  color: #999;
  font-size: 24rpx;
}

/* 成员列表卡片（与城市成员管理一致：固定标题，仅 scroll-list 内滚动） */
.group_7 {
  width: 714rpx;
  flex: 1;
  max-height: 80vh;
  background-color: #FFFFFF;
  border-radius: 28.99rpx;
  display: flex;
  flex-direction: column;
  margin: 34rpx 0 20rpx 18rpx;
  padding: 38rpx 25rpx 20rpx 25rpx;
  box-sizing: border-box;
  overflow: hidden;
  position: relative;
  z-index: 1;
}

.scroll-list {
  flex: 1;
  width: 100%;
  height: 0;
  min-height: 0;
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.scroll-list::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}

.group_7 .member-list-header {
  width: 100%;
  height: 58rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin: 0 0 11rpx 18rpx;
  padding: 0;
  box-sizing: border-box;
  flex-shrink: 0;
}

.group_7 .text_20 {
  width: auto;
  height: 40rpx;
  overflow-wrap: break-word;
  color: rgba(0,0,0,1);
  font-size: 29rpx;
  letter-spacing: 0rpx;
  font-family: PingFangSC-Semibold, -apple-system, sans-serif;
  font-weight: 600;
  text-align: left;
  white-space: nowrap;
  line-height: 40rpx;
}

.invite-btn-wrap {
  flex-shrink: 0;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  margin-right: 24rpx;
}

.group_7 .invite-btn {
  background-color: rgba(24,144,255,1);
  border-radius: 7rpx;
  height: 58rpx;
  min-width: 167rpx;
  padding: 0 24rpx;
  font-size: 25rpx;
  color: rgba(255,255,255,1);
  line-height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  white-space: nowrap;
}

.group_7 .invite-btn-disabled {
  background-color: #d9d9d9 !important;
  color: rgba(0, 0, 0, 0.25) !important;
}

.group_7 .member-list {
  width: 100%;
  margin-top: 11rpx;
  padding-bottom: 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.group_7 .member-item {
  background-color: rgba(249,249,249,1);
  border-radius: 14rpx;
  width: 100%;
  min-height: 125rpx;
  margin-bottom: 14rpx;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 20rpx 0;
  box-sizing: border-box;
}

.group_7 .member-item:last-child {
  margin-bottom: 0;
}

.member-item-left {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  margin: 0 0 0 31rpx;
  flex: 0 0 auto;
  min-width: 0;
  max-width: 42%;
}

.group_7 .member-avatar {
  width: 65rpx;
  height: 65rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}

.group_7 .avatar-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.member-text-group {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  margin-left: 24rpx;
  min-height: 78rpx;
}

.group_7 .member-name {
  width: auto;
  max-width: 200rpx;
  height: 36rpx;
  overflow-wrap: break-word;
  color: rgba(0,0,0,1);
  font-size: 25rpx;
  letter-spacing: 0rpx;
  font-family: PingFangSC-Semibold, -apple-system, sans-serif;
  font-weight: 600;
  text-align: left;
  white-space: nowrap;
  line-height: 36rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

.member-gender-text {
  width: auto;
  height: 36rpx;
  overflow-wrap: break-word;
  color: rgba(0,0,0,1);
  font-size: 25rpx;
  font-family: PingFangSC-Regular, -apple-system, sans-serif;
  font-weight: normal;
  text-align: left;
  white-space: nowrap;
  line-height: 36rpx;
  margin-top: 5rpx;
}

/* 标签组容器（角色+状态标签上下排列） */
.member-tags-group {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
  margin-left: 12rpx;
  flex: 1;
  min-width: 0;
  padding-right: 8rpx;
}

/* 状态标签容器（未注册+主页展示横向排列） */
.member-status-tags {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  max-width: 100%;
}

.member-role-tag {
  background-color: rgba(24,144,255,1);
  border-radius: 12rpx;
  min-height: 36rpx;
  height: auto;
  display: inline-block;
  width: auto;
  max-width: 100%;
  box-sizing: border-box;
  padding: 8rpx 12rpx;
  font-size: 22rpx;
  letter-spacing: 0rpx;
  font-family: PingFangSC-Semibold, -apple-system, sans-serif;
  font-weight: 600;
  color: rgba(255,255,255,1);
  line-height: 1.45;
  word-break: break-word;
  overflow-wrap: break-word;
  white-space: normal;
  vertical-align: top;
}

/* 标签无文本时不展示底色块 */
.member-role-tag:empty {
  display: none;
}

.group_7 .member-actions {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  margin-left: auto;
  padding: 0 12rpx 0 4rpx;
  gap: 8rpx;
  flex-shrink: 0;
  flex: 0 0 auto;
}

.group_7 .edit-btn {
  background-color: rgba(255,255,255,1);
  border-radius: 12rpx;
  height: 34rpx;
  min-width: 56rpx;
  padding: 0 10rpx;
  border: 1rpx solid rgba(67,100,204,1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  letter-spacing: 0rpx;
  font-family: PingFangSC-Semibold, -apple-system, sans-serif;
  font-weight: 600;
  color: rgba(67,100,204,1);
  line-height: 1;
  margin-left: 0;
  box-sizing: border-box;
}

.group_7 .delete-btn {
  box-shadow: 0px 1px 6px 0px rgba(194,194,255,0.28);
  background-color: rgba(255,255,255,1);
  border-radius: 12rpx;
  height: 34rpx;
  min-width: 56rpx;
  padding: 0 10rpx;
  border: 1rpx solid rgba(176,54,62,1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  letter-spacing: 0rpx;
  font-family: PingFangSC-Semibold, -apple-system, sans-serif;
  font-weight: 600;
  color: rgba(176,54,62,1);
  line-height: 1;
  margin-left: 0;
  box-sizing: border-box;
}

.alumni-name-field {
  position: relative;
  margin-bottom: 30rpx;
}

.field-label {
  font-size: 28rpx;
  color: #666;
  line-height: 40rpx;
  height: 40rpx;
  margin-bottom: 16rpx;
  display: block;
}

.field-input-wrapper {
  position: relative;
  width: 100%;
  height: 80rpx;
}

.field-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #eee;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 80rpx;
  background-color: #fff;
  box-sizing: border-box;
  color: #333;
}

.field-placeholder {
  color: #999;
  font-size: 28rpx;
}

.alumni-search-dropdown {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  margin-top: 8rpx;
  background-color: #fff;
  border: 1rpx solid #eee;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
  max-height: 400rpx;
  overflow: hidden;
}

.alumni-search-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.alumni-search-item:last-child {
  border-bottom: none;
}

.alumni-search-item:active {
  background-color: #f5f5f5;
}

.alumni-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.alumni-item-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.alumni-item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 4rpx;
}

.alumni-item-school {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.role-selector {
  border: 1rpx solid #eee;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  height: 80rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #fff;
  cursor: pointer;
}

.selector-text {
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.selector-arrow {
  color: #999;
  font-size: 20rpx;
}

.role-name {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.invite-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.modal-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background-color: #fff;
  border-radius: 20rpx;
  width: 80%;
  max-width: 600rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  cursor: pointer;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
}

.modal-body {
  padding: 30rpx;
}

.modal-body .form-item {
  margin-bottom: 30rpx;
}

.modal-body .label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}

.modal-body .input {
  border: 1rpx solid #eee;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  height: 80rpx;
}

.modal-footer {
  display: flex;
  justify-content: flex-end;
  padding: 30rpx;
  border-top: 1rpx solid #f0f0f0;
  gap: 20rpx;
}

.modal-footer .btn {
  padding: 0 30rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: none;
  cursor: pointer;
}

.modal-footer .btn-cancel {
  background-color: #f5f5f5;
  color: #333;
}

.modal-footer .btn-confirm {
  background-color: #1890ff;
  color: #fff;
}

.edit-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1001;
}

.member-info-display {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #fafafa;
  border-radius: 8rpx;
  border: 1rpx solid #eee;
}

.avatar-small {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  object-fit: cover;
}

.member-name-display {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

/* 编辑弹窗容器 - 更大的宽度 */
.edit-modal .modal-content {
  width: 90%;
  max-width: 680rpx;
}

/* 编辑弹窗表单输入框 */
.form-input {
  border: 1rpx solid #eee;
  padding: 0 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  height: 80rpx;
  background-color: #fff;
  line-height: 80rpx;
}

.form-input:focus {
  border-color: #1890ff;
}

/* 角色选择器样式（使用特定前缀避免与校友会选择器冲突） */
.role-picker-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 1rpx solid #eee;
  padding: 0 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  height: 80rpx;
  background-color: #fff;
  line-height: 80rpx;
}

.role-picker-text {
  flex: 1;
  color: #333;
}

.role-picker-arrow {
  color: #999;
  font-size: 24rpx;
  margin-left: 10rpx;
}

/* 编辑弹窗开关项布局 */
.form-item-switch {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.form-item-switch .label {
  margin-bottom: 0 !important;
}

/* 编辑弹窗内容区域滚动 */
.edit-modal .modal-body {
  max-height: 60vh;
  padding: 30rpx;
  box-sizing: border-box;
}

/* 编辑弹窗底部按钮 */
.edit-modal .modal-footer {
  display: flex;
  padding: 20rpx 30rpx;
  gap: 20rpx;
}

.edit-modal .modal-footer .btn {
  flex: 1;
  margin: 0;
  padding: 0;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
}

/* 校友会选择器项样式（带logo和location） */
.alumni-association-picker .picker-item-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.alumni-association-picker .picker-item-logo {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  background-color: #f5f5f5;
}

.alumni-association-picker .picker-item-info {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.alumni-association-picker .item-location {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.alumni-association-picker .picker-item.selected {
  background-color: #f6ffed;
}

.alumni-association-picker .picker-item.selected .item-name {
  color: #52c41a;
  font-weight: 600;
}

/* 未注册标签样式 */
.unregistered-tag {
  font-size: 20rpx;
  color: #ff4d4f;
  background-color: #fff1f0;
  border: 1rpx solid #ffa39e;
  border-radius: 18rpx;
  padding: 2rpx 12rpx;
  line-height: 28rpx;
  height: 32rpx;
  white-space: nowrap;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 主页展示标签样式 */
.show-on-home-tag {
  font-size: 20rpx;
  color: #52c41a;
  background-color: #f6ffed;
  border: 1rpx solid #b7eb8f;
  border-radius: 18rpx;
  padding: 2rpx 12rpx;
  line-height: 28rpx;
  height: 32rpx;
  white-space: nowrap;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 可点击样式 */
.member-item-left.clickable {
  cursor: pointer;
}

.member-item-left.clickable:active {
  opacity: 0.7;
}

/* 邀请流程说明提示 */
.invite-tip {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 24rpx;
  padding: 16rpx 20rpx;
  background-color: #f6f8fa;
  border-radius: 8rpx;
}

.invite-tip-icon {
  width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  font-size: 22rpx;
  font-weight: 600;
  color: #1890ff;
  background-color: #e6f4ff;
  border-radius: 50%;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.invite-tip-text {
  font-size: 24rpx;
  color: #666;
  line-height: 36rpx;
}

/* 邀请弹窗增大 */
.invite-modal-content {
  width: 90% !important;
  max-width: 680rpx !important;
}

/* 邀请方式选择标签 */
.invite-method-tabs {
  display: flex;
  flex-direction: row;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 30rpx;
}

.invite-method-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.invite-method-tab.active {
  color: #1890ff;
  font-weight: 600;
}

.invite-method-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: #1890ff;
  border-radius: 2rpx;
}

/* 邀请方式内容区域 */
.invite-method-content {
  min-height: 300rpx;
}

/* 链接邀请样式 */
.invite-link-section {
  padding: 0;
}

.invite-link-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.invite-link-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
  line-height: 36rpx;
}

.invite-link-box {
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.invite-link-text {
  font-size: 26rpx;
  color: #333;
  word-break: break-all;
  line-height: 40rpx;
}

/* 分享邀请信息样式 */
.invite-share-info {
  background: linear-gradient(135deg, #1890ff 0%, #40a9ff 100%);
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.invite-share-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.invite-share-hint {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 二维码邀请样式 */
.invite-qrcode-section {
  padding: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.invite-qrcode-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  width: 100%;
}

.invite-qrcode-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 30rpx;
  line-height: 36rpx;
  width: 100%;
}

.invite-qrcode-box {
  width: 320rpx;
  height: 320rpx;
  background-color: #f5f5f5;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  overflow: hidden;
}

.invite-qrcode-img {
  width: 280rpx;
  height: 280rpx;
}

.invite-qrcode-canvas {
  width: 280rpx;
  height: 280rpx;
}

.invite-qrcode-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  color: #999;
  font-size: 26rpx;
}

.invite-qrcode-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  color: #999;
  font-size: 26rpx;
}

.invite-qrcode-section .invite-tip {
  width: 100%;
}

/* 添加未注册成员表单样式 */
.unregistered-form-section {
  padding: 0;
}

.unregistered-form-section .form-item {
  margin-bottom: 30rpx;
}

.unregistered-form-section .form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
  font-weight: 500;
}

.unregistered-form-section .required {
  color: #ff4d4f;
  margin-left: 4rpx;
}

.unregistered-form-section .form-input {
  border: 1rpx solid #e0e0e0;
  padding: 0 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  height: 80rpx;
  background-color: #fafafa;
  line-height: 80rpx;
}

.unregistered-form-section .form-input:focus {
  border-color: #1890ff;
  background-color: #fff;
}

.unregistered-form-section .invite-tip {
  margin-top: 20rpx;
}

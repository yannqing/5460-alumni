/* ========== 组织架构树形预览样式（从上到下布局） ========== */
.template-tree-preview {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #f8f9ff 0%, #f0f5ff 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid #e6e9f0;
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.tree-scroll-container {
  width: 100%;
  flex: 1;
  min-height: 400rpx;
  white-space: nowrap;
}

.tree-container {
  display: inline-block;
  min-width: 100%;
  padding: 20rpx 10rpx;
}

/* 树节点行（居中显示） */
.tree-node-row {
  display: flex;
  justify-content: center;
  margin-bottom: 0;
  position: relative;
}

/* 有子节点的节点下方的垂直线 */
.tree-node.has-children::after {
  content: '';
  position: absolute;
  bottom: -24rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 2rpx;
  height: 24rpx;
  background-color: #c0c4cc;
}

/* 子节点行（水平排列） */
.tree-children-row {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 20rpx;
  margin-top: 24rpx;
  padding-top: 0;
  position: relative;
}

/* 分支容器（垂直排列：节点在上，子节点在下） */
.tree-branch {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  padding-top: 24rpx;
}

/* 分支顶部的垂直连接线 */
.tree-branch::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 2rpx;
  height: 24rpx;
  background-color: #c0c4cc;
}

/* 分支顶部的水平连接线 */
.tree-branch::after {
  content: '';
  position: absolute;
  top: 0;
  left: -10rpx;
  right: -10rpx;
  height: 2rpx;
  background-color: #c0c4cc;
}

/* 第一个分支：水平线从中心开始向右 */
.tree-branch:first-child::after {
  left: 50%;
}

/* 最后一个分支：水平线从左侧到中心 */
.tree-branch:last-child::after {
  right: 50%;
}

/* 只有一个分支时不显示水平线 */
.tree-branch:only-child::after {
  display: none;
}

/* 子节点容器（水平排列） */
.tree-sub-children {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 0;
  position: relative;
}

/* 子节点容器内的分支，gap较小，调整水平线延伸距离 */
.tree-sub-children > .tree-branch::after {
  left: -8rpx;
  right: -8rpx;
}

.tree-sub-children > .tree-branch:first-child::after {
  left: 50%;
}

.tree-sub-children > .tree-branch:last-child::after {
  right: 50%;
}

.tree-sub-children > .tree-branch:only-child::after {
  display: none;
}

/* 节点样式 */
.tree-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  cursor: pointer;
}

.tree-node:active {
  opacity: 0.8;
}


<!--pages/alumni-association/organization/organization.wxml-->
<custom-nav-bar showBack="{{true}}" useAuditStyle="{{true}}" auditTitle="校友会架构">
<view class="page">
  <!-- 校友会选择卡片（与城市架构管理一致，固定不滚动） -->
  <view class="group_5" wx:if="{{!hasSingleAlumniAssociation && hasAlumniAdminPermission}}">
    <text class="text_14">校友会组织</text>
    <text class="label_text">选择校友会</text>
    <view class="text-wrapper_8" bindtap="showAlumniAssociationSelector">
      <text class="text_15">{{selectedAlumniAssociationName || '请选择校友会'}}</text>
    </view>
  </view>

  <!-- 角色列表卡片（与城市架构管理一致：固定标题，仅内部 scroll-list 滚动） -->
  <view class="group_7">
    <view class="group_19">
      <text class="text_25">校友会角色列表</text>
      <view class="text-wrapper_13" bindtap="openAddModal">+新增分支</view>
    </view>
    <scroll-view class="scroll-list" scroll-y enable-back-to-top enhanced show-scrollbar="{{false}}">
      <view wx:if="{{roleLoading}}" class="loading-state">
        <text>加载角色中...</text>
      </view>
      <view class="role-list" wx:else>
      <!-- 一级角色 -->
      <block wx:for="{{roleList}}" wx:key="roleOrId">
        <view class="role-item level-1" bindlongpress="onRoleLongPress" data-role="{{item}}">
          <view class="role-left">
            <view
              class="expand-icon {{expandedRoles[item.roleOrId] ? 'expanded' : ''}}"
              wx:if="{{(item.children && item.children.length > 0) || (item.members && item.members.length > 0)}}"
              catchtap="toggleExpand"
              data-role-or-id="{{item.roleOrId}}"
            >
              <text class="arrow">▶</text>
            </view>
            <view class="expand-placeholder" wx:else></view>
            <view class="role-name">{{item.roleOrName}}</view>
            <view class="member-count" wx:if="{{item.members && item.members.length > 0}}">({{item.members.length}}人)</view>
          </view>
          <view class="role-actions">
            <view class="edit-btn" catchtap="openEditModal" data-role="{{item}}">编辑</view>
            <view class="delete-btn" catchtap="deleteRole" data-role-or-id="{{item.roleOrId}}">删除</view>
          </view>
        </view>
        <!-- 一级角色的成员列表 -->
        <view class="member-list-wrap level-1" wx:if="{{expandedRoles[item.roleOrId] && item.members && item.members.length > 0}}">
          <view class="member-item" wx:for="{{item.members}}" wx:for-item="member" wx:key="wxId">
            <image class="member-avatar" src="{{member.avatarUrl || defaultUserAvatarUrl}}" mode="aspectFill"></image>
            <view class="member-info">
              <text class="member-name">{{member.username || member.name || member.nickname || '未命名'}}</text>
              <text class="member-affiliation" wx:if="{{member.userAffiliation}}">{{member.userAffiliation}}</text>
            </view>
            <view class="member-show-tag" wx:if="{{member.isShowOnHome === 1}}">主页展示</view>
          </view>
        </view>
        <!-- 二级角色 -->
        <block wx:if="{{expandedRoles[item.roleOrId]}}">
          <block wx:for="{{item.children}}" wx:for-item="child" wx:key="roleOrId">
            <view class="role-item level-2" bindlongpress="onRoleLongPress" data-role="{{child}}">
              <view class="role-left">
                <view
                  class="expand-icon {{expandedRoles[child.roleOrId] ? 'expanded' : ''}}"
                  wx:if="{{(child.children && child.children.length > 0) || (child.members && child.members.length > 0)}}"
                  catchtap="toggleExpand"
                  data-role-or-id="{{child.roleOrId}}"
                >
                  <text class="arrow">▶</text>
                </view>
                <view class="expand-placeholder" wx:else></view>
                <view class="role-name">{{child.roleOrName}}</view>
                <view class="member-count" wx:if="{{child.members && child.members.length > 0}}">({{child.members.length}}人)</view>
              </view>
              <view class="role-actions">
                <view class="edit-btn" catchtap="openEditModal" data-role="{{child}}">编辑</view>
                <view class="delete-btn" catchtap="deleteRole" data-role-or-id="{{child.roleOrId}}">删除</view>
              </view>
            </view>
            <!-- 二级角色的成员列表 -->
            <view class="member-list-wrap level-2" wx:if="{{expandedRoles[child.roleOrId] && child.members && child.members.length > 0}}">
              <view class="member-item" wx:for="{{child.members}}" wx:for-item="member" wx:key="wxId">
                <image class="member-avatar" src="{{member.avatarUrl || defaultUserAvatarUrl}}" mode="aspectFill"></image>
                <view class="member-info">
                  <text class="member-name">{{member.username || member.name || member.nickname || '未命名'}}</text>
                  <text class="member-affiliation" wx:if="{{member.userAffiliation}}">{{member.userAffiliation}}</text>
                </view>
                <view class="member-show-tag" wx:if="{{member.isShowOnHome === 1}}">主页展示</view>
              </view>
            </view>
            <!-- 三级角色 -->
            <block wx:if="{{expandedRoles[child.roleOrId]}}">
              <block wx:for="{{child.children}}" wx:for-item="grandChild" wx:key="roleOrId">
                <view class="role-item level-3" bindlongpress="onRoleLongPress" data-role="{{grandChild}}">
                  <view class="role-left">
                    <view
                      class="expand-icon {{expandedRoles[grandChild.roleOrId] ? 'expanded' : ''}}"
                      wx:if="{{(grandChild.children && grandChild.children.length > 0) || (grandChild.members && grandChild.members.length > 0)}}"
                      catchtap="toggleExpand"
                      data-role-or-id="{{grandChild.roleOrId}}"
                    >
                      <text class="arrow">▶</text>
                    </view>
                    <view class="expand-placeholder" wx:else></view>
                    <view class="role-name">{{grandChild.roleOrName}}</view>
                    <view class="member-count" wx:if="{{grandChild.members && grandChild.members.length > 0}}">({{grandChild.members.length}}人)</view>
                  </view>
                  <view class="role-actions">
                    <view class="edit-btn" catchtap="openEditModal" data-role="{{grandChild}}">编辑</view>
                    <view class="delete-btn" catchtap="deleteRole" data-role-or-id="{{grandChild.roleOrId}}">删除</view>
                  </view>
                </view>
                <!-- 三级角色的成员列表 -->
                <view class="member-list-wrap level-3" wx:if="{{expandedRoles[grandChild.roleOrId] && grandChild.members && grandChild.members.length > 0}}">
                  <view class="member-item" wx:for="{{grandChild.members}}" wx:for-item="member" wx:key="wxId">
                    <image class="member-avatar" src="{{member.avatarUrl || defaultUserAvatarUrl}}" mode="aspectFill"></image>
                    <view class="member-info">
                      <text class="member-name">{{member.username || member.name || member.nickname || '未命名'}}</text>
                      <text class="member-affiliation" wx:if="{{member.userAffiliation}}">{{member.userAffiliation}}</text>
                    </view>
                    <view class="member-show-tag" wx:if="{{member.isShowOnHome === 1}}">主页展示</view>
                  </view>
                </view>
                <!-- 四级角色 -->
                <block wx:if="{{expandedRoles[grandChild.roleOrId]}}">
                  <block wx:for="{{grandChild.children}}" wx:for-item="greatGrandChild" wx:key="roleOrId">
                    <view class="role-item level-4" bindlongpress="onRoleLongPress" data-role="{{greatGrandChild}}">
                      <view class="role-left">
                        <view
                          class="expand-icon {{expandedRoles[greatGrandChild.roleOrId] ? 'expanded' : ''}}"
                          wx:if="{{(greatGrandChild.children && greatGrandChild.children.length > 0) || (greatGrandChild.members && greatGrandChild.members.length > 0)}}"
                          catchtap="toggleExpand"
                          data-role-or-id="{{greatGrandChild.roleOrId}}"
                        >
                          <text class="arrow">▶</text>
                        </view>
                        <view class="expand-placeholder" wx:else></view>
                        <view class="role-name">{{greatGrandChild.roleOrName}}</view>
                        <view class="member-count" wx:if="{{greatGrandChild.members && greatGrandChild.members.length > 0}}">({{greatGrandChild.members.length}}人)</view>
                      </view>
                      <view class="role-actions">
                        <view class="edit-btn" catchtap="openEditModal" data-role="{{greatGrandChild}}">编辑</view>
                        <view class="delete-btn" catchtap="deleteRole" data-role-or-id="{{greatGrandChild.roleOrId}}">删除</view>
                      </view>
                    </view>
                    <!-- 四级角色的成员列表 -->
                    <view class="member-list-wrap level-4" wx:if="{{expandedRoles[greatGrandChild.roleOrId] && greatGrandChild.members && greatGrandChild.members.length > 0}}">
                      <view class="member-item" wx:for="{{greatGrandChild.members}}" wx:for-item="member" wx:key="wxId">
                        <image class="member-avatar" src="{{member.avatarUrl || defaultUserAvatarUrl}}" mode="aspectFill"></image>
                        <view class="member-info">
                          <text class="member-name">{{member.username || member.name || member.nickname || '未命名'}}</text>
                          <text class="member-affiliation" wx:if="{{member.userAffiliation}}">{{member.userAffiliation}}</text>
                        </view>
                        <view class="member-show-tag" wx:if="{{member.isShowOnHome === 1}}">主页展示</view>
                      </view>
                    </view>
                    <!-- 五级角色 -->
                    <block wx:if="{{expandedRoles[greatGrandChild.roleOrId]}}">
                      <block wx:for="{{greatGrandChild.children}}" wx:for-item="level5Child" wx:key="roleOrId">
                        <view class="role-item level-5" bindlongpress="onRoleLongPress" data-role="{{level5Child}}">
                          <view class="role-left">
                            <view
                              class="expand-icon {{expandedRoles[level5Child.roleOrId] ? 'expanded' : ''}}"
                              wx:if="{{level5Child.members && level5Child.members.length > 0}}"
                              catchtap="toggleExpand"
                              data-role-or-id="{{level5Child.roleOrId}}"
                            >
                              <text class="arrow">▶</text>
                            </view>
                            <view class="expand-placeholder" wx:else></view>
                            <view class="role-name">{{level5Child.roleOrName}}</view>
                            <view class="member-count" wx:if="{{level5Child.members && level5Child.members.length > 0}}">({{level5Child.members.length}}人)</view>
                          </view>
                          <view class="role-actions">
                            <view class="edit-btn" catchtap="openEditModal" data-role="{{level5Child}}">编辑</view>
                            <view class="delete-btn" catchtap="deleteRole" data-role-or-id="{{level5Child.roleOrId}}">删除</view>
                          </view>
                        </view>
                        <!-- 五级角色的成员列表 -->
                        <view class="member-list-wrap level-5" wx:if="{{expandedRoles[level5Child.roleOrId] && level5Child.members && level5Child.members.length > 0}}">
                          <view class="member-item" wx:for="{{level5Child.members}}" wx:for-item="member" wx:key="wxId">
                            <image class="member-avatar" src="{{member.avatarUrl || defaultUserAvatarUrl}}" mode="aspectFill"></image>
                            <view class="member-info">
                              <text class="member-name">{{member.username || member.name || member.nickname || '未命名'}}</text>
                              <text class="member-affiliation" wx:if="{{member.userAffiliation}}">{{member.userAffiliation}}</text>
                            </view>
                            <view class="member-show-tag" wx:if="{{member.isShowOnHome === 1}}">主页展示</view>
                          </view>
                        </view>
                      </block>
                    </block>
                  </block>
                </block>
              </block>
            </block>
          </block>
        </block>
      </block>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{roleList.length === 0}}">
        <text>{{selectedAlumniAssociationId ? '暂无角色数据' : '请先选择校友会'}}</text>
      </view>
      </view>
    </scroll-view>
  </view>

  <!-- 校友会选择器弹窗 -->
  <view class="alumni-association-picker" wx:if="{{showAlumniAssociationPicker}}">
    <view class="picker-overlay" bindtap="cancelAlumniAssociationSelect"></view>
    <view class="picker-content">
      <view class="picker-header">
        <text class="picker-title">选择校友会</text>
        <text class="picker-cancel" bindtap="cancelAlumniAssociationSelect">取消</text>
      </view>
      <view class="picker-list">
        <view
          class="picker-item {{selectedAlumniAssociationId == item.alumniAssociationId ? 'selected' : ''}}"
          wx:for="{{alumniAssociationList}}"
          wx:key="alumniAssociationId"
          data-alumni-association-id="{{item.alumniAssociationId}}"
          data-alumni-association-name="{{item.alumniAssociationName}}"
          bindtap="selectAlumniAssociation"
        >
          <view class="picker-item-left">
            <image class="picker-item-logo" src="{{item.logo || defaultUserAvatarUrl}}" mode="aspectFill" />
            <view class="picker-item-info">
              <text class="item-name">{{item.alumniAssociationName}}</text>
              <text class="item-location" wx:if="{{item.location}}">{{item.location}}</text>
            </view>
          </view>
          <text class="item-check" wx:if="{{selectedAlumniAssociationId == item.alumniAssociationId}}">✓</text>
        </view>
        <view class="picker-empty" wx:if="{{alumniAssociationList.length === 0}}">
          <text>暂无校友会数据</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 编辑角色弹窗 -->
  <view class="edit-modal" wx:if="{{showEditModal}}">
    <view class="edit-modal-overlay" bindtap="closeEditModal"></view>
    <view class="edit-modal-content">
      <view class="edit-modal-header">
        <text class="edit-modal-title">编辑架构</text>
        <text class="edit-modal-close" bindtap="closeEditModal">×</text>
      </view>
      <scroll-view class="edit-modal-body" scroll-y enhanced show-scrollbar="{{false}}">
        <view class="edit-form-item">
          <text class="edit-label required">架构名称</text>
          <input
            class="edit-input"
            placeholder="请输入架构名称"
            value="{{editForm.roleOrName}}"
            bindinput="onEditInputChange"
            data-field="roleOrName"
          />
        </view>
        <!-- 上级架构 -->
        <view class="edit-form-item">
          <text class="edit-label">上级架构</text>
          <picker
            mode="selector"
            range="{{editParentOptions}}"
            range-key="roleOrName"
            value="{{editSelectedParentIndex}}"
            bindchange="onEditParentChange"
          >
            <view class="add-picker">
              <text class="add-picker-text">{{editSelectedParentName || '请选择父级'}}</text>
              <text class="add-picker-arrow">▼</text>
            </view>
          </picker>
        </view>
        <view class="edit-form-item">
          <text class="edit-label">架构职能</text>
          <input
            class="edit-input"
            placeholder="请输入架构职能"
            value="{{editForm.remark}}"
            bindinput="onEditInputChange"
            data-field="remark"
          />
        </view>
        <view class="edit-form-item">
          <text class="edit-label">状态</text>
          <view class="status-switch">
            <switch checked="{{editForm.status === 1}}" bindchange="onStatusChange" color="#1890ff" />
            <text class="status-text">{{editForm.status === 1 ? '启用' : '禁用'}}</text>
          </view>
        </view>
        <!-- 分支成员列表 -->
        <view class="edit-form-item edit-members-section">
          <view class="edit-members-header">
            <text class="edit-label">分支成员</text>
            <view class="add-member-btn" catchtap="openAddMemberModal">+ 添加成员</view>
          </view>
          <view class="edit-members-list" wx:if="{{editingRole.members && editingRole.members.length > 0}}">
            <view class="edit-member-item" wx:for="{{editingRole.members}}" wx:key="wxId" wx:for-item="member">
              <image class="edit-member-avatar" src="{{member.avatarUrl || defaultUserAvatarUrl}}" mode="aspectFill"></image>
              <view class="edit-member-info">
                <text class="edit-member-name">{{member.username || member.name || '未命名'}}</text>
                <text class="edit-member-affiliation" wx:if="{{member.userAffiliation}}">{{member.userAffiliation}}</text>
              </view>
              <view class="remove-member-btn" catchtap="removeMemberFromRole" data-member="{{member}}">移除</view>
            </view>
          </view>
          <view class="edit-members-empty" wx:else>
            <text>暂无成员，点击上方按钮添加</text>
          </view>
        </view>
      </scroll-view>
      <view class="edit-modal-footer">
        <view class="edit-btn-cancel" bindtap="closeEditModal">取消</view>
        <view class="edit-btn-confirm" bindtap="submitEdit">保存</view>
      </view>
    </view>
  </view>

  <!-- 添加成员弹窗 -->
  <view class="add-member-modal" wx:if="{{showAddMemberModal}}">
    <view class="add-member-modal-overlay" catchtap="closeAddMemberModal"></view>
    <view class="add-member-modal-content">
      <view class="add-member-modal-header">
        <text class="add-member-modal-title">添加成员到「{{editingRole.roleOrName}}」</text>
        <text class="add-member-modal-close" catchtap="closeAddMemberModal">×</text>
      </view>
      <view class="add-member-modal-body">
        <view class="member-search-box">
          <input
            class="member-search-input"
            placeholder="搜索成员姓名"
            value="{{memberSearchKeyword}}"
            bindinput="onMemberSearchInput"
            confirm-type="search"
            bindconfirm="searchMembers"
          />
          <view class="member-search-btn" bindtap="searchMembers">搜索</view>
        </view>
        <scroll-view class="member-search-results" scroll-y show-scrollbar="{{false}}">
          <view wx:if="{{memberSearchLoading}}" class="member-search-loading">
            <text>搜索中...</text>
          </view>
          <block wx:elif="{{memberSearchResults.length > 0}}">
            <view
              class="member-search-item {{item.isSelected ? 'selected' : ''}}"
              wx:for="{{memberSearchResults}}"
              wx:key="wxId"
              bindtap="toggleMemberSelect"
              data-member="{{item}}"
              data-index="{{index}}"
            >
              <image class="member-search-avatar" src="{{item.avatarUrl || defaultUserAvatarUrl}}" mode="aspectFill"></image>
              <view class="member-search-info">
                <text class="member-search-name">{{item.username || item.name || item.nickname || '未命名'}}</text>
                <text class="member-search-school" wx:if="{{item.school}}">{{item.school}}</text>
              </view>
              <view class="member-select-icon {{item.isSelected ? 'checked' : ''}}">
                <text wx:if="{{item.isSelected}}">✓</text>
              </view>
            </view>
          </block>
          <view wx:elif="{{memberSearchKeyword && !memberSearchLoading}}" class="member-search-empty">
            <text>未找到匹配的成员</text>
          </view>
          <view wx:else class="member-search-tip">
            <text>请输入关键词搜索成员</text>
          </view>
        </scroll-view>
      </view>
      <view class="add-member-modal-footer">
        <view class="add-member-btn-cancel" catchtap="closeAddMemberModal">取消</view>
        <view class="add-member-btn-confirm" catchtap="confirmAddMembers">确定添加</view>
      </view>
    </view>
  </view>

  <!-- 移动层级弹窗 -->
  <view class="move-modal" wx:if="{{showMoveModal}}">
    <view class="move-modal-overlay" bindtap="closeMoveModal"></view>
    <view class="move-modal-content">
      <view class="move-modal-header">
        <text class="move-modal-title">移动「{{movingRole.roleOrName}}」到</text>
        <text class="move-modal-close" bindtap="closeMoveModal">×</text>
      </view>
      <view class="move-modal-tip">
        <text>长按角色可快速调整层级关系</text>
      </view>
      <scroll-view class="move-modal-body" scroll-y show-scrollbar="{{false}}">
        <view
          class="parent-item {{item.isRoot ? 'root-item' : ''}} {{(movingRole.pid === null && item.roleOrId === '0') || (String(movingRole.pid) === String(item.roleOrId)) ? 'current-parent' : ''}}"
          wx:for="{{availableParents}}"
          wx:key="roleOrId"
          bindtap="selectNewParent"
          data-parent-id="{{item.roleOrId}}"
        >
          <view class="parent-indent" style="width: {{item.level * 30}}rpx;"></view>
          <text class="parent-name">{{item.roleOrName}}</text>
          <text class="current-tag" wx:if="{{(movingRole.pid === null && item.roleOrId === '0') || (String(movingRole.pid) === String(item.roleOrId))}}">当前</text>
        </view>
        <view class="move-empty" wx:if="{{availableParents.length === 0}}">
          <text>暂无可选的父级</text>
        </view>
      </scroll-view>
      <view class="move-modal-footer">
        <view class="move-btn-cancel" bindtap="closeMoveModal">取消</view>
      </view>
    </view>
  </view>

  <!-- 新增架构弹窗 -->
  <view class="add-modal" wx:if="{{showAddModal}}">
    <view class="add-modal-overlay" bindtap="closeAddModal"></view>
    <view class="add-modal-content">
      <view class="add-modal-header">
        <text class="add-modal-title">新增架构</text>
        <text class="add-modal-close" bindtap="closeAddModal">×</text>
      </view>
      <view class="add-modal-body">
        <view class="add-form-item">
          <text class="add-label required">架构名称</text>
          <input
            class="add-input"
            placeholder="请输入架构名称"
            value="{{addForm.roleOrName}}"
            bindinput="onAddInputChange"
            data-field="roleOrName"
          />
        </view>
        <view class="add-form-item">
          <text class="add-label">上级架构</text>
          <picker
            mode="selector"
            range="{{parentOptions}}"
            range-key="roleOrName"
            value="{{selectedParentIndex}}"
            bindchange="onParentChange"
          >
            <view class="add-picker">
              <text class="add-picker-text">{{selectedParentName || '请选择父级'}}</text>
              <text class="add-picker-arrow">▼</text>
            </view>
          </picker>
        </view>
        <view class="add-form-item">
          <text class="add-label">架构职能</text>
          <input
            class="add-input"
            placeholder="请输入架构职能"
            value="{{addForm.remark}}"
            bindinput="onAddInputChange"
            data-field="remark"
          />
        </view>
      </view>
      <view class="add-modal-footer">
        <view class="add-btn-cancel" bindtap="closeAddModal">取消</view>
        <view class="add-btn-confirm" bindtap="submitAdd">添加</view>
      </view>
    </view>
  </view>
</view>
</custom-nav-bar>

<!--pages/alumni-association/organization/organization.wxml-->
<custom-nav-bar showBack="{{true}}" useAuditStyle="{{true}}" auditTitle="校友会架构">
<view class="page">
  <!-- 选择校友会区域（现代化下拉框样式，放在左上角） -->
  <view class="alumni-selector-wrap" wx:if="{{!hasSingleAlumniAssociation && hasAlumniAdminPermission}}">
    <view class="alumni-selector" bindtap="showAlumniAssociationSelector">
      <image class="selector-avatar" src="{{selectedAlumniAssociationLogo || defaultUserAvatarUrl}}" mode="aspectFill"></image>
      <text class="selector-text">{{selectedAlumniAssociationName || '请选择校友会'}}</text>
      <text class="selector-arrow">▼</text>
    </view>
  </view>

  <!-- 角色列表卡片 -->
  <view class="group_7">
    <view class="group_19">
      <text class="text_25">校友会架构列表</text>
      <view class="text-wrapper_13" bindtap="openAddTopLevelModal">+新增顶级架构</view>
    </view>
    <scroll-view class="scroll-list" scroll-y scroll-x enable-back-to-top enhanced show-scrollbar="{{false}}">
      <view wx:if="{{roleLoading}}" class="loading-state">
        <text>加载架构中...</text>
      </view>
      <!-- 树形展示（从上到下布局） -->
      <view wx:elif="{{roleList.length > 0}}" class="template-tree-preview">
          <view class="tree-container">
            <!-- 递归渲染树节点（最多支持5层，从上到下） -->
            <block wx:for="{{roleList}}" wx:key="roleOrId" wx:for-item="n1">
              <view class="tree-root-branch">
                <!-- 一级节点行 -->
                <view class="tree-node-row">
                  <view class="tree-node level-1 {{n1.children && n1.children.length > 0 ? 'has-children' : ''}}" bindtap="openNodeDetailModal" data-role="{{n1}}">
                    <view class="node-content">
                      <text class="node-name">{{n1.roleOrName}}</text>
                      <text class="node-member-count" wx:if="{{n1.members && n1.members.length > 0}}">({{n1.members.length}}人)</text>
                    </view>
                  </view>
                </view>
                <!-- 二级节点行 -->
                <view wx:if="{{n1.children && n1.children.length > 0}}" class="tree-children-row">
                  <block wx:for="{{n1.children}}" wx:key="roleOrId" wx:for-item="n2">
                    <view class="tree-branch">
                      <view class="tree-node level-2 {{n2.children && n2.children.length > 0 ? 'has-children' : ''}}" bindtap="openNodeDetailModal" data-role="{{n2}}">
                        <view class="node-content">
                          <text class="node-name">{{n2.roleOrName}}</text>
                          <text class="node-member-count" wx:if="{{n2.members && n2.members.length > 0}}">({{n2.members.length}}人)</text>
                        </view>
                      </view>
                      <!-- 三级节点行 -->
                      <view wx:if="{{n2.children && n2.children.length > 0}}" class="tree-sub-children">
                        <block wx:for="{{n2.children}}" wx:key="roleOrId" wx:for-item="n3">
                          <view class="tree-branch">
                            <view class="tree-node level-3 {{n3.children && n3.children.length > 0 ? 'has-children' : ''}}" bindtap="openNodeDetailModal" data-role="{{n3}}">
                              <view class="node-content">
                                <text class="node-name">{{n3.roleOrName}}</text>
                                <text class="node-member-count" wx:if="{{n3.members && n3.members.length > 0}}">({{n3.members.length}}人)</text>
                              </view>
                            </view>
                            <!-- 四级节点行 -->
                            <view wx:if="{{n3.children && n3.children.length > 0}}" class="tree-sub-children">
                              <block wx:for="{{n3.children}}" wx:key="roleOrId" wx:for-item="n4">
                                <view class="tree-branch">
                                  <view class="tree-node level-4 {{n4.children && n4.children.length > 0 ? 'has-children' : ''}}" bindtap="openNodeDetailModal" data-role="{{n4}}">
                                    <view class="node-content">
                                      <text class="node-name">{{n4.roleOrName}}</text>
                                      <text class="node-member-count" wx:if="{{n4.members && n4.members.length > 0}}">({{n4.members.length}}人)</text>
                                    </view>
                                  </view>
                                  <!-- 五级节点行 -->
                                  <view wx:if="{{n4.children && n4.children.length > 0}}" class="tree-sub-children">
                                    <block wx:for="{{n4.children}}" wx:key="roleOrId" wx:for-item="n5">
                                      <view class="tree-branch">
                                        <view class="tree-node level-5" bindtap="openNodeDetailModal" data-role="{{n5}}">
                                          <view class="node-content">
                                            <text class="node-name">{{n5.roleOrName}}</text>
                                            <text class="node-member-count" wx:if="{{n5.members && n5.members.length > 0}}">({{n5.members.length}}人)</text>
                                          </view>
                                        </view>
                                      </view>
                                    </block>
                                  </view>
                                </view>
                              </block>
                            </view>
                          </view>
                        </block>
                      </view>
                    </view>
                  </block>
                </view>
              </view>
            </block>
          </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:elif="{{roleList.length === 0}}">
        <text>{{selectedAlumniAssociationId ? '暂无架构数据' : '请先选择校友会'}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 校友会选择器弹窗 -->
  <organization-picker
    visible="{{showAlumniAssociationPicker}}"
    title="选择校友会"
    list="{{alumniAssociationList}}"
    selectedId="{{selectedAlumniAssociationId}}"
    showSearch="{{true}}"
    searchPlaceholder="搜索校友会"
    emptyText="暂无校友会数据"
    itemKey="alumniAssociationId"
    nameKey="alumniAssociationName"
    showAlphabet="{{true}}"
    bind:select="onAlumniAssociationSelect"
    bind:cancel="cancelAlumniAssociationSelect"
    bind:loadmore="onAlumniAssociationLoadMore"
  />

  <!-- 节点详情弹窗 -->
  <view class="node-detail-modal" wx:if="{{showNodeDetailModal}}">
    <view class="node-detail-modal-overlay" bindtap="closeNodeDetailModal"></view>
    <view class="node-detail-modal-content">
      <view class="node-detail-modal-header">
        <text class="node-detail-modal-title">{{currentDetailRole.roleOrName}}</text>
        <text class="node-detail-modal-close" bindtap="closeNodeDetailModal">×</text>
      </view>
      <scroll-view class="node-detail-modal-body" scroll-y enhanced show-scrollbar="{{false}}">
        <!-- 节点基本信息 -->
        <view class="node-info-section">
          <view class="node-info-title">基本信息</view>
          <view class="node-info-item">
            <text class="node-info-label">架构名称</text>
            <text class="node-info-value">{{currentDetailRole.roleOrName || '-'}}</text>
          </view>
          <view class="node-info-item">
            <text class="node-info-label">架构职能</text>
            <text class="node-info-value">{{currentDetailRole.remark || '-'}}</text>
          </view>
          <view class="node-info-item">
            <text class="node-info-label">状态</text>
            <text class="node-info-value {{currentDetailRole.status === 1 ? 'status-active' : 'status-inactive'}}">{{currentDetailRole.status === 1 ? '启用' : '禁用'}}</text>
          </view>
        </view>

        <!-- 成员列表 -->
        <view class="node-members-section">
          <view class="node-members-header">
            <text class="node-members-title">成员列表 ({{currentDetailRole.members.length || 0}}人)</text>
            <view class="node-add-member-btn" catchtap="openAddMemberModalFromDetail">+ 添加成员</view>
          </view>
          <view wx:if="{{currentDetailRole.members && currentDetailRole.members.length > 0}}" class="node-members-list">
            <view class="node-member-item" wx:for="{{currentDetailRole.members}}" wx:key="wxId" wx:for-item="member">
              <view class="node-member-avatar">
                <image src="{{member.avatarUrl || defaultUserAvatarUrl}}" mode="aspectFill"></image>
              </view>
              <view class="node-member-info">
                <view class="node-member-name">{{member.username || member.name || member.nickname || '未命名'}}</view>
                <view class="node-member-affiliation" wx:if="{{member.userAffiliation}}">{{member.userAffiliation}}</view>
              </view>
              <view class="node-member-show-tag" wx:if="{{member.isShowOnHome === 1}}">主页展示</view>
              <view class="node-member-delete" catchtap="removeMemberFromDetailModal" data-member="{{member}}">移除</view>
            </view>
          </view>
          <view wx:else class="node-members-empty">
            <text>暂无成员，点击上方按钮添加</text>
          </view>
        </view>
      </scroll-view>
      <!-- 操作按钮 -->
      <view class="node-detail-modal-actions">
        <view class="node-action-btn node-action-add-child" catchtap="openAddChildModal">新增子架构</view>
        <view class="node-action-btn node-action-edit" catchtap="openEditModalFromDetail">编辑</view>
        <view class="node-action-btn node-action-delete" catchtap="deleteRoleFromDetail">删除</view>
      </view>
    </view>
  </view>

  <!-- 编辑角色弹窗 -->
  <view class="edit-modal" wx:if="{{showEditModal}}">
    <view class="edit-modal-overlay" bindtap="closeEditModal"></view>
    <view class="edit-modal-content">
      <view class="edit-modal-header">
        <text class="edit-modal-title">编辑架构</text>
        <text class="edit-modal-close" bindtap="closeEditModal">×</text>
      </view>
      <view class="edit-modal-body">
        <!-- 架构名称 -->
        <view class="edit-form-item">
          <text class="edit-label required">架构名称</text>
          <input
            class="edit-input"
            placeholder="请输入架构名称"
            value="{{editForm.roleOrName}}"
            bindinput="onEditInputChange"
            data-field="roleOrName"
          />
        </view>
        <!-- 上级架构 -->
        <view class="edit-form-item">
          <text class="edit-label">上级架构</text>
          <picker
            mode="selector"
            range="{{editParentOptions}}"
            range-key="roleOrName"
            value="{{editSelectedParentIndex}}"
            bindchange="onEditParentChange"
          >
            <view class="add-picker">
              <text class="add-picker-text">{{editSelectedParentName || '顶级架构(无父级)'}}</text>
              <text class="add-picker-arrow">▼</text>
            </view>
          </picker>
        </view>
        <!-- 架构职能 -->
        <view class="edit-form-item">
          <text class="edit-label">架构职能</text>
          <input
            class="edit-input"
            placeholder="请输入架构职能"
            value="{{editForm.remark}}"
            bindinput="onEditInputChange"
            data-field="remark"
          />
        </view>
        <!-- 状态 -->
        <view class="edit-form-item">
          <text class="edit-label">状态</text>
          <view class="status-switch">
            <switch checked="{{editForm.status === 1}}" bindchange="onStatusChange" color="#1890ff" />
            <text class="status-text">{{editForm.status === 1 ? '启用' : '禁用'}}</text>
          </view>
        </view>
      </view>
      <view class="edit-modal-footer">
        <view class="edit-btn-cancel" bindtap="closeEditModal">取消</view>
        <view class="edit-btn-confirm" bindtap="submitEdit">保存</view>
      </view>
    </view>
  </view>

  <!-- 移动层级弹窗 -->
  <view class="move-modal" wx:if="{{showMoveModal}}">
    <view class="move-modal-overlay" bindtap="closeMoveModal"></view>
    <view class="move-modal-content">
      <view class="move-modal-header">
        <text class="move-modal-title">移动「{{movingRole.roleOrName}}」到</text>
        <text class="move-modal-close" bindtap="closeMoveModal">×</text>
      </view>
      <view class="move-modal-tip">
        <text>长按角色可快速调整层级关系</text>
      </view>
      <scroll-view class="move-modal-body" scroll-y show-scrollbar="{{false}}">
        <view
          class="parent-item {{item.isRoot ? 'root-item' : ''}} {{(movingRole.pid === null && item.roleOrId === '0') || (String(movingRole.pid) === String(item.roleOrId)) ? 'current-parent' : ''}}"
          wx:for="{{availableParents}}"
          wx:key="roleOrId"
          bindtap="selectNewParent"
          data-parent-id="{{item.roleOrId}}"
        >
          <view class="parent-indent" style="width: {{item.level * 30}}rpx;"></view>
          <text class="parent-name">{{item.roleOrName}}</text>
          <text class="current-tag" wx:if="{{(movingRole.pid === null && item.roleOrId === '0') || (String(movingRole.pid) === String(item.roleOrId))}}">当前</text>
        </view>
        <view class="move-empty" wx:if="{{availableParents.length === 0}}">
          <text>暂无可选的父级</text>
        </view>
      </scroll-view>
      <view class="move-modal-footer">
        <view class="move-btn-cancel" bindtap="closeMoveModal">取消</view>
      </view>
    </view>
  </view>

  <!-- 新增顶级架构弹窗 -->
  <view class="add-modal" wx:if="{{showAddModal}}">
    <view class="add-modal-overlay" bindtap="closeAddModal"></view>
    <view class="add-modal-content">
      <view class="add-modal-header">
        <text class="add-modal-title">{{addModalTitle || '新增顶级架构'}}</text>
        <text class="add-modal-close" bindtap="closeAddModal">×</text>
      </view>
      <view class="add-modal-body">
        <!-- 架构名称 -->
        <view class="add-form-item">
          <text class="add-label required">架构名称</text>
          <input
            class="add-input"
            placeholder="请输入架构名称"
            value="{{addForm.roleOrName}}"
            bindinput="onAddInputChange"
            data-field="roleOrName"
          />
        </view>
        <!-- 上级架构（新增子架构时显示，新增顶级架构时隐藏） -->
        <view class="add-form-item" wx:if="{{addParentRole}}">
          <text class="add-label">上级架构</text>
          <view class="add-picker disabled">
            <text class="add-picker-text">{{addParentRole.roleOrName}}</text>
          </view>
        </view>
        <!-- 架构职能 -->
        <view class="add-form-item">
          <text class="add-label">架构职能</text>
          <input
            class="add-input"
            placeholder="请输入架构职能"
            value="{{addForm.remark}}"
            bindinput="onAddInputChange"
            data-field="remark"
          />
        </view>
      </view>
      <view class="add-modal-footer">
        <view class="add-btn-cancel" bindtap="closeAddModal">取消</view>
        <view class="add-btn-confirm" bindtap="submitAdd">添加</view>
      </view>
    </view>
  </view>

  <!-- 添加成员弹窗 -->
  <view class="add-member-modal" wx:if="{{showAddMemberModal}}">
    <view class="add-member-modal-overlay" catchtap="closeAddMemberModal"></view>
    <view class="add-member-modal-content">
      <view class="add-member-modal-header">
        <text class="add-member-modal-title">添加成员到「{{currentDetailRole.roleOrName || editingRole.roleOrName}}」</text>
        <text class="add-member-modal-close" catchtap="closeAddMemberModal">×</text>
      </view>
      <view class="add-member-modal-body">
        <view class="member-search-box">
          <input
            class="member-search-input"
            placeholder="搜索成员姓名"
            value="{{memberSearchKeyword}}"
            bindinput="onMemberSearchInput"
            confirm-type="search"
            bindconfirm="searchMembers"
          />
          <view class="member-search-btn" bindtap="searchMembers">搜索</view>
        </view>
        <scroll-view class="member-search-results" scroll-y show-scrollbar="{{false}}">
          <view wx:if="{{memberSearchLoading}}" class="member-search-loading">
            <text>搜索中...</text>
          </view>
          <block wx:elif="{{memberSearchResults.length > 0}}">
            <view
              class="member-search-item {{item.isSelected ? 'selected' : ''}}"
              wx:for="{{memberSearchResults}}"
              wx:key="wxId"
              bindtap="toggleMemberSelect"
              data-member="{{item}}"
              data-index="{{index}}"
            >
              <image class="member-search-avatar" src="{{item.avatarUrl || defaultUserAvatarUrl}}" mode="aspectFill"></image>
              <view class="member-search-info">
                <text class="member-search-name">{{item.username || item.name || item.nickname || '未命名'}}</text>
                <text class="member-search-school" wx:if="{{item.school}}">{{item.school}}</text>
              </view>
              <view class="member-select-icon {{item.isSelected ? 'checked' : ''}}">
                <text wx:if="{{item.isSelected}}">✓</text>
              </view>
            </view>
          </block>
          <view wx:elif="{{memberSearchKeyword && !memberSearchLoading}}" class="member-search-empty">
            <text>未找到匹配的成员</text>
          </view>
          <view wx:else class="member-search-tip">
            <text>请输入关键词搜索成员</text>
          </view>
        </scroll-view>
      </view>
      <view class="add-member-modal-footer">
        <view class="add-member-btn-cancel" catchtap="closeAddMemberModal">取消</view>
        <view class="add-member-btn-confirm" catchtap="confirmAddMembers">确定添加</view>
      </view>
    </view>
  </view>
</view>
</custom-nav-bar>

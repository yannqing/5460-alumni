<!--pages/shop/detail/detail.wxml-->
<custom-nav-bar showBack="{{true}}" useAuditStyle="{{true}}" auditTitle="商户详情">
  <!-- 消息通知组件 -->
  <message-notification />

<view class="shop-detail-page">
  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="loading">加载中...</view>
  </view>

    <view wx:elif="{{shopInfo}}">
      <!-- 白色内容区域 -->
      <view class="white-background-content">
        <!-- 基础信息 -->
        <view class="basic-info-card">
          <!-- 右上角操作图标 -->
          <view class="card-action-icons">
            <view class="favorite-action {{shopInfo.isFavorited ? 'is-favorited' : ''}}" bindtap="toggleFavorite">
              <text class="favorite-action__icon">★</text>
              <text class="favorite-action__text">{{shopInfo.isFavorited ? '已收藏' : '收藏'}}</text>
            </view>
          </view>
          <view class="shop-header">
            <view class="shop-avatar-row">
              <image class="shop-avatar" src="{{shopInfo.avatar}}" mode="aspectFill"></image>
              <view class="shop-info-column">
                <view class="shop-name-row">
                  <text class="shop-name">{{shopInfo.name}}</text>
                  <view wx:if="{{shopInfo.certifiedAssociation}}" class="certified-badge-yellow" bindtap="viewAssociationDetail">
                    {{shopInfo.certifiedAssociation.name}}
                  </view>
                </view>
                <view class="shop-rating-row">
                  <text class="rating-text">{{shopInfo.favoriteCount || 0}}</text>
                  <text class="rating-desc">人收藏</text>
                  <text class="divider">·</text>
                  <text class="category-text">{{shopInfo.category}}</text>
                </view>
              </view>
            </view>
          </view>

          <view class="info-section">
            <view class="info-item" wx:if="{{shopInfo.location && shopInfo.location !== 'null' && shopInfo.location !== 'undefined'}}">
              <view class="info-main">
                <text class="info-label-col">地址</text>
                <text class="info-value-col">{{shopInfo.location}}</text>
              </view>
            </view>
            <view class="info-item" wx:if="{{shopInfo.phone && shopInfo.phone !== 'null' && shopInfo.phone !== 'undefined'}}" bindtap="makeCall" data-phone="{{shopInfo.phone}}">
              <view class="info-main">
                <text class="info-label-col">电话</text>
                <text class="info-value-col info-value--phone">{{shopInfo.phone}}</text>
              </view>
            </view>
            <view class="info-item" wx:if="{{shopInfo.businessHours}}">
              <view class="info-main">
                <text class="info-label-col">营业时间</text>
                <text class="info-value-col">{{shopInfo.businessHours}}</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 推荐优惠券 -->
        <view class="recommended-coupon-section" wx:if="{{recommendedCoupons && recommendedCoupons.length}}">
          <view class="section-title-container">
            <view class="section-title">推荐优惠券</view>
            <view class="section-more" bindtap="viewMoreCoupons">查看更多</view>
          </view>
          <view class="recommended-coupon-list">
            <coupon-card
              wx:for="{{recommendedCoupons}}"
              wx:key="couponId"
              coupon="{{item}}"
              couponBgUrl="{{couponCardBgUrl}}"
              showAction="{{true}}"
              bind:cardtap="viewPublicCouponDetail"
              bind:action="handleClaimCoupon"
            />
          </view>
        </view>

        <!-- 商家图片轮播 -->
        <view class="merchant-gallery" wx:if="{{shopInfo.gallery && shopInfo.gallery.length}}">
          <swiper class="merchant-gallery-swiper" indicator-dots="{{shopInfo.gallery.length > 1}}" autoplay="{{shopInfo.gallery.length > 1}}" interval="{{3000}}" duration="{{500}}" circular="{{shopInfo.gallery.length > 1}}">
            <swiper-item wx:for="{{shopInfo.gallery}}" wx:key="*this">
              <image class="merchant-gallery-image" src="{{item}}" mode="aspectFill"></image>
            </swiper-item>
          </swiper>
        </view>

        <!-- 商户详情图片（单列瀑布流） -->
        <view class="merchant-detail-images" wx:if="{{shopInfo.detailImages && shopInfo.detailImages.length}}">
          <view class="section-title">详情</view>
          <view class="detail-images-waterfall">
            <image
              wx:for="{{shopInfo.detailImages}}"
              wx:key="*this"
              class="detail-image-item"
              src="{{item}}"
              mode="widthFix"
              lazy-load="{{true}}"
            />
          </view>
        </view>

        <!-- 门店列表 -->
        <view class="shops-list-card" wx:if="{{shopInfo.merchantInfo.shops && shopInfo.merchantInfo.shops.length}}">
          <view class="section-title-container">
            <view class="section-title">门店列表</view>
            <view class="shop-count-tag">{{shopInfo.merchantInfo.shopCount || 0}}家门店</view>
          </view>
          <view class="shops-list">
            <shop-store-card
              wx:for="{{shopInfo.merchantInfo.shops}}"
              wx:key="shopId"
              shop="{{item}}"
              iconLocation="{{iconLocation}}"
              bind:cardtap="viewShopDetail"
            />
          </view>
        </view>

        <!-- 店铺动态/话题 -->
        <view class="shop-dynamics" wx:if="{{shopInfo.dynamics && shopInfo.dynamics.length}}">
          <view class="section-title">店铺动态</view>
          <view class="dynamics-list">
            <view class="dynamic-item" wx:for="{{shopInfo.dynamics}}" wx:key="id" bindtap="viewDynamicDetail" data-id="{{item.id}}">
              <image class="dynamic-image" src="{{item.image}}" mode="aspectFill" wx:if="{{item.image}}"></image>
              <view class="dynamic-content">
                <view class="dynamic-title">{{item.title}}</view>
                <view class="dynamic-desc">{{item.description}}</view>
                <view class="dynamic-meta">
                  <text class="dynamic-time">{{item.time}}</text>
                  <text class="dynamic-type">{{item.type === 'activity' ? '活动' : '新品'}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>

        <!-- 校友足迹 -->
        <view class="alumni-footprint" wx:if="{{shopInfo.recentAlumni && shopInfo.recentAlumni.length}}">
          <view class="section-title">校友足迹</view>
          <view class="footprint-desc">最近来过的校友</view>
          <view class="alumni-avatar-wall">
            <view
              class="alumni-avatar-item"
              wx:for="{{shopInfo.recentAlumni}}"
              wx:key="id"
              bindtap="viewAlumniDetail"
              data-id="{{item.id}}"
              data-privacy="{{item.privacy}}"
            >
              <image
                class="avatar-img {{item.privacy === 'private' ? 'blur' : ''}}"
                src="{{item.privacy === 'private' ? defaultAvatar : item.avatar}}"
                mode="aspectFill"
              ></image>
              <view class="avatar-info" wx:if="{{item.privacy === 'private'}}">
                <text class="privacy-text">{{item.school}}</text>
                <text class="privacy-text">{{item.grade}}级</text>
              </view>
              <view class="avatar-info" wx:else>
                <text class="name-text">{{item.name}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</custom-nav-bar>
.coupon-page {
  height: 100vh;
  background-color: #fff;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.coupon-header {
  padding: 28rpx 30rpx 20rpx;
  flex-shrink: 0;
}

.coupon-header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f1f1f;
  line-height: 1.35;
}

.coupon-header-subtitle {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #777;
  line-height: 1.35;
}

.coupon-scroll {
  flex: 1;
  min-height: 0;
}

.coupon-list {
  padding: 0 30rpx 40rpx;
}

.loading-state,
.empty-state {
  padding: 44rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #999;
}

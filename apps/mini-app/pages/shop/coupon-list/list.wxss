.coupon-page {
  height: 100vh;
  background-color: #fff;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.coupon-header {
  padding: 28rpx 30rpx 20rpx;
  flex-shrink: 0;
}

.coupon-header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f1f1f;
  line-height: 1.35;
}

.coupon-header-subtitle {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #777;
  line-height: 1.35;
}

.coupon-scroll {
  flex: 1;
  min-height: 0;
}

.coupon-list {
  padding: 0 30rpx 40rpx;
}

.coupon-card {
  min-height: 156rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  margin-bottom: 22rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #fff7e6, #fff);
  border: 1rpx solid #ffe1a6;
  box-shadow: 0 4rpx 14rpx rgba(255, 181, 64, 0.12);
}

.coupon-card:active {
  opacity: 0.82;
}

.coupon-value {
  width: 136rpx;
  flex-shrink: 0;
  font-size: 36rpx;
  font-weight: 700;
  color: #ff8a00;
  text-align: center;
  line-height: 1.2;
}

.coupon-info {
  flex: 1;
  min-width: 0;
}

.coupon-title {
  font-size: 29rpx;
  font-weight: 600;
  color: #1f1f1f;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.coupon-desc {
  font-size: 24rpx;
  color: #777;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 10rpx;
}

.coupon-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx 14rpx;
  font-size: 22rpx;
  color: #999;
  line-height: 1.35;
}

.coupon-action {
  flex-shrink: 0;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background-color: #ff8a00;
  color: #fff;
  font-size: 24rpx;
  font-weight: 500;
}

.loading-state,
.empty-state {
  padding: 44rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #999;
}

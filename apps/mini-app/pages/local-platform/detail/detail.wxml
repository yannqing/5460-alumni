<custom-nav-bar showBack="{{true}}" useAuditStyle="{{true}}" auditTitle="校促会详情">
<message-notification />
<view class="platform-detail-page">
    <view wx:if="{{loading}}" class="loading-wrap">
        <view class="loading">加载中...</view>
    </view>
    <view wx:elif="{{platformInfo}}">
        <view class="top-background-container">
            <image class="cover-image" src="{{platformInfo.cover}}" mode="aspectFill" />
            <view class="bg-gradient-overlay"></view>
        </view>
            <!-- 白色背景内容区域 -->
            <view class="white-background">
                <view class="card">
                    <view class="flex">
                        <image class="avatar avatar-large" src="{{platformInfo.icon}}" mode="aspectFill" />
                        <view class="flex-1 ml-20">
                            <view class="name-row">
                                <text class="text-primary text-bold">{{platformInfo.platformName}}</text>
                            </view>
                            <view wx:if="{{platformInfo.city}}" class="text-secondary mt-10 location-row">
                                <image class="location-icon" src="{{iconLocation}}" mode="aspectFit" />
                                <text>{{platformInfo.city}}</text>
                            </view>
                        </view>
                    </view>
                </view>
                <!-- 顶部 Tab -->
                <tab-bar tabs="{{tabs}}" activeTab="{{activeTab}}" bind:tabchange="onTabChange" />
                <!-- Tab 内容：基本信息 -->
                <view wx:if="{{activeTab === 0}}" class="tab-content">
                    <view class="card">
                        <view class="text-bold mb-20">基本信息</view>
                        <view class="basic-info-item">负责人姓名：{{platformInfo.principalName || '不方便透露'}}</view>
                        <view class="basic-info-item">负责人职位：{{platformInfo.principalPosition || '不方便透露'}}</view>
                        <view class="basic-info-item">联系电话：{{platformInfo.localPlatformPhone || '不方便透露'}}</view>
                        <view class="basic-info-item">会员数量：{{platformInfo.memberCount || '不方便透露'}}</view>
                        <!-- 会员单位头像预览 -->
                        <view wx:if="{{associations && associations.length > 0}}" class="member-avatar-preview">
                            <view class="avatar-row">
                                <image
                                    wx:for="{{associations}}"
                                    wx:key="alumniAssociationId"
                                    wx:if="{{index < 6}}"
                                    class="preview-avatar"
                                    src="{{item.avatar}}"
                                    mode="aspectFill"
                                    bindtap="viewAssociationDetail"
                                    data-id="{{item.alumniAssociationId}}"
                                />
                            </view>
                            <view class="avatar-row" wx:if="{{associations.length > 6}}">
                                <image
                                    wx:for="{{associations}}"
                                    wx:key="alumniAssociationId"
                                    wx:if="{{index >= 6 && index < 11}}"
                                    class="preview-avatar"
                                    src="{{item.avatar}}"
                                    mode="aspectFill"
                                    bindtap="viewAssociationDetail"
                                    data-id="{{item.alumniAssociationId}}"
                                />
                                <view class="preview-avatar view-more" bindtap="goToMemberTab">
                                    <text class="view-more-text">查看更多</text>
                                </view>
                            </view>
                            <view class="avatar-row" wx:elif="{{associations.length <= 6}}">
                                <view class="preview-avatar view-more" bindtap="goToMemberTab">
                                    <text class="view-more-text">查看更多</text>
                                </view>
                            </view>
                        </view>
                        <view class="basic-info-item">简介：{{platformInfo.description || '不方便透露'}}</view>
                    </view>
                    <!-- 小程序链接 -->
                    <view class="card" wx:if="{{platformInfo.miniProgramLinks && platformInfo.miniProgramLinks.length > 0}}">
                        <view class="text-bold mb-20">相关政务</view>
                        <view class="mini-program-links">
                            <view
                                class="mini-program-item {{!item.url ? 'disabled' : ''}}"
                                wx:for="{{platformInfo.miniProgramLinks}}"
                                wx:key="id"
                                bindtap="onMiniProgramLinkTap"
                                data-url="{{item.url}}"
                                data-text="{{item.text}}"
                            >
                                <image wx:if="{{item.avatar}}" class="mini-program-avatar" src="{{item.avatar}}" mode="aspectFill" />
                                <view wx:else class="mini-program-icon">
                                    <text class="icon-text">小程序</text>
                                </view>
                                <text class="mini-program-name">{{item.text}}</text>
                                <text class="mini-program-arrow">›</text>
                            </view>
                        </view>
                    </view>
                </view>
                <!-- Tab 内容：组织结构 -->
                <view wx:if="{{activeTab === 1}}" class="tab-content">
                    <view class="card dashboard-card">
                        <view class="section-header">
                            <view class="section-title">
                                <view class="text-bold">组织架构</view>
                                <view class="section-subtitle">组织架构展示</view>
                            </view>
                            <!-- 暂时注销编辑按钮 -->
                            <!-- <view wx:if="{{canEditOrg}}" class="section-edit-btn">
                                <view wx:if="{{!isEditOrgMode}}" class="edit-btn" bindtap="onEditOrgClick">
                                    <text class="edit-text">编辑</text>
                                </view>
                                <view wx:else class="edit-btn cancel-btn" bindtap="onCancelOrgEdit">
                                    <text class="edit-text">取消</text>
                                </view>
                            </view> -->
                        </view>
                        <org-structure 
                            id="org-structure" 
                            list="{{roleList}}" 
                            loading="{{organizationLoading}}" 
                            empty-text="暂无角色数据" 
                            isLocalPlatform="{{true}}" 
                            localPlatformId="{{platformId}}" 
                            bind:refresh="onOrgStructureRefresh"
                        />
                    </view>
                </view>
                <!-- Tab 内容：最新动态 -->
                <view wx:if="{{activeTab === 2}}" class="tab-content">
                    <!-- 资讯列表 -->
                    <view class="card dashboard-card" wx:if="{{articleList && articleList.length > 0}}">
                        <view class="section-header">
                            <view class="section-title">
                                <view class="text-bold">资讯</view>
                                <view class="section-subtitle">最新动态与通知</view>
                            </view>
                        </view>
                        <view class="dashboard-list news">
                            <view class="dashboard-item news-item" wx:for="{{articleList}}" wx:key="id" bindtap="goToArticleDetail" data-id="{{item.id}}">
                                <view class="item-leading">
                                    <image class="item-cover" src="{{item.cover}}" mode="aspectFill" />
                                </view>
                                <view class="item-content">
                                    <view class="news-header">
                                        <view class="item-title">{{item.title}}</view>
                                    </view>
                                    <view class="news-footer">
                                        <view class="item-meta">
                                            <text class="news-time">{{item.time}}</text>
                                        </view>
                                    </view>
                                </view>
                            </view>
                        </view>
                    </view>

                    <!-- 空状态 -->
                    <view class="empty-container" wx:if="{{!articleList || articleList.length === 0}}">
                        <view class="empty-icon">📭</view>
                        <view class="empty-text">暂无最新动态</view>
                        <view class="empty-desc">该校促会还没有发布资讯</view>
                    </view>
                </view>
                <!-- Tab 内容：会员单位 -->
                <view wx:if="{{activeTab === 3}}">
                    <view class="member-list">
                        <!-- 骨架屏 -->
                        <view wx:if="{{associationLoading && associations.length === 0}}" class="skeleton-list">
                            <view class="member-item skeleton-item" wx:for="[1,2,3,4,5]" wx:key="*this">
                                <view class="member-avatar skeleton-avatar"></view>
                                <view class="member-info">
                                    <view class="member-name-row">
                                        <view class="skeleton-name"></view>
                                    </view>
                                    <view class="skeleton-text"></view>
                                    <view class="skeleton-text"></view>
                                </view>
                            </view>
                        </view>
                        <!-- 空状态 -->
                        <view wx:elif="{{!associations.length}}" class="empty-container">
                            <view class="empty-icon">👥</view>
                            <view class="empty-text">暂无校友会</view>
                            <view class="empty-desc">该平台还没有关联的校友会</view>
                        </view>
                        <!-- 实际数据 -->
                        <view wx:else>
                            <view class="member-item" wx:for="{{associations}}" wx:key="alumniAssociationId" bindtap="viewAssociationDetail" data-id="{{item.alumniAssociationId}}">
                                <image class="member-avatar" src="{{item.avatar}}" mode="aspectFill" />
                                <view class="member-info">
                                    <view class="member-name-row">
                                        <text class="member-name">{{item.associationName}}</text>
                                    </view>
                                    <view class="member-meta">
                                        <view class="meta-item" wx:if="{{item.location}}">
                                            <image class="meta-icon" src="{{iconLocation}}" mode="aspectFit" />
                                            <text>{{item.location}}</text>
                                        </view>
                                        <view class="meta-item" wx:else>
                                            <text>暂无地点</text>
                                        </view>
                                        <view class="meta-item">
                                            <image class="meta-icon" src="{{iconPeople}}" mode="aspectFit" />
                                            <text>{{item.memberCount}}人</text>
                                        </view>
                                    </view>
                                </view>
                                <view wx:if="{{item.role === 0}}" class="role-tag member-tag">会员单位</view>
                                <view wx:elif="{{item.role === 1}}" class="role-tag director-tag">理事单位</view>
                            </view>
                        </view>
                        <!-- 加载更多 -->
                        <view wx:if="{{associationLoading && associations.length > 0}}" class="loading-more">加载中...</view>
                        <view wx:elif="{{!hasMore && associations.length}}" class="no-more">没有更多了</view>
                    </view>
                </view>
            </view>
        </view>
        <!-- 新增：platformInfo 为空时的空状态展示 -->
        <view wx:else class="empty-state">
            <view class="empty-placeholder">暂无数据</view>
            <text>暂无校促会信息</text>
    </view>
</view>
</custom-nav-bar>

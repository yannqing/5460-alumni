/* 复用通用表单样式 */
page {
  background-color: #f5f5f5;
  padding-bottom: 60rpx;
  padding: 0;
  margin: 0;
}

.page {
  background-color: transparent;
  position: relative;
  width: 750rpx;
  min-height: 100%;
  display: flex;
  flex-direction: column;
  overflow: auto;
}

/* 隐私提示样式 */
.privacy-notice {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f0f9ff;
  border: 1rpx solid #bae6fd;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  margin: 20rpx 18rpx 0;
}

.privacy-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.privacy-text {
  font-size: 24rpx;
  color: #0369a1;
}

.group_5 {
  width: 714rpx;
  min-height: 346rpx;
  background-color: #FFFFFF;
  border-radius: 28.99rpx;
  display: flex;
  flex-direction: column;
  margin: 47rpx 0 0 18rpx;
  padding: 38rpx 43rpx 27rpx 43rpx;
  box-sizing: border-box;
  flex-shrink: 0;
}

.text_14 {
  width: 147rpx;
  height: 40rpx;
  overflow-wrap: break-word;
  color: rgba(0,0,0,1);
  font-size: 29rpx;
  letter-spacing: 0rpx;
  font-family: PingFangSC-Semibold;
  font-weight: 600;
  text-align: left;
  white-space: nowrap;
  line-height: 40rpx;
}

.label_text {
  width: auto;
  height: 36rpx;
  overflow-wrap: break-word;
  color: rgba(0,0,0,0.6);
  font-size: 25rpx;
  font-family: PingFangSC-Regular;
  font-weight: normal;
  text-align: left;
  white-space: nowrap;
  line-height: 36rpx;
  margin-top: 16rpx;
  display: block;
}

.text-wrapper_8 {
  height: 80rpx;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  border: 1rpx solid #E0E0E0;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  margin-top: 16rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  position: relative;
}

.text_15 {
  flex: 1;
  height: 36rpx;
  overflow-wrap: break-word;
  color: rgba(0,0,0,0.85);
  font-size: 28rpx;
  font-family: PingFangSC-Regular;
  font-weight: normal;
  text-align: left;
  white-space: nowrap;
  line-height: 36rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

.text_15:empty:before {
  content: '请选择校友会';
  color: rgba(0,0,0,0.4);
}

.text-wrapper_8::after {
  content: '▼';
  color: #999;
  font-size: 20rpx;
  margin-left: 10rpx;
}

.group_7 {
  width: 714rpx;
  flex: 1;
  background-color: #FFFFFF;
  border-radius: 28.99rpx;
  display: flex;
  flex-direction: column;
  margin: 34rpx 0 20rpx 18rpx;
  padding: 38rpx 25rpx 20rpx 25rpx;
  box-sizing: border-box;
  overflow: visible;
  position: relative;
  z-index: 1;
}

.text_20 {
  width: 118rpx;
  height: 40rpx;
  overflow-wrap: break-word;
  color: rgba(0,0,0,1);
  font-size: 29rpx;
  letter-spacing: 0rpx;
  font-family: PingFangSC-Semibold;
  font-weight: 600;
  text-align: left;
  white-space: nowrap;
  line-height: 40rpx;
  margin-left: 18rpx;
  margin-bottom: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
  padding: 0 18rpx;
}

.label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
  display: block;
}

.form-item.required .label::before {
  content: '*';
  color: #ff4d4f;
  margin-right: 6rpx;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1;
}

.input,
.textarea {
  border: 1rpx solid #eee;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  width: 100%;
}

.input {
  height: 80rpx;
}

.input.disabled {
  background-color: #f5f5f5;
  color: #666;
  border-color: #e8e8e8;
  border-radius: 12rpx;
  box-shadow: inset 0 1rpx 3rpx rgba(0, 0, 0, 0.05);
}

.textarea {
  min-height: 120rpx;
  resize: none;
}

.textarea.disabled {
  background-color: #f5f5f5;
  color: #666;
  border-color: #e8e8e8;
  border-radius: 12rpx;
  box-shadow: inset 0 1rpx 3rpx rgba(0, 0, 0, 0.05);
}

/* 基本信息展示样式优化 */
.alumni-association-info {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.info-item {
  margin-bottom: 24rpx;
  padding: 0 18rpx;
}

.info-label {
  font-size: 26rpx;
  color: #94a3b8;
  margin-bottom: 12rpx;
  display: block;
  font-weight: 500;
}

.info-display-box {
  background-color: #f8fafc;
  border: 1rpx solid #f1f5f9;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #334155;
  min-height: 40rpx;
  line-height: 1.6;
  word-break: break-all;
}

.info-display-box.textarea-box {
  min-height: 120rpx;
}

/* 顶部 Header 优化 */
.detail-header {
  position: relative;
  width: 100%;
  height: 320rpx;
  margin-bottom: 30rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.detail-header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 160rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.5), transparent);
  z-index: 1;
}

.header-bg {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  border-radius: 28.99rpx;
}

/* 背景图片上的头像 */
.platform-avatar-on-bg {
  position: absolute;
  bottom: 24rpx;
  left: 24rpx;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid #ffffff;
  background-color: #ffffff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.15);
  z-index: 2;
}

/* 背景图片上的信息容器 */
.info-on-bg {
  position: absolute;
  bottom: 27rpx;
  left: 130rpx;
  z-index: 2;
  color: #ffffff;
  text-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.3);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

/* 背景图片上的标题行 */
.title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  margin-bottom: 6rpx;
  margin-top: -3rpx;
  transform: translateY(-6rpx);
}

/* 背景图片上的标题 */
.card-title-on-bg {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
  margin-right: 10rpx;
}

.form-actions {
  margin-top: 60rpx;
  padding: 0 30rpx;
  display: flex;
  justify-content: center;
}

.submit-btn {
  background-color: #1890FF;
  color: white;
  border-radius: 42.57rpx;
  font-weight: 500;
  width: 660rpx;
  height: 85.14rpx;
}

.upload-container {
  position: relative;
  width: 100%;
}

.upload-btn-group {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.upload-btn {
  border: 1rpx solid #eee;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  height: 80rpx;
  box-sizing: border-box;
  background-color: #f9f9f9;
  color: #666;
  flex: 1;
  text-align: center;
  line-height: 40rpx;
}

.attachments-list {
  margin-top: 20rpx;
  width: 100%;
}

.attachment-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
  width: 100%;
}

.attachment-name {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.attachment-delete {
  font-size: 24rpx;
  color: #ff4d4f;
  margin-left: 20rpx;
}

/* 选择校友会卡片样式 */
.group_5 {
  margin-bottom: 30rpx;
}

.text_14 {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #333;
}

.label_text {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.text-wrapper_8 {
  border: 1rpx solid #eee;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #f9f9f9;
}

.text_15 {
  font-size: 28rpx;
  color: #333;
}

/* 校友会选择器弹窗样式 */
.alumni-association-picker {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.picker-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.picker-content {
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: 40rpx;
  position: relative;
  z-index: 1;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.picker-cancel {
  font-size: 28rpx;
  color: #999;
}

.picker-list {
  max-height: 500rpx;
  overflow-y: auto;
  padding: 0 30rpx;
}

.picker-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.item-name {
  font-size: 28rpx;
  color: #333;
}

.item-check {
  font-size: 32rpx;
  color: #1890FF;
  font-weight: bold;
}

.picker-empty {
  padding: 40rpx 0;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}

/* 反馈入口提示 */
.feedback-hint-section {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 30rpx;
  padding: 0 18rpx;
}

.feedback-hint-text {
  font-size: 24rpx;
  color: #999999;
}

.feedback-hint-link {
  font-size: 24rpx;
  color: #1890FF;
  margin-left: 8rpx;
}
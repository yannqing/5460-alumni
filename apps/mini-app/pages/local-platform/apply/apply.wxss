/* 复用通用表单样式 */
page {
  background-color: #f5f5f5;
  padding-bottom: 60rpx;
  padding: 0;
  margin: 0;
}

.page {
  background-color: transparent;
  position: relative;
  width: 750rpx;
  height: 100%;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.group_5 {
  width: 714rpx;
  min-height: 346rpx;
  background-color: #FFFFFF;
  border-radius: 28.99rpx;
  display: flex;
  flex-direction: column;
  margin: 47rpx 0 0 18rpx;
  padding: 38rpx 43rpx 27rpx 43rpx;
  box-sizing: border-box;
  flex-shrink: 0;
}

.text_14 {
  width: 147rpx;
  height: 40rpx;
  overflow-wrap: break-word;
  color: rgba(0,0,0,1);
  font-size: 29rpx;
  letter-spacing: 0rpx;
  font-family: PingFangSC-Semibold;
  font-weight: 600;
  text-align: left;
  white-space: nowrap;
  line-height: 40rpx;
}

.label_text {
  width: auto;
  height: 36rpx;
  overflow-wrap: break-word;
  color: rgba(0,0,0,0.6);
  font-size: 25rpx;
  font-family: PingFangSC-Regular;
  font-weight: normal;
  text-align: left;
  white-space: nowrap;
  line-height: 36rpx;
  margin-top: 16rpx;
  display: block;
}

.text-wrapper_8 {
  height: 80rpx;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  border: 1rpx solid #E0E0E0;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  margin-top: 16rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  position: relative;
}

.text_15 {
  flex: 1;
  height: 36rpx;
  overflow-wrap: break-word;
  color: rgba(0,0,0,0.85);
  font-size: 28rpx;
  font-family: PingFangSC-Regular;
  font-weight: normal;
  text-align: left;
  white-space: nowrap;
  line-height: 36rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

.text_15:empty:before {
  content: '请选择校友会';
  color: rgba(0,0,0,0.4);
}

.text-wrapper_8::after {
  content: '▼';
  color: #999;
  font-size: 20rpx;
  margin-left: 10rpx;
}

.group_7 {
  width: 714rpx;
  flex: 1;
  background-color: #FFFFFF;
  border-radius: 28.99rpx;
  display: flex;
  flex-direction: column;
  margin: 34rpx 0 20rpx 18rpx;
  padding: 38rpx 25rpx 20rpx 25rpx;
  box-sizing: border-box;
  overflow: hidden;
  position: relative;
  z-index: 1;
}

.text_20 {
  width: 118rpx;
  height: 40rpx;
  overflow-wrap: break-word;
  color: rgba(0,0,0,1);
  font-size: 29rpx;
  letter-spacing: 0rpx;
  font-family: PingFangSC-Semibold;
  font-weight: 600;
  text-align: left;
  white-space: nowrap;
  line-height: 40rpx;
  margin-left: 18rpx;
  margin-bottom: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
  padding: 0 18rpx;
}

.label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
  display: block;
}

.form-item.required .label::before {
  content: '*';
  color: #ff4d4f;
  margin-right: 6rpx;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1;
}

.input,
.textarea {
  border: 1rpx solid #eee;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  width: 100%;
}

.input {
  height: 80rpx;
}

.input.disabled {
  background-color: #f9f9f9;
  color: #999;
  border-color: #e0e0e0;
}

.textarea {
  min-height: 120rpx;
  resize: none;
}

.textarea.disabled {
  background-color: #f9f9f9;
  color: #999;
  border-color: #e0e0e0;
}

/* 图片预览样式 */
.image-preview {
  width: 100%;
  height: 200rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  overflow: hidden;
  background-color: #f9f9f9;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.logo-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  object-fit: cover;
}

/* 顶部 Header */
.detail-header {
  position: relative;
  width: 100%;
  height: 380rpx;
  margin-bottom: 30rpx;
  overflow: visible;
}

.detail-header::after {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.4) 100%);
  border-radius: 40rpx 40rpx 40rpx 40rpx;
  z-index: 1;
}

.header-bg {
  width: 100%;
  height: 100%;
  border-radius: 40rpx 40rpx 40rpx 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.header-content {
  position: absolute;
  bottom: -40rpx;
  left: 40rpx;
  right: 40rpx;
  display: flex;
  align-items: flex-end;
  z-index: 2;
}

.header-left {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-container {
  width: 140rpx;
  height: 140rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.headquarters-logo {
  width: 100%;
  height: 100%;
  border-radius: 28rpx;
}

.headquarters-basic {
  margin-left: 24rpx;
  padding-bottom: 50rpx;
  flex: 1;
}

.headquarters-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
  display: block;
  margin-bottom: 12rpx;
}

.form-actions {
  margin-top: 60rpx;
  padding: 0 30rpx;
  display: flex;
  justify-content: center;
}

.submit-btn {
  background-color: #1890FF;
  color: white;
  border-radius: 42.57rpx;
  font-weight: 500;
  width: 660rpx;
  height: 85.14rpx;
}

.upload-container {
  position: relative;
  width: 100%;
}

.upload-btn-group {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.upload-btn {
  border: 1rpx solid #eee;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  height: 80rpx;
  box-sizing: border-box;
  background-color: #f9f9f9;
  color: #666;
  flex: 1;
  text-align: center;
  line-height: 40rpx;
}

.attachments-list {
  margin-top: 20rpx;
  width: 100%;
}

.attachment-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
  width: 100%;
}

.attachment-name {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.attachment-delete {
  font-size: 24rpx;
  color: #ff4d4f;
  margin-left: 20rpx;
}

/* 选择校友会卡片样式 */
.group_5 {
  margin-bottom: 30rpx;
}

.text_14 {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #333;
}

.label_text {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.text-wrapper_8 {
  border: 1rpx solid #eee;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #f9f9f9;
}

.text_15 {
  font-size: 28rpx;
  color: #333;
}

/* 校友会选择器弹窗样式 */
.alumni-association-picker {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.picker-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.picker-content {
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: 40rpx;
  position: relative;
  z-index: 1;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.picker-cancel {
  font-size: 28rpx;
  color: #999;
}

.picker-list {
  max-height: 500rpx;
  overflow-y: auto;
  padding: 0 30rpx;
}

.picker-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.item-name {
  font-size: 28rpx;
  color: #333;
}

.item-check {
  font-size: 32rpx;
  color: #1890FF;
  font-weight: bold;
}

.picker-empty {
  padding: 40rpx 0;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}
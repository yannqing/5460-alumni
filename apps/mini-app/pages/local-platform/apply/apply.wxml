<custom-nav-bar useAuditStyle="{{true}}" auditTitle="申请加入校促会" showBack="{{true}}">
  <view class="page">
    <!-- 隐私提示 -->
    <view class="privacy-notice">
      <text class="privacy-text">您所填写的信息仅用于审核，不会对外公开</text>
    </view>

    <!-- 选择校友会卡片 -->
    <view class="group_5" wx:if="{{!hasSingleAlumniAssociation && hasAlumniAdminPermission}}">
      <text class="text_14">申请加入校促会</text>
      <text class="label_text">选择校友会</text>
      <view class="text-wrapper_8" bindtap="showAlumniAssociationSelector">
        <text class="text_15">{{selectedAlumniAssociationName || '请选择校友会'}}</text>
      </view>
    </view>

    <!-- 基本信息卡片 -->
    <view class="group_7">
      <text class="text_20">基本信息</text>

      <!-- 校友会信息展示 -->
      <view wx:if="{{alumniAssociationDetail}}" class="alumni-association-info">
        <!-- 背景横幅 -->
        <view class="detail-header">
          <image class="header-bg" src="{{alumniAssociationDetail.bgImg || defaultBackground}}" mode="aspectFill" />
          <image class="platform-avatar-on-bg" src="{{alumniAssociationDetail.logo || defaultAlumniAvatar}}" mode="aspectFill" />
          <view class="info-on-bg">
            <view class="title-row">
              <text class="card-title-on-bg">{{alumniAssociationDetail.associationName || '无'}}</text>
            </view>
          </view>
        </view>
        <view class="info-item">
          <text class="info-label">所属学校</text>
          <view class="info-display-box">{{alumniAssociationDetail.schoolInfo ? alumniAssociationDetail.schoolInfo.schoolName : '未知学校'}}</view>
        </view>
        <view class="info-item">
          <text class="info-label">联系信息</text>
          <view class="info-display-box">{{alumniAssociationDetail.contactInfo || '暂无联系信息'}}</view>
        </view>
        <view class="info-item">
          <text class="info-label">常驻地点</text>
          <view class="info-display-box">{{alumniAssociationDetail.location || '暂无常驻地点'}}</view>
        </view>
        <view class="info-item">
          <text class="info-label">校友会简介</text>
          <view class="info-display-box textarea-box">{{alumniAssociationDetail.associationProfile || '暂无简介'}}</view>
        </view>
        <view class="info-item" wx:if="{{alumniAssociationDetail.chargeName}}">
          <text class="info-label">主要负责人姓名</text>
          <view class="info-display-box">{{alumniAssociationDetail.chargeName}}</view>
        </view>
        <view class="info-item" wx:if="{{alumniAssociationDetail.chargeRole}}">
          <text class="info-label">主要负责人职务</text>
          <view class="info-display-box">{{alumniAssociationDetail.chargeRole}}</view>
        </view>
        <view class="info-item" wx:if="{{alumniAssociationDetail.zhName}}">
          <text class="info-label">驻会代表姓名</text>
          <view class="info-display-box">{{alumniAssociationDetail.zhName}}</view>
        </view>
        <view class="info-item" wx:if="{{alumniAssociationDetail.zhPhone}}">
          <text class="info-label">驻会代表电话</text>
          <view class="info-display-box">{{alumniAssociationDetail.zhPhone}}</view>
        </view>
        <view class="info-item" wx:if="{{alumniAssociationDetail.zhSocialAffiliation}}">
          <text class="info-label">驻会代表社会职务</text>
          <view class="info-display-box">{{alumniAssociationDetail.zhSocialAffiliation}}</view>
        </view>
      </view>

      <!-- 校促会选择 -->
      <view class="form-item required">
        <text class="label">申请加入的校促会</text>
        <picker
          mode="selector"
          range="{{platformList}}"
          range-key="platformName"
          value="{{platformIndex}}"
          bindchange="handlePlatformChange"
          class="input"
        >
          <view class="picker-content">
            {{formData.platformName || '请选择校促会'}}
          </view>
        </picker>
      </view>

    <!-- 反馈入口 -->
    <view class="feedback-hint-section">
      <text class="feedback-hint-text">遇到问题或信息有误？</text>
      <text class="feedback-hint-link" bindtap="goToFeedback">点击反馈</text>
    </view>

    <view class="form-actions">
      <button class="submit-btn" bindtap="submitForm">提交申请</button>
    </view>
    </view>

  <!-- 校友会选择器弹窗 -->
  <view class="alumni-association-picker" wx:if="{{showAlumniAssociationPicker}}">
    <view class="picker-overlay" bindtap="cancelAlumniAssociationSelect"></view>
    <view class="picker-content">
      <view class="picker-header">
        <text class="picker-title">选择校友会</text>
        <text class="picker-cancel" bindtap="cancelAlumniAssociationSelect">取消</text>
      </view>
      <view class="picker-list">
        <view
          class="picker-item"
          wx:for="{{alumniAssociationList}}"
          wx:key="alumniAssociationId"
          data-alumni-association-id="{{item.alumniAssociationId}}"
          data-alumni-association-name="{{item.alumniAssociationName}}"
          bindtap="selectAlumniAssociation"
        >
          <text class="item-name">{{item.alumniAssociationName}}</text>
          <text class="item-check" wx:if="{{selectedAlumniAssociationId == item.alumniAssociationId}}">✓</text>
        </view>
        <view class="picker-empty" wx:if="{{alumniAssociationList.length === 0}}">
          <text>暂无校友会数据</text>
        </view>
      </view>
    </view>
  </view>
  </view>
</custom-nav-bar>
.activity-detail-page {
  min-height: 100vh;
  margin-top: 0;
  position: relative;
  z-index: 1;
}

/* 活动封面 */
.cover-container {
  width: 100%;
  height: 400rpx;
  overflow: hidden;
  position: relative;
}

.cover-image {
  width: 100%;
  height: 100%;
}

/* 白色背景内容区域 */
.white-background-content {
  background-color: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  margin-top: -30rpx;
  position: relative;
  z-index: 10;
  padding-top: 20rpx;
  min-height: 800rpx;
  padding-bottom: 100rpx;
}

/* 活动标题 */
.title-container {
  padding: 24rpx;
  margin-bottom: 12rpx;
  position: relative;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  line-height: 44rpx;
  margin-bottom: 12rpx;
}

.status-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  background-color: #E8F3FF;
  border-radius: 12rpx;
}

.status-text {
  font-size: 20rpx;
  color: #40B2E6;
}

/* 主办方信息 */
.organizer-container {
  padding: 24rpx;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}

.organizer-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.organizer-info {
  flex: 1;
}

.organizer-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
}

.organizer-type {
  font-size: 24rpx;
  color: #999;
}

/* 活动信息 */
.info-section {
  margin-bottom: 12rpx;
}

.info-item {
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  align-items: flex-start;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #666;
  width: 140rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  line-height: 36rpx;
}

.location-info {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.location-btn {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  background-color: #f0f0f0;
  color: #333;
}

.contact-info {
  flex: 1;
}

/* 活动图片 */
.images-section {
  padding: 24rpx;
  margin-bottom: 12rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.images-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -8rpx;
}

.image-item {
  width: 33.33%;
  padding: 8rpx;
  box-sizing: border-box;
}

.activity-image {
  width: 100%;
  height: 133rpx;
  border-radius: 8rpx;
}

/* 活动详情 */
.description-section {
  padding: 24rpx;
  margin-bottom: 12rpx;
}

.description {
  font-size: 26rpx;
  color: #333;
  line-height: 40rpx;
  white-space: pre-wrap;
}

/* 加载中 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  background-color: #f5f5f5;
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

/* 错误提示 */
.error-container {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 100vh;
  background-color: #f5f5f5;
  padding: 0 40rpx;
}

.error-text {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 40rpx;
}

.retry-btn {
  padding: 12rpx 40rpx;
  background-color: #40B2E6;
  color: #fff;
  font-size: 26rpx;
  border-radius: 24rpx;
}
/* ============== 已报名校友区 ============== */
.participants-section {
  padding: 24rpx;
  margin-bottom: 12rpx;
}
.participants-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.participants-count {
  font-size: 24rpx;
  color: #999;
}
.participants-scroll {
  white-space: nowrap;
}
.participants-list {
  display: inline-flex;
  align-items: flex-start;
  gap: 24rpx;
}
.participant-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 110rpx;
}
.participant-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background-color: #eee;
}
.participant-name {
  font-size: 22rpx;
  color: #555;
  margin-top: 10rpx;
  max-width: 110rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ============== 驳回理由 ============== */
.reject-reason {
  margin-top: 30rpx;
  padding: 20rpx 24rpx;
  background-color: #fff1f0;
  border-radius: 12rpx;
  font-size: 26rpx;
}
.reject-reason-label {
  color: #cf1322;
  font-weight: 600;
}
.reject-reason-value {
  color: #555;
  margin-left: 8rpx;
}

/* ============== 报名按钮 & 弹窗 ============== */
.signup-placeholder {
  height: 140rpx;
}
.signup-btn-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 50;
}
.signup-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background-color: #40B2E6;
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
}
.signup-btn-disabled {
  background-color: #c9d3dc !important;
  color: #fff !important;
}

.signup-modal {
  position: fixed;
  inset: 0;
  z-index: 100;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}
.signup-overlay {
  position: absolute;
  inset: 0;
  background-color: rgba(0, 0, 0, 0.45);
}
.signup-content {
  position: relative;
  width: 100%;
  background-color: #fff;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  padding: 32rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  z-index: 1;
}
.signup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.signup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
}
.signup-cancel {
  font-size: 28rpx;
  color: #999;
  padding: 8rpx 0;
}
.signup-form-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}
.signup-label {
  font-size: 26rpx;
  color: #555;
  margin-bottom: 12rpx;
}
.signup-label .required {
  color: #ff4d4f;
  margin-left: 4rpx;
}
.signup-input {
  height: 80rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #222;
}
.signup-textarea {
  width: 100%;
  min-height: 140rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #222;
  box-sizing: border-box;
}
.signup-submit {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #40B2E6;
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-top: 12rpx;
}

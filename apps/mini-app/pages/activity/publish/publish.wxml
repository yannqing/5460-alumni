<!--pages/activity/publish/publish.wxml-->
<custom-nav-bar showBack="{{true}}" useAuditStyle="{{true}}" auditTitle="发布活动">
<view class="page">
  <form bindsubmit="submitForm">
    <view class="form-scroll-wrap">
      <scroll-view class="scroll-content" scroll-y enable-back-to-top show-scrollbar="{{false}}" bindscroll="onFormScroll">
        <view class="group_7">
          <!-- 基本信息 -->
          <view class="form-card">
            <view class="form-title">基本信息</view>

            <view class="form-item">
              <text class="label">活动标题 <text class="required">*</text></text>
              <view class="field-input-wrapper">
                <input
                  class="input"
                  placeholder="填写活动标题"
                  placeholder-class="input-placeholder"
                  adjust-position="{{false}}"
                  data-field="activityTitle"
                  bindinput="onInput"
                  value="{{formData.activityTitle}}"
                  maxlength="200"
                />
              </view>
            </view>

            <view class="form-item">
              <text class="label">活动分类</text>
              <view class="field-input-wrapper">
                <input
                  class="input"
                  placeholder="填写活动分类"
                  placeholder-class="input-placeholder"
                  adjust-position="{{false}}"
                  data-field="activityCategory"
                  bindinput="onInput"
                  value="{{formData.activityCategory}}"
                />
              </view>
            </view>

            <view class="form-item">
              <text class="label">活动封面图 <text class="required">*</text></text>
              <view class="upload-container">
                <view class="cover-preview" wx:if="{{formData.coverImage}}">
                  <image class="cover-image" src="{{formData.coverImage}}" mode="aspectFill"></image>
                  <view class="cover-actions">
                    <view class="change-cover-btn" bindtap="onChangeCover">更换封面</view>
                    <view class="delete-cover-btn" bindtap="onDeleteCover">删除封面</view>
                  </view>
                </view>
                <view class="upload-btn" wx:if="{{!formData.coverImage}}" bindtap="onUploadCover">
                  <text class="upload-icon">+</text>
                  <text class="upload-text">点击上传封面图</text>
                </view>
              </view>
            </view>

            <view class="form-item">
              <text class="label">活动图片</text>
              <view class="upload-container">
                <view class="image-list">
                  <view class="image-item" wx:for="{{activityImagesList}}" wx:key="index">
                    <image class="list-image" src="{{item}}" mode="aspectFill"></image>
                    <view class="image-delete-btn" bindtap="deleteImage" data-index="{{index}}">
                      <text class="delete-icon">×</text>
                    </view>
                  </view>
                  <view class="upload-btn" bindtap="chooseActivityImages" wx:if="{{activityImagesList.length < 9}}">
                    <text class="upload-icon">+</text>
                    <text class="upload-text">{{activityImagesList.length > 0 ? '继续上传' : '点击上传图片'}}</text>
                  </view>
                </view>
                <text class="image-count">{{activityImagesList.length}}/9</text>
              </view>
            </view>

            <view class="form-item">
              <text class="label">活动详情描述 <text class="required">*</text></text>
              <view class="field-textarea-wrapper">
                <textarea
                  class="textarea"
                  placeholder="请输入活动详情描述"
                  placeholder-class="textarea-placeholder"
                  adjust-position="{{false}}"
                  cursor-spacing="120"
                  data-field="description"
                  bindinput="onInput"
                  bindfocus="onFieldFocus"
                  bindblur="onFieldBlur"
                  value="{{formData.description}}"
                  maxlength="-1"
                />
              </view>
            </view>
          </view>

          <!-- 时间信息 -->
          <view class="form-card">
            <view class="form-title">时间信息</view>

            <view class="form-item">
              <text class="label">活动开始时间 <text class="required">*</text></text>
              <view class="time-input-box" bindtap="openTimePicker" data-type="startTime">
                <text class="{{startTimeDisplay ? 'time-input-text' : 'time-input-placeholder'}}">{{startTimeDisplay || '请选择开始时间'}}</text>
                <text class="time-input-arrow">▸</text>
              </view>
            </view>

            <view class="form-item">
              <text class="label">活动结束时间 <text class="required">*</text></text>
              <view class="time-input-box" bindtap="openTimePicker" data-type="endTime">
                <text class="{{endTimeDisplay ? 'time-input-text' : 'time-input-placeholder'}}">{{endTimeDisplay || '请选择结束时间'}}</text>
                <text class="time-input-arrow">▸</text>
              </view>
            </view>

          </view>

          <!-- 地点信息 -->
          <view class="form-card">
            <view class="form-title">地点信息</view>
              <view class="form-item">
                <text class="label">省份</text>
                <input
                  class="input"
                  placeholder="请输入省份"
                  placeholder-class="input-placeholder"
                  adjust-position="{{false}}"
                  data-field="province"
                  bindinput="onInput"
                  value="{{formData.province}}"
                />
              </view>
              
              <view class="form-item">
                <text class="label">城市</text>
                <input
                  class="input"
                  placeholder="请输入城市"
                  placeholder-class="input-placeholder"
                  adjust-position="{{false}}"
                  data-field="city"
                  bindinput="onInput"
                  value="{{formData.city}}"
                />
              </view>
              
              <view class="form-item">
                <text class="label">区县</text>
                <input
                  class="input"
                  placeholder="请输入区县"
                  placeholder-class="input-placeholder"
                  adjust-position="{{false}}"
                  data-field="district"
                  bindinput="onInput"
                  value="{{formData.district}}"
                />
              </view>
              
              <view class="form-item">
                <text class="label">详细地址</text>
                <input
                  class="input"
                  placeholder="请输入详细地址"
                  placeholder-class="input-placeholder"
                  adjust-position="{{false}}"
                  data-field="address"
                  bindinput="onInput"
                  value="{{formData.address}}"
                />
              </view>
              
          </view>
          
          <!-- 报名设置 -->
          <view class="form-card">
            <view class="form-title">报名设置</view>

            <view class="form-item">
              <text class="label">是否需要报名</text>
              <switch
                checked="{{formData.isSignup === 1}}"
                bindchange="onSignupSwitchChange"
                color="#1890ff"
              />
            </view>

            <block wx:if="{{formData.isSignup === 1}}">
              <view class="form-item">
                <text class="label">是否需要审核</text>
                <switch
                  checked="{{formData.isNeedReview === 1}}"
                  bindchange="onNeedReviewSwitchChange"
                  color="#1890ff"
                />
              </view>

              <view class="form-item">
                <text class="label">最大报名人数（不填代表不限）</text>
                <view class="field-input-wrapper">
                  <input
                    class="input"
                    type="number"
                    placeholder="例如：50"
                    placeholder-class="input-placeholder"
                    adjust-position="{{false}}"
                    data-field="maxParticipants"
                    bindinput="onNumberChange"
                    value="{{formData.maxParticipants}}"
                  />
                </view>
              </view>

              <view class="form-item">
                <text class="label">报名开始时间</text>
                <view class="time-input-box" bindtap="openTimePicker" data-type="registrationStartTime">
                  <text class="{{registrationStartTimeDisplay ? 'time-input-text' : 'time-input-placeholder'}}">{{registrationStartTimeDisplay || '请选择报名开始时间'}}</text>
                  <text class="time-input-arrow">▸</text>
                </view>
              </view>

              <view class="form-item">
                <text class="label">报名截止时间</text>
                <view class="time-input-box" bindtap="openTimePicker" data-type="registrationEndTime">
                  <text class="{{registrationEndTimeDisplay ? 'time-input-text' : 'time-input-placeholder'}}">{{registrationEndTimeDisplay || '请选择报名截止时间'}}</text>
                  <text class="time-input-arrow">▸</text>
                </view>
              </view>
            </block>
          </view>

          <!-- 其他设置 -->
          <view class="form-card">
            <view class="form-title">其他设置</view>

            <view class="form-item">
              <text class="label">联系人</text>
              <view class="field-input-wrapper">
                <input
                  class="input"
                  placeholder="请输入联系人"
                  placeholder-class="input-placeholder"
                  adjust-position="{{false}}"
                  data-field="contactPerson"
                  bindinput="onInput"
                  value="{{formData.contactPerson}}"
                />
              </view>
            </view>

            <view class="form-item">
              <text class="label">联系电话</text>
              <view class="field-input-wrapper">
                <input
                  class="input"
                  type="digit"
                  placeholder="请输入联系电话"
                  placeholder-class="input-placeholder"
                  adjust-position="{{false}}"
                  data-field="contactPhone"
                  bindinput="onInput"
                  value="{{formData.contactPhone}}"
                />
              </view>
            </view>

            <view class="form-item">
              <text class="label">联系邮箱</text>
              <view class="field-input-wrapper">
                <input
                  class="input"
                  placeholder="请输入联系邮箱"
                  placeholder-class="input-placeholder"
                  adjust-position="{{false}}"
                  data-field="contactEmail"
                  bindinput="onInput"
                  value="{{formData.contactEmail}}"
                />
              </view>
            </view>

            <view class="form-item">
              <text class="label">备注信息</text>
              <view class="field-textarea-wrapper">
                <textarea
                  class="textarea"
                  placeholder="请输入备注信息"
                  placeholder-class="textarea-placeholder"
                  adjust-position="{{false}}"
                  cursor-spacing="120"
                  data-field="remark"
                  bindinput="onInput"
                  bindfocus="onFieldFocus"
                  bindblur="onFieldBlur"
                  value="{{formData.remark}}"
                />
              </view>
            </view>

            <view class="form-item">
              <text class="label">在主页展示</text>
              <switch
                checked="{{formData.showOnHomepage === 1}}"
                bindchange="onHomepageSwitchChange"
                color="#1890ff"
              />
            </view>
          </view>
          <view class="submit-placeholder"></view>
        </view>
      </scroll-view>
    </view>

    <view class="submit-area">
      <button
        class="submit-btn"
        form-type="submit"
        loading="{{submitting}}"
      >
        发布活动
      </button>
    </view>
  </form>
</view>

<!-- 时间选择器弹窗 -->
<view class="time-picker-mask" wx:if="{{showTimePicker}}" bindtap="closeTimePicker"></view>
<view class="time-picker-popup {{showTimePicker ? 'show' : ''}}">
  <view class="time-picker-header">
    <text class="time-picker-cancel" bindtap="closeTimePicker">取消</text>
    <text class="time-picker-title">{{timePickerTitle}}</text>
    <text class="time-picker-confirm" bindtap="confirmTimePicker">确定</text>
  </view>
  <picker-view
    class="time-picker-view"
    value="{{tempPickerValue}}"
    bindchange="onTempPickerChange"
    indicator-style="height: 50rpx;"
  >
    <picker-view-column>
      <view wx:for="{{yearList}}" wx:key="*this" class="picker-view-item">{{item}}</view>
    </picker-view-column>
    <picker-view-column>
      <view wx:for="{{monthList}}" wx:key="*this" class="picker-view-item">{{item}}</view>
    </picker-view-column>
    <picker-view-column>
      <view wx:for="{{dayList}}" wx:key="*this" class="picker-view-item">{{item}}</view>
    </picker-view-column>
    <picker-view-column>
      <view wx:for="{{hourList}}" wx:key="*this" class="picker-view-item">{{item}}</view>
    </picker-view-column>
    <picker-view-column>
      <view wx:for="{{minuteList}}" wx:key="*this" class="picker-view-item">{{item}}</view>
    </picker-view-column>
  </picker-view>
</view>
</custom-nav-bar>

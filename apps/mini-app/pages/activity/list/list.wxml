<!--pages/activity/list/list.wxml-->
<custom-nav-bar showBack="{{true}}" useAuditStyle="{{true}}" auditTitle="活动管理">
<message-notification />

<view class="page">
  <!-- 校友会选择卡片（与成员管理/架构管理一致，固定不滚动） -->
  <view class="group_5" wx:if="{{!hasSingleAlumniAssociation && hasAlumniAdminPermission}}">
    <text class="text_14">校友会组织</text>
    <text class="label_text">选择校友会</text>
    <view class="text-wrapper_8" bindtap="showAlumniAssociationSelector">
      <text class="text_15">{{selectedAlumniAssociationName || '请选择校友会'}}</text>
    </view>
  </view>

  <!-- 活动列表卡片（与审核列表一致：固定标题+筛选，仅内部滚动） -->
  <view class="group_7">
    <view class="activity-list-header">
      <view class="header-left">
        <text class="header-title">校友活动</text>
        <text class="header-subtitle">一起链接更有能量的同伴</text>
      </view>
      <view class="header-btn-wrap">
        <button class="hero-btn" size="mini" bindtap="goToPublish">发布活动</button>
      </view>
    </view>

    <scroll-view class="scroll-list" scroll-y enable-back-to-top show-scrollbar="{{false}}" style="height: {{scrollListHeight}}px;">
      <view wx:if="{{!displayList.length}}" class="empty-block">
        <text class="empty-text">{{selectedAlumniAssociationId ? '暂无匹配的活动，换个条件试试' : '请先选择校友会'}}</text>
      </view>

      <view class="activity-list" wx:else>
        <view
          class="activity-card"
          wx:for="{{displayList}}"
          wx:key="id"
          bindtap="viewDetail"
          data-id="{{item.id}}"
        >
          <view class="activity-header">
            <view class="activity-title">{{item.title}}</view>
          </view>
          <view class="activity-meta">
            <text>{{item.organizer}}</text>
          </view>
          <view class="activity-tags" wx:if="{{item.tags.length > 0}}">
            <view class="tag" wx:for="{{item.tags}}" wx:key="*this">{{item}}</view>
          </view>
          <view class="activity-footer">
            <text wx:if="{{item.location}}">📍 {{item.location}}</text>
            <text class="time">🕐 {{item.startTime}}</text>
          </view>
          <view class="activity-actions">
            <view class="edit-btn" catchtap="editActivity" data-id="{{item.id}}">编辑</view>
            <view class="delete-btn" catchtap="deleteActivity" data-id="{{item.id}}">删除</view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 校友会选择器弹窗（与架构管理一致） -->
  <view class="alumni-association-picker" wx:if="{{showAlumniAssociationPicker}}">
    <view class="picker-overlay" bindtap="cancelAlumniAssociationSelect"></view>
    <view class="picker-content">
      <view class="picker-header">
        <text class="picker-title">选择校友会</text>
        <text class="picker-cancel" bindtap="cancelAlumniAssociationSelect">取消</text>
      </view>
      <view class="picker-list">
        <view
          class="picker-item {{selectedAlumniAssociationId == item.alumniAssociationId ? 'selected' : ''}}"
          wx:for="{{alumniAssociationList}}"
          wx:key="alumniAssociationId"
          data-alumni-association-id="{{item.alumniAssociationId}}"
          data-alumni-association-name="{{item.alumniAssociationName}}"
          bindtap="selectAlumniAssociation"
        >
          <view class="picker-item-left">
            <image class="picker-item-logo" src="{{item.logo || defaultUserAvatarUrl}}" mode="aspectFill" />
            <view class="picker-item-info">
              <text class="item-name">{{item.alumniAssociationName}}</text>
              <text class="item-location" wx:if="{{item.location}}">{{item.location}}</text>
            </view>
          </view>
          <text class="item-check" wx:if="{{selectedAlumniAssociationId == item.alumniAssociationId}}">✓</text>
        </view>
        <view class="picker-empty" wx:if="{{alumniAssociationList.length === 0}}">
          <text>暂无校友会数据</text>
        </view>
      </view>
    </view>
  </view>
</view>
</custom-nav-bar>

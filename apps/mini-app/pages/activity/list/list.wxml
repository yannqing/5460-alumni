<!--pages/activity/list/list.wxml-->
<custom-nav-bar showBack="{{true}}" useAuditStyle="{{true}}" auditTitle="活动管理">
<message-notification />

<view class="page">
  <!-- 选择校友会区域（现代化下拉框样式，放在左上角） -->
  <view class="alumni-selector-wrap" wx:if="{{!hasSingleAlumniAssociation && hasAlumniAdminPermission}}">
    <view class="alumni-selector" bindtap="showAlumniAssociationSelector">
      <image class="selector-avatar" src="{{selectedAlumniAssociationLogo || defaultUserAvatarUrl}}" mode="aspectFill"></image>
      <text class="selector-text">{{selectedAlumniAssociationName || '请选择校友会'}}</text>
      <text class="selector-arrow">▼</text>
    </view>
  </view>

  <!-- 活动列表卡片（与审核列表一致：固定标题+筛选，仅内部滚动） -->
  <view class="group_7">
    <view class="activity-list-header">
      <view class="header-left">
        <text class="header-title">校友活动</text>
        <text class="header-subtitle">一起链接更有能量的同伴</text>
      </view>
      <view class="header-btn-wrap">
        <button class="hero-btn" size="mini" bindtap="goToPublish">发布活动</button>
      </view>
    </view>

    <scroll-view class="scroll-list" scroll-y enable-back-to-top show-scrollbar="{{false}}" style="height: {{scrollListHeight}}px;">
      <view wx:if="{{!displayList.length}}" class="empty-block">
        <text class="empty-text">{{selectedAlumniAssociationId ? '暂无匹配的活动，换个条件试试' : '请先选择校友会'}}</text>
      </view>

      <view class="activity-list" wx:else>
        <view
          class="activity-card"
          wx:for="{{displayList}}"
          wx:key="id"
          bindtap="viewDetail"
          data-id="{{item.id}}"
        >
          <view class="activity-header">
            <view class="activity-title">{{item.title}}</view>
          </view>
          <view class="activity-meta">
            <text>{{item.organizer}}</text>
          </view>
          <view class="activity-tags" wx:if="{{item.tags.length > 0}}">
            <view class="tag" wx:for="{{item.tags}}" wx:key="*this">{{item}}</view>
          </view>
          <view class="activity-footer">
            <text wx:if="{{item.location}}">📍 {{item.location}}</text>
            <text class="time">🕐 {{item.startTime}}</text>
          </view>
          <view class="activity-actions">
            <view
              wx:if="{{item.isSignup === 1}}"
              class="audit-btn"
              catchtap="goToRegistrationAudit"
              data-id="{{item.id}}"
              data-title="{{item.title}}"
            >报名审核</view>
            <view class="edit-btn" catchtap="editActivity" data-id="{{item.id}}">编辑</view>
            <view class="delete-btn" catchtap="deleteActivity" data-id="{{item.id}}">删除</view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 校友会选择器弹窗 -->
  <organization-picker
    visible="{{showAlumniAssociationPicker}}"
    title="选择校友会"
    list="{{alumniAssociationList}}"
    selectedId="{{selectedAlumniAssociationId}}"
    showSearch="{{true}}"
    searchPlaceholder="搜索校友会"
    emptyText="暂无校友会数据"
    itemKey="alumniAssociationId"
    nameKey="alumniAssociationName"
    showAlphabet="{{true}}"
    bind:select="onAlumniAssociationSelect"
    bind:cancel="cancelAlumniAssociationSelect"
    bind:loadmore="onAlumniAssociationLoadMore"
  />
</view>
</custom-nav-bar>

<!--pages/discover/discover.wxml-->
<!-- 消息通知组件 -->
<message-notification />

<view class="discover-page">
  <!-- 蓝色头部 -->
  <view class="header-section">
    <view class="header-section-inner">
      <view class="header-top-row">
        <view class="logo-placeholder">
          <image class="logo-icon" src="{{icon5460}}" mode="aspectFit"></image>
        </view>
      </view>
      <view class="search-container">
        <text class="search-icon">🔍</text>
        <input
          class="search-input"
          placeholder="搜索附近优惠、活动"
          value="{{searchValue}}"
          confirm-type="search"
          bindinput="handleSearchInput"
          bindconfirm="handleSearchConfirm"
        />
        <view class="search-btn" bindtap="handleSearchConfirm">搜索</view>
      </view>
    </view>
  </view>

  <!-- 白色内容区域 -->
  <view class="white-content-container">
    <!-- 导航标签 -->
    <view class="nav-tabs">
      <view
        class="nav-tab {{selectedTab === item.id ? 'active' : ''}} {{item.disabled ? 'disabled' : ''}}"
        wx:for="{{navTabs}}"
        wx:key="id"
        data-id="{{item.id}}"
        data-disabled="{{item.disabled}}"
        bindtap="handleTabChange"
      >
        <image class="tab-icon-img" src="{{item.icon}}" mode="aspectFit"></image>
        <text class="tab-text">{{item.label}}</text>
        <view wx:if="{{item.disabled}}" class="construction-tag">开发中</view>
      </view>
    </view>

  </view>

  <!-- 视图切换和排序 -->
  <view class="view-sort-container">
    <view class="view-toggle">
      <view
        class="toggle-item {{viewMode === 'map' ? 'active' : ''}}"
        bindtap="switchViewMode"
        data-mode="map"
      >
        <text class="toggle-icon">🗺️</text>
        <text class="toggle-text">地图</text>
      </view>
      <view
        class="toggle-item {{viewMode === 'list' ? 'active' : ''}}"
        bindtap="switchViewMode"
        data-mode="list"
      >
        <text class="toggle-icon">📋</text>
        <text class="toggle-text">列表</text>
      </view>
    </view>
  </view>

  <!-- 列表视图 -->
  <scroll-view
    class="list-view"
    wx:if="{{viewMode === 'list'}}"
    scroll-y="true"
    show-scrollbar="{{false}}"
    refresher-enabled="true"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onPullDownRefresh"
    bindscrolltolower="onReachBottom"
    lower-threshold="100"
  >
    <!-- 附近优惠列表 -->
    <view class="content-list" wx:if="{{selectedTab === 'coupon'}}">
      <!-- 骨架加载 -->
      <view wx:if="{{loading && couponList.length === 0}}" class="skeleton-list">
        <view class="skeleton-card" wx:for="{{[1,2,3]}}" wx:key="*this">
          <view class="skeleton-card-header">
            <view class="skeleton-avatar"></view>
            <view class="skeleton-card-info">
              <view class="skeleton-title"></view>
              <view class="skeleton-subtitle"></view>
            </view>
          </view>
          <view class="skeleton-coupon-row">
            <view class="skeleton-coupon-tag"></view>
            <view class="skeleton-coupon-tag short"></view>
          </view>
        </view>
      </view>

      <view class="empty-tip" wx:if="{{couponList.length === 0 && !loading}}">暂无附近优惠</view>

      <view class="merchant-list-container" wx:if="{{couponList.length > 0}}">
        <merchant-card
          wx:for="{{couponList}}"
          wx:key="merchantId"
          item="{{item}}"
          bind:tap="handleShopTap"
          bind:coupontap="handleCouponTap"
        />
      </view>

      <view class="no-more" wx:if="{{!hasMore && couponList.length > 0 && !loading}}">没有更多了</view>
    </view>

    <!-- 附近场所列表 -->
    <view class="content-list" wx:if="{{selectedTab === 'venue'}}">
      <view class="empty-tip" wx:if="{{venueList.length === 0 && !loading}}">暂无附近场所</view>

      <view class="venue-card" wx:for="{{venueList}}" wx:key="id">
        <image class="venue-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="venue-content">
          <view class="venue-header">
            <view class="venue-name">{{item.name}}</view>
            <view class="venue-type-tag" wx:if="{{item.typeLabel}}">{{item.typeLabel}}</view>
          </view>

          <view class="venue-address" wx:if="{{item.address}}">
            <text class="venue-icon">📍</text>
            <text class="venue-address-text">{{item.address}}</text>
          </view>

          <view class="venue-info-row">
            <view class="venue-distance">
              <text class="venue-icon">📏</text>
              <text>{{item.distance}}</text>
            </view>
            <view class="venue-contact" wx:if="{{item.contactPhone}}">
              <text class="venue-icon">📞</text>
              <text>{{item.contactPhone}}</text>
            </view>
          </view>

          <view class="venue-stats" wx:if="{{item.ratingScore > 0 || item.viewCount > 0}}">
            <view class="stat-item" wx:if="{{item.ratingScore > 0}}">
              <text class="stat-icon">⭐</text>
              <text class="stat-text">{{item.ratingScore}}分</text>
            </view>
            <view class="stat-item" wx:if="{{item.viewCount > 0}}">
              <text class="stat-icon">👁️</text>
              <text class="stat-text">{{item.viewCount}}次浏览</text>
            </view>
          </view>

          <view class="venue-description" wx:if="{{item.description}}">{{item.description}}</view>
        </view>
      </view>

      <view class="no-more" wx:if="{{!hasMore && venueList.length > 0 && !loading}}">没有更多了</view>
    </view>

    <!-- 附近校友列表 (已隐藏) -->
    <!-- <view class="content-list" wx:if="{{selectedTab === 'alumni'}}">
      <view class="content-card" wx:for="{{alumniList}}" wx:key="id">
        <view class="card-avatar">
          <image class="avatar-img" src="{{item.avatar}}" mode="aspectFill" wx:if="{{item.avatar}}"></image>
        </view>
        <view class="card-content">
          <view class="card-name">{{item.name}}</view>
          <view class="card-distance">距离 {{item.distance}}</view>
          <view class="card-signature" wx:if="{{item.signature}}">{{item.signature}}</view>
          <view class="card-association" wx:if="{{item.association}}">{{item.association}}</view>
          <view class="card-tag" wx:if="{{item.tag}}">{{item.tag}}</view>
        </view>
        <view class="card-action">
          <view class="follow-btn {{item.isFollowed ? 'followed' : ''}}" bindtap="handleFollow" data-id="{{item.id}}" data-followed="{{item.isFollowed}}">
            {{item.isFollowed ? '已关注' : '关注'}}
          </view>
        </view>
      </view>
    </view> -->

    <!-- 附近活动列表 -->
    <view class="content-list" wx:if="{{selectedTab === 'activity'}}">
      <!-- 骨架加载 -->
      <view wx:if="{{loading && activityList.length === 0}}" class="skeleton-list">
        <view class="skeleton-card" wx:for="{{[1,2,3]}}" wx:key="*this">
          <view class="skeleton-card-header">
            <view class="skeleton-avatar"></view>
            <view class="skeleton-card-info">
              <view class="skeleton-title"></view>
              <view class="skeleton-subtitle"></view>
            </view>
          </view>
          <view class="skeleton-coupon-row">
            <view class="skeleton-coupon-tag"></view>
          </view>
        </view>
      </view>

      <view class="empty-tip" wx:if="{{activityList.length === 0 && !loading}}">暂无附近活动</view>

      <view class="merchant-list-container" wx:if="{{activityList.length > 0}}">
        <merchant-card
          wx:for="{{activityList}}"
          wx:key="merchantId"
          item="{{item}}"
          bind:tap="handleShopTap"
          bind:activitytap="handleActivityTap"
        />
      </view>

      <view class="no-more" wx:if="{{!hasMore && activityList.length > 0 && !loading}}">没有更多了</view>
    </view>
  </scroll-view>

  <!-- 地图视图 -->
  <view class="map-view" wx:if="{{viewMode === 'map'}}">
    <map
      id="discoverMap"
      class="discover-map"
      latitude="{{mapCenter.latitude}}"
      longitude="{{mapCenter.longitude}}"
      scale="{{mapScale}}"
      enable-scroll="{{!showCouponMerchantPopup}}"
      enable-zoom="{{!showCouponMerchantPopup}}"
      markers="{{mapMarkers}}"
      bindmarkertap="onMarkerTap"
      bindtap="onMapTap"
    ></map>
    <!-- 隐藏的 Canvas，用于绘制圆形头像 -->
    <canvas canvas-id="roundAvatarCanvas" class="hidden-canvas"></canvas>
    <!-- 定位到我的位置按钮 -->
    <view class="location-btn" bindtap="locateToMyPosition">
      <text class="location-icon">📍</text>
    </view>

    <!-- 附近优惠商家弹窗 -->
    <view
      wx:if="{{showCouponMerchantPopup && (selectedTab === 'coupon' || selectedTab === 'activity') && selectedCouponMerchant}}"
      class="merchant-popup-mask"
      bindtap="closeCouponMerchantPopup"
    >
      <view class="merchant-popup-card" catchtap="noop">
        <view class="merchant-popup-top-detail-btn" bindtap="handleCouponMerchantDetailTap">查看详情</view>
        <view class="merchant-popup-header">
          <image
            class="merchant-popup-logo"
            src="{{selectedCouponMerchant.logoUrl}}"
            mode="aspectFill"
          ></image>
          <view class="merchant-popup-info">
            <view class="merchant-popup-name">{{selectedCouponMerchant.name}}</view>
            <view class="merchant-popup-city">城市：{{selectedCouponMerchant.city}}</view>
            <view class="merchant-popup-distance" wx:if="{{selectedCouponMerchant.distance}}">
              距离：{{selectedCouponMerchant.distance}}
            </view>
            <view class="merchant-popup-favorite">
              收藏：{{selectedCouponMerchant.favoriteCount}}人
            </view>
          </view>
        </view>
        <view class="merchant-popup-coupons" wx:if="{{selectedCouponMerchant.coupons.length > 0}}">
          <view class="merchant-popup-coupons-title">优惠券</view>
          <view
            class="merchant-popup-coupon-item"
            wx:for="{{selectedCouponMerchant.coupons}}"
            wx:key="couponId"
            bindtap="handlePopupCouponTap"
            data-coupon-id="{{item.couponId}}"
          >
            <view class="merchant-popup-coupon-tag">券</view>
            <text class="merchant-popup-coupon-discount">{{item.discountText}}</text>
            <text class="merchant-popup-coupon-name">{{item.couponName}}</text>
          </view>
        </view>
        <view
          class="merchant-popup-coupons-empty"
          wx:if="{{selectedCouponMerchant.popupType === 'coupon' && selectedCouponMerchant.coupons.length === 0}}"
        >
          暂无可展示优惠券
        </view>
        <view class="merchant-popup-coupons" wx:if="{{selectedCouponMerchant.activities.length > 0}}">
          <view class="merchant-popup-coupons-title">活动</view>
          <view
            class="merchant-popup-coupon-item"
            wx:for="{{selectedCouponMerchant.activities}}"
            wx:key="activityId"
            bindtap="handlePopupActivityTap"
            data-activity-id-safe="{{item.activityIdSafe}}"
          >
            <view class="merchant-popup-activity-tag">活</view>
            <text class="merchant-popup-coupon-name">{{item.activityTitle}}</text>
          </view>
        </view>
        <view
          class="merchant-popup-coupons-empty"
          wx:if="{{selectedCouponMerchant.popupType === 'activity' && selectedCouponMerchant.activities.length === 0}}"
        >
          暂无可展示活动
        </view>
      </view>
    </view>
  </view>
</view>

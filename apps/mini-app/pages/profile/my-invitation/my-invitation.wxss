/* pages/profile/my-invitation/my-invitation.wxss */
.page {
  background-color: transparent;
  position: relative;
  width: 750rpx;
  height: 100%;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.group_7 {
  width: 714rpx;
  flex: 1;
  background-color: #FFFFFF;
  border-radius: 28.99rpx;
  display: flex;
  flex-direction: column;
  margin: 34rpx 0 20rpx 18rpx;
  padding: 38rpx 25rpx 20rpx 25rpx;
  box-sizing: border-box;
  overflow: hidden;
  position: relative;
  z-index: 1;
}

.scroll-list {
  flex: 1;
  width: 100%;
  min-height: 0;
  position: relative;
  z-index: 0;
}

/* 顶部统计区域 */
.summary {
  padding: 20rpx 24rpx;
  margin-bottom: 32rpx;
  background-color: #f7f8fa;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
}

.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.summary-label {
  font-size: 24rpx;
  color: #999;
}

.summary-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.summary-text-number {
  font-size: 32rpx;
  font-weight: 600;
  color: #ff7d27;
  padding: 0 4rpx;
}

.summary-text-rank {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffae00;
  padding: 0 4rpx;
}

.summary-btn {
  margin-left: 20rpx;
  padding: 8rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #ffffff;
  background: #40B2E6;
  flex-shrink: 0;
}

.summary-value {
  margin-top: 8rpx;
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
}

/* 邀请记录列表 */
.invite-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1px solid #F3F3F3;
}

.invite-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background-color: #f5f5f5;
}

.invite-name {
  font-size: 30rpx;
  color: #333;
  max-width: 500rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.invite-status {
  font-size: 24rpx;
  color: #18a058;
}

.invite-sub {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}

.invite-wxid {
  max-width: 380rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.invite-time {
  margin-left: 16rpx;
}

/* 底部邀请按钮 */
.invite-btn-wrap {
  padding: 32rpx 0 20rpx;
  flex-shrink: 0;
}
.invite-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #40B2E6 0%, #5cc5f5 100%);
  border-radius: 44rpx;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 80vh;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

<!--pages/profile/invitation-poster/invitation-poster.wxml-->
<!-- 自定义导航栏 -->
<custom-nav-bar showBack="{{true}}" useAuditStyle="{{true}}" auditTitle="邀请海报">
<view class="page">
  <view class="group_7">
    <block wx:if="{{loading}}">
      <view class="loading-container">
        <view class="loading-spinner"></view>
        <text class="loading-text">正在生成海报，请稍候...</text>
      </view>
    </block>
    <block wx:elif="{{list && list.length}}">
      <scroll-view class="scroll-list" scroll-y="true">
        <block wx:for="{{list}}" wx:key="id">
          <view class="poster-item">
            <view class="poster-container" data-url="{{item.imageUrl}}" bindlongpress="onPosterLongPress">
              <image class="poster-image" src="{{item.imageUrl}}" mode="widthFix" show-menu-by-longpress="{{false}}" />
              <view class="poster-copy">
                <text class="poster-copy-line1">HI 同学：</text>
                <text class="poster-copy-line2">思念母校，发现校友；搭建校友平台，助力校友经济，邀请您加入中国校友录5460，享5460专属权益。</text>
              </view>
            </view>
          </view>
        </block>
      </scroll-view>
    </block>
    <block wx:else>
      <view class="empty-container">
        <text class="empty-text">暂无海报模板</text>
      </view>
    </block>
  </view>
  <canvas
    canvas-id="posterSaveCanvas"
    class="poster-save-canvas"
    style="width: {{canvasWidth}}px; height: {{canvasHeight}}px;"
  />
</view>
</custom-nav-bar>

/* pages/profile/invitation-poster/invitation-poster.wxss */
.page {
  background-color: transparent;
  position: relative;
  width: 750rpx;
  height: 100%;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.group_7 {
  width: 714rpx;
  flex: 1;
  background-color: #FFFFFF;
  border-radius: 28.99rpx;
  display: flex;
  flex-direction: column;
  margin: 34rpx 0 20rpx 18rpx;
  padding: 38rpx 25rpx 20rpx 25rpx;
  box-sizing: border-box;
  overflow: hidden;
  position: relative;
  z-index: 1;
}

.scroll-list {
  flex: 1;
  width: 100%;
  min-height: 0;
  position: relative;
  z-index: 0;
}

.loading-container {
  flex: 1;
  min-height: 300rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 6rpx solid #e3ecff;
  border-top-color: #3b82f6;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}

.loading-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #6b7280;
}

.poster-container {
  position: relative;
  overflow: hidden;
}

.poster-copy {
  position: absolute;
  left: 72rpx;
  right: 72rpx;
  top: 680rpx;
  z-index: 2;
  color: #5f6b7a;
  line-height: 1.6;
}

.poster-copy-line1 {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
}

.poster-copy-line2 {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  text-indent: 2em;
}

.poster-item {
  padding-bottom: 32rpx;
}

.poster-image {
  width: 100%;
  border-radius: 16rpx;
  display: block;
}

.poster-save-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  opacity: 0;
  pointer-events: none;
}

/* 空状态 */
.empty-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  min-height: 300rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}


/* pages/alumni-activity/list/list.wxss */

.activity-list-page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.activity-scroll {
  height: 100vh;
  box-sizing: border-box;
}

/* 活动列表 */
.activity-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 20rpx;
}

/* 活动卡片 */
.activity-card {
  position: relative;
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 右上角状态标签 */
.status-tag {
  position: absolute;
  top: 0;
  right: 0;
  width: 104rpx;
  height: 104rpx;
  transform: translateY(-40rpx);
  z-index: 10;
}

/* 封面容器 */
.activity-cover-wrapper {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
  border-radius: 12rpx;
  overflow: hidden;
}

.activity-cover {
  width: 100%;
  height: 100%;
}

/* 状态标签 */
.activity-status {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 12rpx;
  border-radius: 20rpx;
  background: rgba(0, 0, 0, 0.5);
}

.status-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #52c41a;
}

.activity-status.ongoing .status-dot {
  background: #52c41a;
}

.activity-status.upcoming .status-dot {
  background: #1890ff;
}

.activity-status.ended .status-dot {
  background: #999;
}

.status-text {
  font-size: 20rpx;
  color: #fff;
}

/* 活动类型标签 */
.activity-type-tag {
  position: absolute;
  bottom: 12rpx;
  left: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 83rpx;
  height: 33rpx;
  background: #4A64C7;
  border-radius: 11rpx;
}

.type-text {
  font-size: 20rpx;
  color: #fff;
  line-height: 1;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  font-weight: 600;
}

/* 活动信息 */
.activity-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 8rpx 0;
  transform: translateY(3rpx);
  overflow: hidden;
}

.activity-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  padding-right: 56rpx; /* 增加右侧间距，使每行少展示约2个字 */
}

/* 主办方信息 */
.activity-organizer {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
}

.organizer-avatar {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background-color: #f0f0f0;
}

.organizer-name {
  font-size: 22rpx;
  color: #666;
  max-width: 350rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.organizer-type {
  font-size: 18rpx;
  color: #fff;
  background: #6F8BE6;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.activity-time,
.activity-address {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
}

.info-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.info-text {
  font-size: 24rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 价格标签 */
.activity-price-tag {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
}

.price-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #ff4d4f;
}

.price-text.free {
  color: #52c41a;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

/* 加载更多 */
.loading-more,
.first-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
}

.loading-dots {
  display: flex;
  gap: 12rpx;
}

.loading-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #701FFF;
  animation: loading-bounce 1.4s infinite ease-in-out both;
}

.loading-dot:nth-child(1) {
  animation-delay: -0.32s;
}

.loading-dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes loading-bounce {
  0%, 80%, 100% {
    transform: scale(0);
  }
  40% {
    transform: scale(1);
  }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #999;
}

/* 没有更多 */
.no-more {
  text-align: center;
  padding: 30rpx;
  font-size: 26rpx;
  color: #999;
}

page {
  background-color: #f5f5f5;
  margin: 0;
  padding: 0;
  height: 100vh;
  overflow: hidden;
}

.white-background-content {
  background-color: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  margin-top: -30rpx;
  position: relative;
  z-index: 1;
  padding-top: 20rpx;
  height: calc(100vh - 88px);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.container {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx;
}

.info-text {
  font-size: 32rpx;
  color: #333;
  text-align: center;
  line-height: 1.8;
}

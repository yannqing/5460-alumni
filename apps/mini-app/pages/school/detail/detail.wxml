<custom-nav-bar showBack="{{true}}" useAuditStyle="{{true}}" auditTitle="总会详情">
  <message-notification />

  <view class="school-detail-page">
    <view wx:if="{{headquartersInfo}}">
      <!-- 顶部背景图区域（包含校友总会信息） -->
      <view class="top-background-container">
        <image class="cover-image" src="{{headquartersInfo.cover}}" mode="aspectFill" bindtap="previewImage" data-url="{{headquartersInfo.cover}}" />
        <!-- 渐变遮罩 -->
        <view class="bg-gradient-overlay"></view>
        <!-- 校友总会头像 -->
        <image class="school-avatar-on-bg" src="{{headquartersInfo.icon}}" mode="aspectFill" />
        <!-- 校友总会信息 -->
        <view class="school-info-on-bg">
          <text class="school-name-on-bg">{{headquartersInfo.headquartersName}}</text>
          <view wx:if="{{headquartersInfo.address}}" class="location-row-on-bg">
            <image class="location-icon-on-bg" src="{{iconLocation}}" mode="aspectFit" />
            <text>{{headquartersInfo.address}}</text>
          </view>
        </view>
      </view>

      <!-- 标签栏 -->
      <view class="tabs">
        <view wx:for="{{tabs}}" wx:key="index" class="tab-item {{activeTab === index ? 'active' : ''}}" bindtap="switchTab" data-index="{{index}}">
          {{item}}
        </view>
      </view>

      <!-- 白色背景内容区域 -->
      <view class="white-background">

        <!-- 基本信息 -->
        <view wx:if="{{activeTab === 0}}" class="card">
          <view class="text-bold mb-20">基本信息</view>
          
          <view wx:if="{{headquartersInfo.description}}" class="text-secondary">{{headquartersInfo.description}}</view>
          <view wx:if="{{headquartersInfo.schoolInfo && headquartersInfo.schoolInfo.schoolName}}" class="divider"></view>
          <view wx:if="{{headquartersInfo.establishedDate}}" class="divider"></view>
          <view wx:if="{{headquartersInfo.establishedDate}}" class="basic-info-item">成立日期：{{headquartersInfo.establishedDate}}</view>
          <view wx:if="{{headquartersInfo.address}}" class="divider"></view>
          <view wx:if="{{headquartersInfo.address}}" class="basic-info-item">办公地址：{{headquartersInfo.address}}</view>
          <view wx:if="{{headquartersInfo.phone}}" class="divider"></view>
          <view wx:if="{{headquartersInfo.phone}}" class="basic-info-item">联系电话：{{headquartersInfo.phone}}</view>
          <view wx:if="{{headquartersInfo.email}}" class="divider"></view>
          <view wx:if="{{headquartersInfo.email}}" class="basic-info-item">联系邮箱：{{headquartersInfo.email}}</view>
          <view wx:if="{{headquartersInfo.website}}" class="divider"></view>
          <view wx:if="{{headquartersInfo.website}}" class="basic-info-item">官方网站：{{headquartersInfo.website}}</view>
          <view wx:if="{{headquartersInfo.wechatPublicAccount}}" class="divider"></view>
          <view wx:if="{{headquartersInfo.wechatPublicAccount}}" class="basic-info-item">微信公众号：{{headquartersInfo.wechatPublicAccount}}</view>
          <view wx:if="{{headquartersInfo.memberCount}}" class="divider"></view>
          <view wx:if="{{headquartersInfo.memberCount}}" class="basic-info-item">下属校友会总数：{{headquartersInfo.memberCount}}</view>
          <view wx:if="{{headquartersInfo.contactInfo}}" class="divider"></view>
          <view wx:if="{{headquartersInfo.contactInfo}}" class="basic-info-item">联系信息：{{headquartersInfo.contactInfo.content || headquartersInfo.contactInfo}}</view>
        </view>

        <!-- 组织架构 -->
        <view wx:if="{{activeTab === 1}}" class="card">
          <view class="text-bold mb-20">组织架构</view>
          <view class="empty-association">
            <text class="empty-text">组织架构功能开发中</text>
          </view>
        </view>

        <!-- 成员列表 -->
        <view wx:if="{{activeTab === 2}}" class="card">
          <view class="text-bold mb-20">成员列表</view>
          <view class="empty-association">
            <text class="empty-text">成员列表功能开发中</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</custom-nav-bar>

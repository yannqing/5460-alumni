.page {
  padding: 20rpx;
  min-height: 100%;
  box-sizing: border-box;
}

.content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid #eef0f4;
}

.loading,
.empty {
  display: block;
  text-align: center;
  color: #9ca3af;
  font-size: 26rpx;
  padding: 40rpx 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 18rpx;
}

.status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
}

.edit-btn {
  min-width: 120rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  border: 1rpx solid #40b2e6;
  color: #40b2e6;
  background: #fff;
  font-size: 24rpx;
}

.status-pill {
  font-size: 24rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
}

.status-pill.pending { color: #b45309; background: #fff7ed; }
.status-pill.approved { color: #166534; background: #ecfdf3; }
.status-pill.rejected { color: #b91c1c; background: #fef2f2; }
.status-pill.cancelled { color: #6b7280; background: #f3f4f6; }
.status-pill.unknown { color: #374151; background: #f3f4f6; }

.sub {
  color: #6b7280;
  font-size: 22rpx;
}

.row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 14rpx;
  gap: 14rpx;
}

.row:last-child {
  margin-bottom: 0;
}

.row.vertical {
  flex-direction: column;
}

.label {
  width: 132rpx;
  color: #6b7280;
  font-size: 24rpx;
  flex-shrink: 0;
}

.value {
  flex: 1;
  min-width: 0;
  color: #111827;
  font-size: 25rpx;
  word-break: break-all;
}

.multiline {
  line-height: 1.6;
}

.attachments {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.attachment-item {
  width: 180rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.attachment-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 10rpx;
  background: #eef0f4;
}

.attachment-name {
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.3;
  word-break: break-all;
}

.page {
  padding: 20rpx;
  min-height: 100%;
  box-sizing: border-box;
}

.content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid #eef0f4;
}

.loading,
.empty {
  display: block;
  text-align: center;
  color: #9ca3af;
  font-size: 26rpx;
  padding: 40rpx 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 18rpx;
}

.status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
}

.action-buttons {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.edit-btn {
  min-width: 120rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  border: 1rpx solid #40b2e6;
  color: #40b2e6;
  background: #fff;
  font-size: 24rpx;
}

.cancel-btn {
  min-width: 120rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  border: 1rpx solid #ef4444;
  color: #ef4444;
  background: #fff;
  font-size: 24rpx;
}

.status-pill {
  font-size: 24rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
}

.status-pill.pending { color: #b45309; background: #fff7ed; }
.status-pill.approved { color: #166534; background: #ecfdf3; }
.status-pill.rejected { color: #b91c1c; background: #fef2f2; }
.status-pill.cancelled { color: #6b7280; background: #f3f4f6; }
.status-pill.unknown { color: #374151; background: #f3f4f6; }

.sub {
  color: #6b7280;
  font-size: 22rpx;
}

.row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 14rpx;
  gap: 14rpx;
}

.row:last-child {
  margin-bottom: 0;
}

.row.vertical {
  flex-direction: column;
}

.label {
  width: 132rpx;
  color: #6b7280;
  font-size: 24rpx;
  flex-shrink: 0;
}

.value {
  flex: 1;
  min-width: 0;
  color: #111827;
  font-size: 25rpx;
  word-break: break-all;
}

.multiline {
  line-height: 1.6;
}

.nowrap {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: normal;
}

.attachments {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.attachment-item {
  width: 180rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.attachment-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 10rpx;
  background: #eef0f4;
}

.attachment-name {
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.3;
  word-break: break-all;
}

/* 创建校友会详情：与 audit/alumni-association/detail 一致的顶栏与分区 */
.create-assoc-header {
  position: relative;
  width: 100%;
  height: 320rpx;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.create-assoc-header-bg {
  width: 100%;
  height: 100%;
  display: block;
}

.create-assoc-header-mask {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.45) 100%);
  z-index: 1;
}

.create-assoc-header-inner {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 28rpx;
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  z-index: 2;
}

.create-assoc-logo-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #fff;
  padding: 6rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  flex-shrink: 0;
}

.create-assoc-logo {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.create-assoc-title {
  flex: 1;
  margin-left: 20rpx;
  padding-bottom: 8rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.35);
  word-break: break-all;
}

.create-assoc-card .create-assoc-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 18rpx;
  padding-left: 12rpx;
  border-left: 6rpx solid #4a8bf5;
}

.create-member-list {
  background: #f7f8fa;
  border-radius: 16rpx;
  padding: 24rpx;
}

.create-member-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.create-member-item:last-child {
  border-bottom: none;
}

.create-member-line {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 8rpx;
}

.create-member-name {
  font-size: 28rpx;
  font-weight: 500;
  color: rgba(0, 0, 0, 0.85);
  margin-right: 20rpx;
}

.create-member-phone {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.55);
}

.create-member-affil {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.55);
  line-height: 1.6;
}

<custom-nav-bar showBack="{{true}}" useAuditStyle="{{true}}" auditTitle="校友会认证详情">
  <view class="page">
    <scroll-view class="container" scroll-y enable-back-to-top>
      <!-- 骨架屏加载状态 -->
      <view class="skeleton-container" wx:if="{{loading}}">
        <view class="skeleton-header">
          <view class="skeleton-avatar skeleton-animate"></view>
          <view class="skeleton-user-info">
            <view class="skeleton-name skeleton-animate"></view>
            <view class="skeleton-time skeleton-animate"></view>
          </view>
        </view>
        <view class="skeleton-title skeleton-animate"></view>
        <view class="skeleton-content">
          <view class="skeleton-line skeleton-animate"></view>
          <view class="skeleton-line skeleton-animate" style="width: 85%;"></view>
          <view class="skeleton-line skeleton-animate" style="width: 70%;"></view>
        </view>
      </view>

      <!-- 认证详情内容 -->
      <block wx:elif="{{detail}}">
        <!-- 背景横幅 -->
        <view class="detail-header">
          <image class="header-bg" src="{{detail.applyBgImg || detail.bgImg || defaultBackground}}" mode="aspectFill" />
          <view class="header-content">
            <view class="header-left">
              <view class="logo-container">
                <image class="association-logo" src="{{detail.applyLogo || detail.logo || defaultAlumniAvatar}}" mode="aspectFill" />
              </view>
            </view>
            <view class="association-basic">
              <text class="association-name">{{detail.associationName || '无'}}</text>
            </view>
          </view>
        </view>

        <!-- 详细信息卡片 -->
        <view class="detail-card">
          <!-- 基本状态 -->
          <view class="info-grid">
            <view class="info-item">
              <text class="info-label">审核状态</text>
              <view class="status-tag {{statusClass}}">
                <text class="status-text">{{statusText}}</text>
              </view>
            </view>
            <view class="info-item">
              <text class="info-label">提交时间</text>
              <text class="info-value">{{detail.createTime || '-'}}</text>
            </view>
          </view>

          <!-- 申请人信息 -->
          <view class="detail-section">
            <view class="section-title">申请人信息</view>
            <view class="info-item">
              <text class="info-label">申请人</text>
              <view class="info-value" style="display: flex; align-items: center;">
                <image wx:if="{{detail.applicantAvatarUrl}}" src="{{detail.applicantAvatarUrl}}" class="applicant-avatar" mode="aspectFill" />
                <text>{{detail.applicantName || '-'}}</text>
              </view>
            </view>
            <view class="info-item">
              <text class="info-label">联系电话</text>
              <text class="info-value">{{detail.applicantPhone || '-'}}</text>
            </view>
          </view>

          <view class="divider"></view>

          <!-- 校友会基本信息 -->
          <view class="detail-section">
            <view class="section-title">校友会信息</view>
            <view class="info-item">
              <text class="info-label">校友会名称</text>
              <text class="info-value">{{detail.associationName || '-'}}</text>
            </view>
            <view class="info-item">
              <text class="info-label">常驻地点</text>
              <text class="info-value">{{detail.location || '-'}}</text>
            </view>
            <view class="info-item">
              <text class="info-label">联系电话</text>
              <text class="info-value">{{detail.contactInfo || '-'}}</text>
            </view>
            <view class="info-item" style="flex-direction: column;">
              <text class="info-label" style="width: 100%; margin-bottom: 12rpx;">校友会简介</text>
              <text class="info-value multi-line">{{detail.associationProfile || '-'}}</text>
            </view>
          </view>

          <view class="divider"></view>

          <!-- 负责人及联系人信息 -->
          <view class="detail-section">
            <view class="section-title">负责人信息</view>
            <view class="info-item">
              <text class="info-label">负责人姓名</text>
              <text class="info-value">{{detail.applyChargeName || '-'}}</text>
            </view>
            <view class="info-item">
              <text class="info-label">职务</text>
              <text class="info-value">{{detail.applyChargeRole || '-'}}</text>
            </view>
            <view class="info-item">
              <text class="info-label">联系方式</text>
              <text class="info-value">{{detail.applyContactInfo || '-'}}</text>
            </view>
          </view>

          <view class="divider"></view>

          <view class="detail-section">
            <view class="section-title">联系人</view>
            <view class="info-item">
              <text class="info-label">联系人姓名</text>
              <text class="info-value">{{detail.applyZhName || '-'}}</text>
            </view>
            <view class="info-item">
              <text class="info-label">职务</text>
              <text class="info-value">{{detail.applyZhRole || '-'}}</text>
            </view>
            <view class="info-item">
              <text class="info-label">联系电话</text>
              <text class="info-value">{{detail.applyZhPhone || '-'}}</text>
            </view>
          </view>

          <view class="divider"></view>

          <!-- 附件信息 -->
          <view class="detail-section">
            <view class="section-title">创建申请附件</view>
            <view class="attachment-container" wx:if="{{detail.attachmentFiles && detail.attachmentFiles.length > 0}}">
              <view class="attachment-grid">
                <view 
                  class="attachment-item {{item.isImage ? 'image-item' : 'file-item'}}" 
                  wx:for="{{detail.attachmentFiles}}" 
                  wx:key="fileId"
                >
                  <!-- 内容展示区域 -->
                  <view 
                    class="attachment-content" 
                    data-url="{{item.fileUrl}}"
                    data-is-image="{{item.isImage}}"
                    bindtap="handleAttachmentTap"
                  >
                    <!-- 图片预览 -->
                    <image 
                      wx:if="{{item.isImage}}" 
                      class="preview-image" 
                      src="{{item.fileUrl}}" 
                      mode="aspectFill" 
                      lazy-load="{{true}}"
                    />
                    <!-- 文件预览 -->
                    <view wx:else class="file-preview-box">
                      <view class="file-icon-bg">
                        <text class="file-ext-text">{{item.fileExtension || 'FILE'}}</text>
                      </view>
                      <view class="file-info">
                        <text class="file-name">{{item.displayName}}</text>
                        <text class="file-meta">{{item.fileSizeText}}</text>
                      </view>
                    </view>
                  </view>
                </view>
              </view>
            </view>
            <view class="empty-wrap" style="padding: 40rpx 0;" wx:else>
              <text>暂无附件</text>
            </view>
          </view>
        </view>

        <view class="bottom-placeholder"></view>
      </block>

      <!-- 错误状态 -->
      <view wx:else class="empty-wrap">
        <text>暂无详情数据</text>
      </view>
    </scroll-view>
  </view>
</custom-nav-bar>

                <!-- 待处理角标 -->
                <view wx:if="{{item.code && auditTodo.todoCount(todoCounts, item.code) > 0}}" class="badge">
                  {{auditTodo.todoBadgeText(todoCounts, item.code)}}
                </view>
              </view>
              <text lines="1" class="text-group_name_common">{{item.name}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 商家 -->
    <view class="section_8 {{merchantFunctions.length > 4 ? 'section_8_multi-row' : ''}}" wx:if="{{merchantFunctions.length > 0}}">
      <text lines="1" class="text_18">商家</text>
      <view class="grid_1">

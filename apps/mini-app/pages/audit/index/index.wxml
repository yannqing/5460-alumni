              <text lines="1" class="text-group_name_common">{{item.name}}</text>
            </view>
          </view>
        </view>

        <!-- 校友会 -->
        <view class="list-items_common {{alumniFunctions.length > 4 ? 'list-items_multi-row' : ''}}" wx:if="{{alumniFunctions.length > 0}}">
          <view class="text-wrapper_common">
            <text lines="1" class="text_title_common">校友会</text>
          </view>
          <view class="group_items_common">
            <view class="image-text_item_common" wx:for="{{alumniFunctions}}" wx:key="id" data-url="{{item.url}}" bindtap="onFunctionTap">
              <view class="icon-wrapper">

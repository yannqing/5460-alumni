              <view class="icon-wrapper">
                <image src="{{item.icon}}" class="label_icon_common" wx:if="{{item.iconType === 'image'}}"></image>
                <view class="label_icon_common" style="display:flex;align-items:center;justify-content:center;font-size:40rpx;" wx:else>{{item.icon}}</view>
                <!-- 待处理角标 -->
                <view wx:if="{{item.code && auditTodo.todoCount(todoCounts, item.code) > 0}}" class="badge">
                  {{auditTodo.todoBadgeText(todoCounts, item.code)}}
                </view>

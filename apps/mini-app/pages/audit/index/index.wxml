<!--pages/audit/index/index.wxml-->
<!-- WXS：用函数按 code 取 todoCounts；WXML 里 todoCounts[item.code] 对 wx:for 的 item 动态键不可靠 -->
<wxs module="auditTodo">
function todoCount(map, code) {
  if (!code || !map) return 0
  var v = map[code]
  if (v == undefined) return 0
  return +v
}
function todoBadgeText(map, code) {
  var n = todoCount(map, code)
  if (n > 99) return '99+'
  return n + ''
}
module.exports.todoCount = todoCount
module.exports.todoBadgeText = todoBadgeText
</wxs>
<custom-nav-bar showBack="{{true}}" useAuditStyle="{{true}}" auditTitle="管理入口">
<view class="page">
    <view class="section_7">
      <view class="list_1">
        <!-- 管理功能 -->
        <view class="list-items_common {{auditFunctions.length > 4 ? 'list-items_multi-row' : ''}}" wx:if="{{auditFunctions.length > 0}}">
          <view class="text-wrapper_common">
            <text lines="1" class="text_title_common">管理功能</text>
          </view>
          <view class="group_items_common">
            <view class="image-text_item_common {{item.id === 5 ? 'special-item' : ''}}" wx:for="{{auditFunctions}}" wx:key="id" data-url="{{item.url}}" bindtap="onFunctionTap">
              <view class="icon-wrapper">
                <image src="{{item.icon}}" class="label_icon_common" wx:if="{{item.iconType === 'image'}}"></image>
                <view class="label_icon_common" style="display:flex;align-items:center;justify-content:center;font-size:40rpx;" wx:else>{{item.icon}}</view>
                <!-- 待处理角标 -->
                <view wx:if="{{item.code && auditTodo.todoCount(todoCounts, item.code) > 0}}" class="badge">
                  {{auditTodo.todoBadgeText(todoCounts, item.code)}}
                </view>
              </view>
              <text lines="1" class="text-group_name_common">{{item.name}}</text>
            </view>
          </view>
        </view>

        <!-- 校促会 -->
        <view class="list-items_common {{schoolOfficeFunctions.length > 4 ? 'list-items_multi-row' : ''}}" wx:if="{{schoolOfficeFunctions.length > 0}}">

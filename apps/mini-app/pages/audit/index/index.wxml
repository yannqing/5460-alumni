          <view class="icon-wrapper">
            <image src="{{item.icon}}" class="label_3-0" wx:if="{{item.iconType === 'image'}}"></image>
            <view class="label_3-0" style="display:flex;align-items:center;justify-content:center;font-size:40rpx;" wx:else>{{item.icon}}</view>

/* pages/audit/merchant/topic/publish/publish.wxss
 * 顶栏：与 topic 一致，使用 custom-nav-bar 审核样式
 * 表单：与 alumni-association/create 一致的 label / input / form-card
 */

page {
  background-color: #f5f5f5;
  padding: 0;
  margin: 0;
  height: 100%;
  overflow: hidden;
}

.white-background-content {
  background-color: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  margin-top: -30rpx;
  position: relative;
  z-index: 1;
  padding-top: 20rpx;
  min-height: 100vh;
}

.container {
  padding: 0 30rpx 60rpx;
  box-sizing: border-box;
}

.form-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx 30rpx;
  margin-top: 0;
}

.form-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 30rpx;
  color: #333;
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
  display: block;
}

.required-mark {
  color: #ff4d4f;
  margin-right: 6rpx;
}

.input,
.textarea {
  border: 1rpx solid #eee;
  padding: 0 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.input {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
}

.input-placeholder,
.textarea-placeholder {
  color: #bfbfbf;
}

.textarea {
  width: 100%;
  min-height: 350rpx;
  padding: 16rpx 20rpx;
  line-height: 1.5;
}

.input.disabled {
  background-color: #f9f9f9;
  color: #999;
}

/* 单选（与 create 一致，本页横向排列） */
.radio-group {
  display: flex;
  flex-direction: column;
  margin-bottom: 0;
}

.publish-radio-group {
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx 48rpx;
}

.radio-label {
  display: flex;
  align-items: center;
  margin-bottom: 0;
  font-size: 28rpx;
  color: #333;
}

.radio-label radio {
  transform: scale(0.8);
  margin-right: 10rpx;
}

/* 时间选择器 */
.form-picker-view {
  width: 100%;
  height: 300rpx;
  background-color: #fff;
  border: 1rpx solid #eee;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
  box-sizing: border-box;
}

.picker-view-item {
  font-size: 28rpx;
  color: #333;
  height: 50rpx;
  line-height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.form-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  line-height: 1.5;
}

/* 上传区域 */
.upload-container {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  position: relative;
  width: 168rpx;
  height: 168rpx;
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #eee;
  background-color: #fafafa;
}

.list-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.cover-preview {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 12rpx;
}

.cover-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.cover-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  border: 1rpx solid #eee;
  background-color: #fafafa;
}

.change-cover-btn {
  background-color: #1890ff;
  color: #fff;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  border: none;
}

.change-cover-btn::after {
  border: none;
}

.delete-cover-btn {
  background-color: #ff4d4f;
  color: #fff;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  border: none;
}

.delete-cover-btn::after {
  border: none;
}

.upload-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 168rpx;
  height: 168rpx;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  background-color: #fafafa;
  box-sizing: border-box;
}

.upload-icon {
  font-size: 48rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.upload-text {
  font-size: 22rpx;
  color: #666;
}

.image-count {
  font-size: 24rpx;
  color: #999;
  align-self: flex-start;
}

.image-delete-btn {
  position: absolute;
  top: 0;
  right: 0;
  width: 50rpx;
  height: 50rpx;
  background-color: rgba(255, 69, 69, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  line-height: 1;
}

.image-loading {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
}

.image-loading .loading-text {
  color: #fff;
  font-size: 24rpx;
}

/* 位置 */
.location-selector {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.location-input {
  flex: 1;
  min-width: 0;
}

.select-location-btn {
  flex-shrink: 0;
  background-color: #1890ff;
  color: #fff;
  font-size: 26rpx;
  border: none;
  border-radius: 8rpx;
  padding: 0 24rpx;
  height: 80rpx;
  line-height: 80rpx;
}

.select-location-btn::after {
  border: none;
}

/* 提交（与 create 一致） */
.form-actions {
  margin-top: 40rpx;
  padding: 0 0 20rpx;
  display: flex;
  justify-content: center;
}

.submit-btn {
  background-color: #1890ff;
  color: white;
  border-radius: 42.57rpx;
  font-weight: 500;
  width: 713.77rpx;
  max-width: 100%;
  height: 85.14rpx;
  line-height: 85.14rpx;
  padding: 0;
  font-size: 32rpx;
}

.submit-btn::after {
  border: none;
}

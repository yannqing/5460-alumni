              placeholder-class="input-placeholder"
              value="{{publishForm.locationName}}"
              disabled
            />
            <button class="select-location-btn" bindtap="onChooseLocation">选择位置</button>
          </view>
        </view>
        -->

        <!-- 省份 -->
        <view class="form-item">
          <text class="label">省份</text>
          <input
            class="input"
            placeholder="请输入省份"
            placeholder-class="input-placeholder"
            value="{{publishForm.province}}"
            bindinput="onFormInput"
            data-field="province"
            adjust-position="{{false}}"
          />
        </view>

        <!-- 城市 -->
        <view class="form-item">
          <text class="label">城市</text>
          <input
            class="input"
            placeholder="请输入城市"
            placeholder-class="input-placeholder"
            value="{{publishForm.city}}"
            bindinput="onFormInput"
            data-field="city"
            adjust-position="{{false}}"
          />
        </view>

        <!-- 区县 -->
        <view class="form-item">
          <text class="label">区县</text>
          <input
            class="input"
            placeholder="请输入区县"
            placeholder-class="input-placeholder"
            value="{{publishForm.district}}"
            bindinput="onFormInput"
            data-field="district"
            adjust-position="{{false}}"
          />
        </view>

        <!-- 详细地址 -->
        <view class="form-item">
          <text class="label">详细地址</text>
          <input
            class="input"
            placeholder="请输入详细地址"
            placeholder-class="input-placeholder"
            value="{{publishForm.address}}"
            bindinput="onFormInput"
            data-field="address"
            adjust-position="{{false}}"
          />
        </view>


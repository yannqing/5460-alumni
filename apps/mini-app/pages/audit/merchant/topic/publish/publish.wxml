        <!-- 联系人 -->
        <view class="form-item">
          <text class="label">联系人</text>
          <input
            class="input"
            placeholder="请输入联系人姓名"
            placeholder-class="input-placeholder"
            value="{{publishForm.contactPerson}}"
            bindinput="onFormInput"
            data-field="contactPerson"
            maxlength="50"
            adjust-position="{{false}}"
          />
        </view>

        <!-- 联系电话 -->
        <view class="form-item">
          <text class="label">联系电话</text>
          <input
            class="input"
            placeholder="请输入联系电话"
            placeholder-class="input-placeholder"
            value="{{publishForm.contactPhone}}"
            bindinput="onFormInput"
            data-field="contactPhone"
            type="number"
            maxlength="20"
            adjust-position="{{false}}"
          />
        </view>

        <!-- 联系邮箱 -->
        <view class="form-item">
          <text class="label">联系邮箱</text>
          <input
            class="input"
            placeholder="请输入联系邮箱"
            placeholder-class="input-placeholder"
            value="{{publishForm.contactEmail}}"
            bindinput="onFormInput"
            data-field="contactEmail"
            type="email"
            maxlength="100"
            adjust-position="{{false}}"
          />
        </view>

        <view class="form-actions">
          <button class="submit-btn" bindtap="onSubmitPublish" loading="{{loading}}">发布话题</button>
        </view>
      </view>
    </view>
  </view>
</custom-nav-bar>

<custom-nav-bar showBack="{{true}}" useAuditStyle="{{true}}" auditTitle="话题管理">
<view class="page">
  <!-- 选择店铺卡片 -->
  <view class="group_5" wx:if="{{shops.length > 1}}">
    <text class="text_14">话题管理</text>
    <text class="label_text">选择店铺</text>
    <view class="text-wrapper_8" bindtap="showShopPicker">
      <text class="text_15">{{selectedShopIndex >= 0 ? shops[selectedShopIndex].shopName : '请选择店铺'}}</text>
    </view>
  </view>

  <!-- 活动列表卡片 -->
  <view class="group_7" wx:if="{{shops.length > 0}}">
    <view class="topic-list-header">
      <text class="text_20">活动列表</text>
      <view class="topic-publish-wrap">
        <button class="topic-publish-btn" hover-class="topic-publish-btn--hover" bindtap="onNavigateToPublish">发布话题</button>
      </view>
    </view>
    <view class="filter-container">
        <view class="filter-item">
          <text class="filter-label">活动标题：</text>
          <input 
            class="filter-input" 
            placeholder="请输入活动标题" 
            value="{{activityTitle}}" 
            bindinput="onActivityTitleInput"
          />
        </view>
        
        <view class="filter-btn-row">
          <button class="filter-btn search-btn" bindtap="onSearchActivity">搜索</button>
          <button class="filter-btn reset-btn" bindtap="onResetSearch">重置</button>
        </view>
    </view>
    <scroll-view class="scroll-list" scroll-y enable-back-to-top show-scrollbar="{{false}}" lower-threshold="80" bindscrolltolower="onActivityScrollToLower">
      <view class="loading-container" wx:if="{{activityLoading}}">
        <text class="loading-text">加载中...</text>
      </view>
      <view class="empty-container" wx:elif="{{activityList.length === 0 && !activityLoading}}">
        <text class="empty-text">暂无活动数据</text>
      </view>
      <view class="activity-list-wrap" wx:else>
      <view class="activity-list">
          <view class="activity-item" wx:for="{{activityList}}" wx:key="activityId">
            <view class="activity-header">
              <text class="activity-title">{{item.activityTitle}}</text>
              <view class="activity-status-wrap">
                <view class="status-tag" wx:if="{{item.reviewStatus === 0}}">待审核</view>
                <view class="status-tag pass" wx:elif="{{item.reviewStatus === 1}}">审核通过</view>
                <view class="status-tag fail" wx:else>审核失败</view>

                <view class="status-tag" wx:if="{{item.status === 0}}">草稿</view>
                <view class="status-tag" wx:elif="{{item.status === 1}}">报名中</view>
                <view class="status-tag" wx:elif="{{item.status === 2}}">报名结束</view>
                <view class="status-tag" wx:elif="{{item.status === 3}}">进行中</view>
                <view class="status-tag" wx:elif="{{item.status === 4}}">已结束</view>
                <view class="status-tag" wx:else>已取消</view>
              </view>
            </view>
            
            <view class="activity-info">
              <view class="info-item">
                <text class="info-label">主办方：</text>
                <text class="info-value">{{item.organizerName}}</text>
              </view>
              <view class="info-item">
                <text class="info-label">活动分类：</text>
                <text class="info-value">{{item.activityCategory}}</text>
              </view>
              <view class="info-item">
                <text class="info-label">开始时间：</text>
                <text class="info-value">{{item.startTime}}</text>
              </view>
              <view class="info-item">
                <text class="info-label">结束时间：</text>
                <text class="info-value">{{item.endTime}}</text>
              </view>
              <view class="info-item">
                <text class="info-label">活动地点：</text>
                <text class="info-value">{{item.address}}</text>
              </view>
              <view class="info-item">
                <text class="info-label">浏览次数：</text>
                <text class="info-value">{{item.viewCount}}</text>
              </view>
            </view>
            
            <view class="activity-footer">
              <!-- 编辑按钮 -->
              <button class="edit-btn" bindtap="onEditActivity" data-activity-id="{{item.activityId}}">编辑</button>
              <!-- 删除按钮 -->
              <button class="delete-btn" bindtap="onDeleteActivity" data-activity-id="{{item.activityId}}">删除</button>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>

<!-- 选择店铺弹窗（与 pages/audit/merchant/shop/shop 商户列表样式一致） -->
<view class="merchant-picker" wx:if="{{showShopPicker}}">
  <view class="picker-overlay" bindtap="cancelShopSelect"></view>
  <view class="shop-picker-sheet">
    <view class="picker-header">
      <text class="picker-title">选择店铺</text>
      <text class="picker-cancel" bindtap="cancelShopSelect">取消</text>
    </view>
    <view class="picker-list">
      <view class="shop-picker-row" wx:for="{{shops}}" wx:key="shopId" data-index="{{index}}" bindtap="selectShop">
        <text class="shop-picker-name">{{item.shopName}}</text>
        <text class="shop-picker-check" wx:if="{{selectedShopIndex === index}}">✓</text>
      </view>
      <view class="picker-empty" wx:if="{{shops.length === 0}}">
        <text>暂无店铺数据</text>
      </view>
    </view>
  </view>
</view>
</custom-nav-bar>
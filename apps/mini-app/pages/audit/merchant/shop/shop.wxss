/* pages/audit/merchant/shop/shop.wxss */
/* 与校友会审核页一致：.page + group_5 + group_7 */
.page {
  background-color: transparent;
  width: 100%;
  min-height: calc(100vh - 190.22rpx);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.page .group_5 {
  width: 714rpx;
  min-height: auto;
  margin: 47rpx 0 0 18rpx;
  padding: 38rpx 43rpx 27rpx 43rpx;
  flex-shrink: 0;
}

.group_5 {
  background-color: #FFFFFF;
  border-radius: 28.99rpx;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  flex-shrink: 0;
}

.group_5 .text_14 {
  font-size: 29rpx;
  font-weight: 600;
  color: rgba(0,0,0,1);
  line-height: 40rpx;
}

.group_5 .label_text {
  font-size: 25rpx;
  color: rgba(0,0,0,0.6);
  line-height: 36rpx;
  margin-top: 16rpx;
  display: block;
}

.group_5 .text-wrapper_8 {
  height: 80rpx;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  border: 1rpx solid #E0E0E0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  margin-top: 16rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.group_5 .text_15 {
  flex: 1;
  font-size: 28rpx;
  color: rgba(0,0,0,0.85);
  line-height: 36rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

.group_5 .text-wrapper_8::after {
  content: '▼';
  color: #999;
  font-size: 20rpx;
  margin-left: 10rpx;
}

.group_7 {
  width: 714rpx;
  flex: 1;
  min-height: 0;
  background-color: #FFFFFF;
  border-radius: 28.99rpx;
  margin: 34rpx 0 0 18rpx;
  padding: 38rpx 43rpx 27rpx 43rpx;
  box-sizing: border-box;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.shop-list-header {
  margin-bottom: 16rpx;
  flex-shrink: 0;
}

.group_7 .text_20 {
  font-size: 29rpx;
  font-weight: 600;
  color: rgba(0,0,0,1);
  line-height: 40rpx;
}

.scroll-list { 
  width: 100%; 
  flex: 1;
  min-height: 0;
}

.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-block {
  padding: 16rpx 0 60rpx;
  text-align: center;
}

.empty-text { font-size: 28rpx; color: #999; }

.shop-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 16rpx;
}

.shop-item {
  background-color: #f9f9f9;
  padding: 0;
  border-radius: 12rpx;
  border: 1rpx solid #f0f0f0;
  overflow: hidden;
}

.shop-item-body {
  padding: 20rpx 24rpx 12rpx;
}

.shop-item-body:active {
  opacity: 0.92;
}

.shop-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.shop-name {
  font-size: 29rpx;
  font-weight: 600;
  color: #333;
}

.shop-type {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 14rpx;
}

.shop-item .shop-type:nth-of-type(1) {
  color: #52c41a;
  background-color: rgba(82,196,26,0.12);
}

.shop-item .shop-type:nth-of-type(2) {
  color: #1890ff;
  background-color: rgba(24,144,255,0.12);
}

.shop-address {
  font-size: 25rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.shop-phone {
  font-size: 25rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.shop-actions {
  display: flex;
  gap: 16rpx;
  padding: 12rpx 24rpx 20rpx;
  border-top: 1rpx solid #f0f0f0;
  background-color: #f9f9f9;
}

.edit-btn, .delete-btn {
  flex: 1;
  height: 58rpx;
  line-height: 58rpx;
  font-size: 25rpx;
  border-radius: 8rpx;
  border: none;
  text-align: center;
}

.edit-btn {
  background-color: rgba(24,144,255,0.12);
  color: #1890ff;
  border: 1rpx solid #1890ff;
}

.delete-btn {
  background-color: rgba(255,77,79,0.12);
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
}

.edit-btn::after, .delete-btn::after { border: none; }

.add-shop-btn {
  position: fixed;
  bottom: 60rpx;
  right: 60rpx;
  width: 120rpx;
  height: 120rpx;
  background-color: #1890ff;
  color: #fff;
  font-size: 80rpx;
  text-align: center;
  line-height: 110rpx;
  border-radius: 50%;
  box-shadow: 0 4rpx 12rpx rgba(24,144,255,0.3);
  z-index: 1000;
}

.add-shop-btn:active {
  transform: scale(0.95);
}

/* 商户选择器弹窗（与校友会审核页一致，底部弹出） */
.merchant-picker {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 10000;
}

.merchant-picker .picker-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0,0,0,0.5);
}

.merchant-picker .picker-content {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  background-color: #fff;
  border-radius: 20rpx 20rpx 0 0;
  max-height: 70vh;
  overflow: hidden;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #E5E5E5;
  background-color: #FAFAFA;
}

.picker-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.picker-cancel {
  font-size: 28rpx;
  color: #666;
  cursor: pointer;
}

.picker-cancel:active {
  color: #333;
}

.picker-list {
  max-height: calc(80vh - 88rpx + 40px);
  overflow-y: auto;
  padding: 16rpx 0;
}

.picker-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: #333;
  cursor: pointer;
  border-bottom: 1rpx solid #F0F0F0;
}

.picker-item:active {
  background-color: #F5F5F5;
}

.item-name {
  flex: 1;
}

.item-check {
  color: #1AAD19;
  font-weight: bold;
}

.picker-empty {
  padding: 40rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
}

/* 去除按钮默认样式 */
.edit-btn::after,
.delete-btn::after {
  border: none;
}
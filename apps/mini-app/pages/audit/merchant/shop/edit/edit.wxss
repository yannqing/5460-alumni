.page {
  min-height: calc(100vh - 190.22rpx);
  padding: 28rpx 18rpx 40rpx;
  box-sizing: border-box;
}

.loading-wrap {
  padding: 120rpx 40rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
}

.form-card {
  width: 100%;
  background-color: #ffffff;
  border-radius: 28rpx;
  padding: 32rpx;
  box-sizing: border-box;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.required {
  color: #ff4d4f;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background-color: #fafafa;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background-color: #fafafa;
}

.radio-group {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx 40rpx;
  margin-top: 8rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #333;
}

.radio-item radio {
  margin-right: 12rpx;
}

.merchant-readonly {
  width: 100%;
  min-height: 80rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  background-color: #f5f5f5;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

.location-selector {
  margin-top: 12rpx;
}

.select-location-btn {
  margin: 0;
  padding: 0 40rpx;
  min-width: 200rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  color: #fff;
  background-color: #1aad19;
  border: 1rpx solid #1aad19;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.select-location-btn::after {
  border: none;
}

.image-upload-container {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.uploaded-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.uploaded-image {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  border-radius: 8rpx;
  overflow: hidden;
  border: 1rpx solid #e5e5e5;
}

.image-preview {
  width: 100%;
  height: 100%;
}

.image-delete {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 36rpx;
  height: 36rpx;
  background-color: rgba(0, 0, 0, 0.6);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.upload-btn {
  margin: 0;
  padding: 0 40rpx;
  min-width: 200rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  font-weight: 400;
  color: #fff;
  background-color: #1677ff;
  border: 1rpx solid #1677ff;
  border-radius: 8rpx;
  box-sizing: border-box;
  text-align: center;
}

.upload-btn::after {
  border: none;
}

.upload-btn-hover {
  opacity: 0.9;
  background-color: #0958d9 !important;
  border-color: #0958d9 !important;
}

.form-actions {
  margin-top: 40rpx;
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
  background-color: #1aad19;
  color: #fff;
}

.btn-submit::after {
  border: none;
}

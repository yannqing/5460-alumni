<custom-nav-bar showBack="{{true}}" useAuditStyle="{{true}}" auditTitle="编辑店铺">
  <view class="loading-wrap" wx:if="{{detailLoading}}">
    <text>加载中...</text>
  </view>
  <view class="page" wx:else>
    <view class="form-card">
      <form bindsubmit="submitShopForm">
        <view class="form-item">
          <text class="form-label">所属商户</text>
          <view class="merchant-readonly">{{merchantDisplayName}}</view>
        </view>

        <view class="form-item">
          <text class="form-label">店铺名称 <text class="required">*</text></text>
          <input class="form-input" placeholder="请输入店铺名称" value="{{formData.shopName}}" bindinput="onInputChange" data-field="shopName" />
        </view>

        <view class="form-item">
          <text class="form-label">店铺类型 <text class="required">*</text></text>
          <view class="radio-group">
            <label class="radio-item">
              <radio value="1" checked="{{formData.shopType === 1}}" bindtap="onRadioChange" data-field="shopType" data-value="1" />总店
            </label>
            <label class="radio-item">
              <radio value="2" checked="{{formData.shopType === 2}}" bindtap="onRadioChange" data-field="shopType" data-value="2" />分店
            </label>
          </view>
        </view>

        <view class="form-item">
          <text class="form-label">省份 <text class="required">*</text></text>
          <input class="form-input" placeholder="请输入省份" value="{{formData.province}}" bindinput="onInputChange" data-field="province" />
        </view>

        <view class="form-item">
          <text class="form-label">城市 <text class="required">*</text></text>
          <input class="form-input" placeholder="请输入城市" value="{{formData.city}}" bindinput="onInputChange" data-field="city" />
        </view>

        <view class="form-item">
          <text class="form-label">区县 <text class="required">*</text></text>
          <input class="form-input" placeholder="请输入区县" value="{{formData.district}}" bindinput="onInputChange" data-field="district" />
        </view>

        <view class="form-item">
          <text class="form-label">详细地址 <text class="required">*</text></text>
          <input class="form-input" placeholder="请输入详细地址" value="{{formData.address}}" bindinput="onInputChange" data-field="address" />
        </view>

        <view class="form-item">
          <text class="form-label">店铺位置 <text class="required">*</text></text>
          <view class="location-picker-container" bindtap="selectLocation">
            <view class="location-info">
              <text class="location-text" wx:if="{{formData.locationName}}">{{formData.locationName}}</text>
              <text class="location-placeholder" wx:else>请在地图上选择位置</text>
            </view>
            <view class="location-btn-mini">选择位置</view>
          </view>
        </view>

        <view class="form-item">
          <text class="form-label">店铺电话</text>
          <input class="form-input" type="number" maxlength="11" placeholder="请输入11位店铺电话" value="{{formData.phone}}" bindinput="onInputChange" data-field="phone" />
        </view>

        <view class="form-item">
          <text class="form-label">营业时间</text>
          <input class="form-input" placeholder="请输入营业时间" value="{{formData.businessHours}}" bindinput="onInputChange" data-field="businessHours" />
        </view>

        <view class="form-item">
          <text class="form-label">店铺 Logo</text>
          <view class="image-upload-container">
            <view class="uploaded-images">
              <view class="uploaded-image" wx:if="{{formData.logo}}">
                <image src="{{formData.logo}}" mode="aspectFill" class="image-preview" />
                <view class="image-delete" bindtap="clearLogo">×</view>
              </view>
            </view>
            <button class="upload-btn" bindtap="chooseLogo" hover-class="upload-btn-hover">上传 logo</button>
          </view>
        </view>

        <view class="form-item">
          <text class="form-label">上传店铺背景图</text>
          <view class="image-upload-container">
            <view class="uploaded-images">
              <view class="uploaded-image" wx:for="{{uploadedImages}}" wx:key="index">
                <image src="{{item}}" mode="aspectFill" class="image-preview" />
                <view class="image-delete" bindtap="deleteImage" data-index="{{index}}">×</view>
              </view>
            </view>
            <button class="upload-btn" bindtap="chooseImage" hover-class="upload-btn-hover">上传图片</button>
          </view>
        </view>

        <view class="form-item">
          <text class="form-label">店铺简介</text>
          <textarea class="form-textarea" placeholder="请输入店铺简介" value="{{formData.description}}" bindinput="onInputChange" data-field="description" />
        </view>

        <view class="form-item">
          <text class="form-label">店铺状态</text>
          <view class="radio-group">
            <label class="radio-item">
              <radio value="0" checked="{{formData.status === 0}}" bindtap="onRadioChange" data-field="status" data-value="0" />停业
            </label>
            <label class="radio-item">
              <radio value="1" checked="{{formData.status === 1}}" bindtap="onRadioChange" data-field="status" data-value="1" />营业中
            </label>
            <label class="radio-item">
              <radio value="2" checked="{{formData.status === 2}}" bindtap="onRadioChange" data-field="status" data-value="2" />装修中
            </label>
          </view>
        </view>

        <view class="form-actions">
          <button class="btn-submit" form-type="submit" loading="{{submitting}}">提交</button>
        </view>
      </form>
    </view>
  </view>
</custom-nav-bar>

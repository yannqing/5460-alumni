/* pages/audit/merchant/coupon/verify/verify.wxss */
.verify-coupon-page {
  min-height: 100vh;
  background-color: transparent;
  padding: 0;
  width: 750rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 门店选择器（与校友会审核页 group_5 一致） */
.shop-selector-container {
  width: 714rpx;
  margin: 47rpx 0 0 18rpx;
  padding: 38rpx 43rpx 27rpx 43rpx;
  background-color: #FFFFFF;
  border-radius: 28.99rpx;
  box-sizing: border-box;
  flex-shrink: 0;
}

.shop-selector-header {
  display: flex;
  align-items: center;
  height: 80rpx;
  border-radius: 12rpx;
  border: 1rpx solid #E0E0E0;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.shop-selector-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.shop-selector-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  min-width: 0;
}

.shop-selector-value .placeholder-text {
  color: #999;
}

.shop-selector-arrow {
  font-size: 20rpx;
  color: #999;
  margin-left: 10rpx;
  flex-shrink: 0;
}

.shop-picker {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.picker-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.picker-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  border-radius: 20rpx 20rpx 0 0;
  max-height: 70vh;
  overflow: hidden;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.picker-cancel {
  font-size: 28rpx;
  color: #999;
}

.picker-list {
  max-height: calc(50vh + 40px);
  overflow-y: auto;
  padding: 0 30rpx;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-item-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.item-name {
  font-size: 28rpx;
  color: #333;
}

.item-address {
  font-size: 24rpx;
  color: #999;
}

.item-check {
  font-size: 32rpx;
  color: #52c41a;
  font-weight: 600;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.picker-empty {
  padding: 60rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: #999;
}

.search-container {
  width: 714rpx;
  margin: 34rpx 0 20rpx 18rpx;
  padding: 38rpx 43rpx 27rpx 43rpx;
  background-color: #FFFFFF;
  border-radius: 28.99rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 20rpx;
  height: 88rpx;
}

.search-input {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  color: #333;
}

.scan-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
  flex-shrink: 0;
  width: 60rpx;
  height: 60rpx;
  min-width: 60rpx;
  min-height: 60rpx;
}

.scan-btn-icon {
  width: 32rpx !important;
  height: 32rpx !important;
  flex-shrink: 0;
  display: block;
}

/* 加载中 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 优惠券信息 */
.coupon-info-container {
  margin-top: 20rpx;
}

.coupon-card {
  display: flex;
  background: linear-gradient(135deg, #ff6b9d 0%, #ff8fb3 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 157, 0.3);
}

.coupon-card-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 180rpx;
  padding-right: 30rpx;
}

.coupon-discount {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.2;
  margin-bottom: 10rpx;
}

.coupon-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  background-color: rgba(255, 255, 255, 0.2);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.coupon-card-divider {
  width: 2rpx;
  background-color: rgba(255, 255, 255, 0.3);
  margin: 0 20rpx;
}

.coupon-card-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.coupon-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.coupon-merchant {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 12rpx;
}

.coupon-code {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.coupon-validity {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 核销码显示 */
.code-display-container {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.code-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.code-value {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  word-break: break-all;
}

/* 订单金额输入 */
.order-amount-container {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.amount-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.amount-input {
  width: 100%;
  height: 88rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 32rpx;
  color: #333;
  box-sizing: border-box;
}

/* 核销按钮 */
.verify-btn-container {
  padding: 0 20rpx;
}

.verify-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(90deg, #40B2E6 0%, #6BC5ED 100%);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(64, 178, 230, 0.3);
}

.verify-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.verify-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

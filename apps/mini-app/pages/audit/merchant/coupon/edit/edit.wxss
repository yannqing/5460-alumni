/* 参考 create 页样式 */
.page-scroll {
  width: 750rpx;
  min-height: calc(100vh - 190.22rpx);
  box-sizing: border-box;
  padding-bottom: 48rpx;
}

.loading-tip {
  padding: 32rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
}

.group_7 {
  width: 714rpx;
  background-color: #FFFFFF;
  border-radius: 28.99rpx;
  margin: 34rpx 0 0 18rpx;
  padding: 38rpx 43rpx 27rpx 43rpx;
  box-sizing: border-box;
}

.group_7 .text_20 {
  font-size: 29rpx;
  font-weight: 600;
  color: rgba(0,0,0,1);
  line-height: 40rpx;
  margin-bottom: 12rpx;
  display: block;
}

.rule-lead {
  display: block;
  font-size: 24rpx;
  color: #999;
  line-height: 36rpx;
  margin: -4rpx 0 20rpx;
}

.field-hint {
  display: block;
  font-size: 22rpx;
  color: #888;
  line-height: 34rpx;
  margin-bottom: 10rpx;
}

.radio-group {
  display: flex;
  flex-wrap: wrap;
  gap: 40rpx;
  margin-top: 8rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #333;
}

.radio-item radio {
  margin-right: 12rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label_text {
  font-size: 25rpx;
  color: rgba(0,0,0,0.6);
  line-height: 36rpx;
  margin-bottom: 12rpx;
  display: block;
}

.required {
  color: #ff4d4f;
}

.hint {
  font-size: 22rpx;
  color: #999;
  font-weight: normal;
}

.merchant-fixed {
  padding: 20rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  border: 1rpx solid #e8e8e8;
}

.merchant-fixed-text {
  display: block;
  font-size: 28rpx;
  color: #333;
  line-height: 40rpx;
}

.picker-row {
  margin-top: 0;
}

.text-wrapper_8.picker-row {
  height: 80rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
  border: 1rpx solid #E0E0E0;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.text-wrapper_8.picker-row::after {
  content: '▼';
  color: #999;
  font-size: 20rpx;
  margin-left: 10rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background-color: #fafafa;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background-color: #fafafa;
}

.datetime-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.date-picker-cell {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #fafafa;
  border: 1rpx solid #e5e5e5;
  border-radius: 12rpx;
  text-align: center;
}

.row-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.row-between .label_text {
  margin-bottom: 0;
}

.image-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex-wrap: wrap;
}

.img-preview {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #e5e5e5;
}

.img-cover {
  width: 100%;
  height: 100%;
}

.img-del {
  position: absolute;
  top: 0;
  right: 0;
  width: 44rpx;
  height: 44rpx;
  line-height: 40rpx;
  text-align: center;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 32rpx;
  border-bottom-left-radius: 8rpx;
}

.upload-btn {
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  color: #1890ff;
  border: 1rpx solid #1890ff;
  border-radius: 8rpx;
  background-color: rgba(24,144,255,0.08);
}

.submit-bar {
  width: 714rpx;
  margin: 40rpx 0 0 18rpx;
  padding: 0 0 32rpx;
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  color: #fff;
  background-color: #1890ff;
  border-radius: 12rpx;
  border: none;
}

.submit-btn::after {
  border: none;
}

.submit-btn-hover {
  opacity: 0.92;
}

<!-- pages/audit/merchant/shop-audit/shop-audit.wxml -->
<custom-nav-bar showBack="{{true}}" useAuditStyle="{{true}}" auditTitle="店铺审核">
<view class="page">
  <!-- 选择校友会卡片 -->
  <view class="group_5" wx:if="{{!hasSingleAlumniAssociation && hasAlumniAdminPermission}}">
    <text class="text_14">店铺审核</text>
    <text class="label_text">选择校友会</text>
    <view class="text-wrapper_8" bindtap="showAlumniAssociationSelector">
      <text class="text_15">{{selectedAlumniAssociationName || '请选择校友会'}}</text>
    </view>
  </view>

  <!-- 审核列表卡片 -->
  <view class="group_7">
    <view class="list-header">
      <text class="text_20">审核列表</text>
    </view>
    <scroll-view class="scroll-list" scroll-y enable-back-to-top enhanced show-scrollbar="{{false}}" style="height: {{scrollListHeight}}px;">
      <view class="loading-state" wx:if="{{shopLoading}}">
        <text>加载中...</text>
      </view>
      <view class="empty-block" wx:elif="{{approvalList.length === 0}}">
        <text class="empty-text">{{hasAlumniAdminPermission ? (selectedAlumniAssociationId ? '暂无待审核店铺' : '请先选择校友会') : '暂无待审核店铺'}}</text>
      </view>
      <view class="approval-list" wx:else>
    <view
      class="shop-item"
      hover-class="shop-item--tap"
      wx:for="{{approvalList}}"
      wx:key="shopId"
      bindtap="goApprovalDetail"
      data-shop-id="{{item.shopId}}"
    >
      <view class="shop-header">
        <view class="shop-name">{{item.shopName}}</view>
        <view class="shop-header-right">
          <view class="status-badge status-badge--{{item.reviewStatusKind}}">{{item.reviewStatusLabel}}</view>
        </view>
      </view>
      
      <view class="shop-info">
        <view class="info-item">
          <text class="info-label">所属商家：</text>
          <text class="info-value">{{item.merchantName}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">店铺地址：</text>
          <text class="info-value">{{item.province}}{{item.city}}{{item.district}}{{item.address}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">联系电话：</text>
          <text class="info-value">{{item.phone}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">营业时间：</text>
          <text class="info-value">{{item.businessHours || '未设置'}}</text>
        </view>
        <view class="info-item">
          <!-- 单行 text 嵌套 + nowrap，避免多个 text 在 flex 下仍换行或产生空白节点 -->
          <text class="status-line">
            <text class="info-label">审核状态：</text><text class="info-value status-text status-text--{{item.reviewStatusKind}}">{{item.reviewStatusLabel}}</text>
          </text>
        </view>
        <view class="info-item" wx:if="{{item.reviewStatus !== 0}}">
          <text class="info-label">审核时间：</text>
          <text class="info-value">{{item.reviewTime || 'N/A'}}</text>
        </view>
        <view class="info-item" wx:if="{{item.reviewStatus === 2}}">
          <text class="info-label">审核原因：</text>
          <text class="info-value reject-reason">{{item.reviewReason || '未填写'}}</text>
        </view>
      </view>
      
      <!-- 审核操作按钮 -->
      <view class="audit-actions" wx:if="{{item.reviewStatus === 0}}">
        <button class="approve-btn" catchtap="confirmApprove" data-shop-id="{{item.shopId}}">通过</button>
        <button class="reject-btn" catchtap="openRejectModal" data-shop-id="{{item.shopId}}">拒绝</button>
      </view>
    </view>
    
    <view class="pagination" wx:if="{{total > 0}}">
      <view class="pagination-info">共 {{total}} 条记录，第 {{current}}/{{pages}} 页</view>
      <view class="pagination-controls">
        <button class="page-btn" disabled="{{!hasPrevious}}" bindtap="previousPage">上一页</button>
        <view class="page-input">
          <input class="page-number" type="number" value="{{current}}" bindconfirm="goToPage" placeholder="页码" />
        </view>
        <button class="page-btn" disabled="{{!hasNext}}" bindtap="nextPage">下一页</button>
      </view>
    </view>
      </view>
    </scroll-view>
  </view>

  <!-- 拒绝审核：填写原因，再二次确认提交 -->
  <view class="modal-overlay" wx:if="{{showRejectModal}}" catchtap="hideRejectModal"></view>
  <view class="modal-container" wx:if="{{showRejectModal}}">
    <view class="modal-header">
      <text class="modal-title">拒绝审核</text>
      <view class="modal-close" catchtap="hideRejectModal">×</view>
    </view>
    <view class="modal-content">
      <view class="audit-shop-name" wx:if="{{currentAuditShop}}">{{currentAuditShop.shopName}}</view>
      <view class="form-item">
        <text class="form-label">拒绝原因<text class="form-label-required">（必填）</text></text>
        <textarea
          class="form-textarea"
          placeholder="请填写拒绝原因"
          value="{{auditRemark}}"
          bindinput="onRemarkInput"
          maxlength="200"
        ></textarea>
      </view>
      <view class="form-actions">
        <button class="btn-cancel" catchtap="hideRejectModal">取消</button>
        <button class="btn-submit btn-submit--danger" catchtap="confirmRejectFromModal" loading="{{loading}}">确认拒绝</button>
      </view>
    </view>
  </view>
  
  <!-- 校友会选择器弹窗 -->
  <view class="alumni-association-picker" wx:if="{{showAlumniAssociationPicker}}">
    <view class="picker-overlay" bindtap="cancelAlumniAssociationSelect"></view>
    <view class="picker-content">
      <view class="picker-header">
        <text class="picker-title">选择校友会</text>
        <text class="picker-cancel" bindtap="cancelAlumniAssociationSelect">取消</text>
      </view>
      <view class="picker-list">
        <view 
          class="picker-item" 
          wx:for="{{alumniAssociationList}}" 
          wx:key="alumniAssociationId"
          data-alumni-association-id="{{item.alumniAssociationId}}"
          data-alumni-association-name="{{item.alumniAssociationName}}"
          bindtap="selectAlumniAssociation"
        >
          <text class="item-name">{{item.alumniAssociationName}}</text>
          <text class="item-check" wx:if="{{selectedAlumniAssociationId == item.alumniAssociationId}}">✓</text>
        </view>
        <view class="picker-empty" wx:if="{{alumniAssociationList.length === 0}}">
          <text>暂无校友会数据</text>
        </view>
      </view>
    </view>
  </view>
</view>
</custom-nav-bar>

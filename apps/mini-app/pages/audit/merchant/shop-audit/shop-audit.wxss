/* pages/audit/merchant/shop-audit/shop-audit.wxss */
.page {
  background-color: transparent;
  width: 750rpx;
  height: calc(100vh - 190.22rpx);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.page .group_5 {
  width: 714rpx;
  min-height: auto;
  margin: 47rpx 0 0 18rpx;
  padding: 38rpx 43rpx 27rpx 43rpx;
  flex-shrink: 0;
}

.group_5 {
  background-color: #FFFFFF;
  border-radius: 28.99rpx;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  flex-shrink: 0;
}

.group_5 .text_14 { font-size: 29rpx; font-weight: 600; color: rgba(0,0,0,1); line-height: 40rpx; }
.group_5 .label_text { font-size: 25rpx; color: rgba(0,0,0,0.6); margin-top: 16rpx; display: block; line-height: 36rpx; }
.group_5 .text-wrapper_8 {
  height: 80rpx;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  border: 1rpx solid #E0E0E0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  margin-top: 16rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}
.group_5 .text_15 { flex: 1; font-size: 28rpx; color: rgba(0,0,0,0.85); line-height: 36rpx; overflow: hidden; text-overflow: ellipsis; }
.group_5 .text-wrapper_8::after { content: '▼'; color: #999; font-size: 20rpx; margin-left: 10rpx; }

.group_7 {
  width: 714rpx;
  flex: 1;
  min-height: 0;
  background-color: #FFFFFF;
  border-radius: 28.99rpx;
  /* 底部留白略收紧，列表区尽量占满剩余屏高 */
  margin: 34rpx 0 12rpx 18rpx;
  padding: 38rpx 43rpx 20rpx 43rpx;
  box-sizing: border-box;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 1;
}

.list-header { margin-bottom: 16rpx; flex-shrink: 0; }
.group_7 .text_20 { font-size: 29rpx; font-weight: 600; color: rgba(0,0,0,1); line-height: 40rpx; }
.scroll-list { 
  width: 100%; 
  flex-shrink: 0;
  position: relative;
  z-index: 0;
  /* 与 show-scrollbar="{{false}}"、enhanced 配合，尽量隐藏滚动条 */
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.scroll-list::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}

.loading-state { display: flex; justify-content: center; align-items: center; padding: 40rpx 0; color: #999; font-size: 28rpx; }
.empty-block { padding: 16rpx 0 60rpx; text-align: center; }
.empty-text { font-size: 28rpx; color: #999; }

.approval-list { display: flex; flex-direction: column; gap: 16rpx; padding-bottom: 8rpx; }

.shop-item {
  background-color: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid #f0f0f0;
}

.shop-item--tap {
  background-color: #f0f4ff;
}

/* 店铺头部 */
.shop-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
  gap: 16rpx;
}

.shop-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  min-width: 0;
}

.shop-header-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
  flex-shrink: 0;
}

/* 列表顶部即展示审核状态，避免与「通过」混淆 */
.status-badge {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 600;
  line-height: 1.3;
}
.status-badge--pending {
  color: #e65100;
  background-color: #fff3e0;
  border: 1rpx solid #ffcc80;
}
.status-badge--approved {
  color: #2e7d32;
  background-color: #e8f5e9;
  border: 1rpx solid #a5d6a7;
}
.status-badge--rejected {
  color: #c62828;
  background-color: #ffebee;
  border: 1rpx solid #ef9a9a;
}
.status-badge--unknown {
  color: #616161;
  background-color: #f5f5f5;
  border: 1rpx solid #e0e0e0;
}

/* 店铺信息 */
.shop-info {
  margin-bottom: 20rpx;
}

.info-item {
  margin-bottom: 12rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

/* 审核状态：同一 text 流 + nowrap，避免 text 作 flex 子项时仍换行 */
.status-line {
  display: block;
  font-size: 28rpx;
  line-height: 1.5;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.info-label {
  color: #999;
  margin-right: 10rpx;
}

.info-value {
  color: #666;
}

/* 状态文本（与 badge 语义一致） */
.status-text--pending {
  color: #e65100;
  font-weight: 600;
}
.status-text--approved {
  color: #2e7d32;
  font-weight: 600;
}
.status-text--rejected {
  color: #c62828;
  font-weight: 600;
}
.status-text--unknown {
  color: #616161;
}

/* 审核操作 */
.audit-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.approve-btn {
  background-color: #4caf50;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 12rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.2;
}

.reject-btn {
  background-color: #f44336;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 12rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.2;
}

/* 模态框 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.modal-container {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background-color: #fff;
  border-radius: 12rpx;
  width: 80%;
  max-width: 600rpx;
  z-index: 1001;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  cursor: pointer;
}

.modal-content {
  padding: 20rpx;
}

/* 审核店铺名称 */
.audit-shop-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
  padding: 10rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
}

/* 表单样式 */
.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.form-label-required {
  color: #f44336;
  font-size: 24rpx;
  font-weight: normal;
}

/* 单选组 */
.radio-group {
  display: flex;
  gap: 40rpx;
  align-items: center;
}

.radio-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: #666;
}

/* 文本域 */
.form-textarea {
  width: 100%;
  height: 160rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  resize: none;
}

/* 商户选择器 */
.merchant-selector {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  background-color: #fafafa;
}

.selector-label {
  font-size: 28rpx;
  color: #333;
}

.selector-arrow {
  font-size: 24rpx;
  color: #999;
}

/* 校友会选择器弹窗（对齐 join-audit/index） */
.merchant-picker,
.alumni-association-picker {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.picker-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.picker-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  border-radius: 20rpx 20rpx 0 0;
  max-height: 70vh;
  overflow: hidden;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.picker-cancel {
  font-size: 28rpx;
  color: #999;
}

.picker-list {
  max-height: calc(50vh + 40px);
  overflow-y: auto;
  padding: 0 30rpx;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.item-name {
  font-size: 28rpx;
  color: #333;
}

.item-check {
  font-size: 32rpx;
  color: #52c41a;
  font-weight: 600;
}

.picker-empty {
  padding: 60rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

/* 分页样式 */
.pagination {
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #e0e0e0;
}

.pagination-info {
  text-align: center;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.pagination-controls {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20rpx;
}

.page-btn {
  padding: 10rpx 20rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #fff;
}

.page-btn[disabled] {
  color: #999;
  background-color: #f5f5f5;
}

.page-input {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.page-number {
  width: 100rpx;
  height: 60rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 10rpx;
  font-size: 28rpx;
  text-align: center;
}

/* 拒绝原因样式 */
.reject-reason {
  color: #f44336;
  font-weight: bold;
}

/* 表单操作按钮 */
.form-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 30rpx;
}

.btn-cancel {
  background-color: #f0f0f0;
  color: #666;
  border: none;
  border-radius: 8rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  line-height: 1.2;
}

.btn-submit {
  background-color: #1989fa;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  line-height: 1.2;
}

.btn-submit--danger {
  background-color: #f44336;
}

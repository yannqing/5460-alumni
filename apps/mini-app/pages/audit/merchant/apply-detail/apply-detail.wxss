/* pages/audit/merchant/apply-detail/apply-detail.wxss */
.apply-detail-page {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.loading-text {
  text-align: center;
  padding: 50rpx;
  color: #999;
  font-size: 28rpx;
}

.detail-content {
  padding-bottom: 20rpx;
}

.detail-section {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 25rpx;
  padding-bottom: 15rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.section-title--assoc {
  font-size: 30rpx;
  margin-top: 24rpx;
  margin-bottom: 20rpx;
  padding-top: 8rpx;
  border-bottom: 1rpx solid #eee;
}

.association-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 20rpx;
}

.association-logo {
  flex-shrink: 0;
  width: 88rpx;
  height: 88rpx;
  margin-right: 20rpx;
  border-radius: 12rpx;
  background: #fafafa;
  border: 1rpx solid #eee;
}

.association-name-body {
  flex: 1;
  min-width: 0;
}

.association-name {
  color: #333;
  font-size: 30rpx;
  line-height: 1.5;
  word-break: break-all;
}

.detail-item {
  display: flex;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  align-items: flex-start;
}

.detail-label {
  color: #999;
  width: 180rpx;
  padding-top: 8rpx;
}

.detail-value {
  color: #333;
  flex: 1;
  min-width: 0;
  line-height: 1.6;
  padding-top: 8rpx;
}

.license-photo-block {
  margin-bottom: 24rpx;
}

.license-photo-label {
  display: block;
  margin-bottom: 16rpx;
  color: #999;
  font-size: 28rpx;
}

.license-photo {
  width: 100%;
  max-height: 480rpx;
  background: #fafafa;
  border-radius: 8rpx;
  border: 1rpx solid #eee;
}

.status-pending {
  color: #fa8c16;
}

.status-approved {
  color: #52c41a;
}

.status-rejected {
  color: #ff4d4f;
}

.audit-actions {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.action-buttons {
  display: flex;
  justify-content: space-between;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin: 0 10rpx;
}

.action-btn.reject {
  background-color: #fff2f0;
  color: #ff4d4f;
  border: 2rpx solid #ffccc7;
}

.action-btn.approve {
  background-color: #e6f7ff;
  color: #1890ff;
  border: 2rpx solid #91d5ff;
}

/* pages/audit/merchant/apply-detail/apply-detail.wxss */
.apply-detail-page {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.loading-text {
  text-align: center;
  padding: 50rpx;
  color: #999;
  font-size: 28rpx;
}

.detail-content {
  padding-bottom: 20rpx;
}

.detail-header {
  position: relative;
  width: 100%;
  height: 380rpx;
  margin-bottom: 30rpx;
  overflow: visible;
}

.detail-header::after {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.4) 100%);
  border-radius: 40rpx;
  z-index: 1;
}

.header-bg {
  width: 100%;
  height: 100%;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.header-content {
  position: absolute;
  bottom: -40rpx;
  left: 40rpx;
  right: 40rpx;
  display: flex;
  align-items: flex-end;
  z-index: 2;
}

.header-left {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-container {
  width: 140rpx;
  height: 140rpx;
  background: #fff;
  border-radius: 50%;
  padding: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.merchant-logo {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.merchant-basic {
  margin-left: 24rpx;
  padding-bottom: 50rpx;
  flex: 1;
}

.merchant-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
  display: block;
  margin-bottom: 12rpx;
}

.detail-section {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 25rpx;
  padding-bottom: 15rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.section-title--assoc {
  font-size: 30rpx;
  margin-top: 24rpx;
  margin-bottom: 20rpx;
  padding-top: 8rpx;
  border-bottom: 1rpx solid #eee;
}

.association-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 20rpx;
}

.association-logo {
  flex-shrink: 0;
  width: 88rpx;
  height: 88rpx;
  margin-right: 20rpx;
  border-radius: 50%;
  background: #fafafa;
  border: 1rpx solid #eee;
}

.association-name-body {
  flex: 1;
  min-width: 0;
}

.association-name {
  color: #333;
  font-size: 30rpx;
  line-height: 1.5;
  word-break: break-all;
  display: block;
}

.association-status-tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
  margin-top: 8rpx;
}

.tag-pending {
  background-color: #fff7e6;
  color: #fa8c16;
  border: 1rpx solid #ffd591;
}

.tag-approved {
  background-color: #f6ffed;
  color: #52c41a;
  border: 1rpx solid #b7eb8f;
}

.tag-rejected {
  background-color: #fff1f0;
  color: #ff4d4f;
  border: 1rpx solid #ffa39e;
}

.detail-item {
  display: flex;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  align-items: flex-start;
}

.detail-label {
  color: #999;
  width: 240rpx;
  padding-top: 8rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.detail-label-single-line {
  width: auto;
  min-width: 180rpx;
  flex-shrink: 0;
  padding-right: 8rpx;
  white-space: nowrap;
}

.detail-value {
  color: #333;
  flex: 1;
  min-width: 0;
  line-height: 1.6;
  padding-top: 8rpx;
}

.detail-value-single-line {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.license-photo-block {
  margin-bottom: 24rpx;
}

.license-photo-label {
  display: block;
  margin-bottom: 16rpx;
  color: #999;
  font-size: 28rpx;
  white-space: nowrap;
}

.license-photo {
  width: 100%;
  max-height: 480rpx;
  background: #fafafa;
  border-radius: 8rpx;
  border: 1rpx solid #eee;
}

.status-pending {
  color: #fa8c16;
}

.status-approved {
  color: #52c41a;
}

.status-rejected {
  color: #ff4d4f;
}

.audit-actions {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.action-buttons {
  display: flex;
  justify-content: space-between;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin: 0 10rpx;
}

.action-btn.reject {
  background-color: #fff2f0;
  color: #ff4d4f;
  border: 2rpx solid #ffccc7;
}

.action-btn.approve {
  background-color: #e6f7ff;
  color: #1890ff;
  border: 2rpx solid #91d5ff;
}

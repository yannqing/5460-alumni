<!--pages/audit/merchant/apply-detail/apply-detail.wxml-->
<!-- 审核样式下内容必须放在 custom-nav-bar 内部，否则不会进入 slot，白底区域为空 -->
<custom-nav-bar showBack="{{true}}" useAuditStyle="{{true}}" auditTitle="商户申请详情">
<view class="apply-detail-page">
  <view class="detail-section" wx:if="{{loading}}">
    <view class="loading-text">加载中...</view>
  </view>

  <view class="detail-content" wx:else>
    <!-- 商家头图 -->
    <view class="detail-header">
      <image class="header-bg" src="{{applyInfo.backgroundImageUrl || defaultBackground}}" mode="aspectFill" />
      <view class="header-content">
        <view class="header-left">
          <view class="logo-container">
            <image class="merchant-logo" src="{{applyInfo.logoUrl || defaultLogo}}" mode="aspectFill" />
          </view>
        </view>
        <view class="merchant-basic">
          <text class="merchant-name">{{applyInfo.merchantName || '-'}}</text>
        </view>
      </view>
    </view>

    <!-- 基本信息 -->
    <view class="detail-section">
      <view class="section-title">基本信息</view>
      <view class="detail-item">
        <text class="detail-label">商户名称：</text>
        <text class="detail-value">{{applyInfo.merchantName}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">商户类型：</text>
        <text class="detail-value">{{applyInfo.merchantTypeText}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">申请人：</text>
        <text class="detail-value">{{applyInfo.applicantName || '-'}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">联系电话：</text>
        <text class="detail-value">{{applyInfo.contactPhone}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">申请时间：</text>
        <text class="detail-value">{{applyInfo.submitTime}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">审核状态：</text>
        <text class="detail-value status-{{applyInfo.status}}">{{applyInfo.statusText}}</text>
      </view>

      <block wx:if="{{applyInfo.alumniAssociation}}">
        <view class="section-title section-title--assoc">关联校友会</view>
        <view class="association-row">
          <image
            class="association-logo"
            src="{{applyInfo.alumniAssociation.logoUrl || defaultAlumniLogo}}"
            mode="aspectFill"
          />
          <view class="association-name-body">
            <text class="association-name">{{applyInfo.alumniAssociation.associationName || '-'}}</text>
          </view>
        </view>
      </block>
    </view>

    <!-- 营业执照信息 -->
    <view class="detail-section">
      <view class="section-title">营业执照信息</view>
      <view class="license-photo-block" wx:if="{{applyInfo.businessLicenseUrl}}">
        <text class="detail-label license-photo-label">营业执照照片：</text>
        <image
          class="license-photo"
          src="{{applyInfo.businessLicenseUrl}}"
          mode="aspectFit"
          show-menu-by-longpress="{{true}}"
        />
      </view>
      <view class="detail-item">
        <text class="detail-label detail-label-single-line">统一社会信用代码：</text>
        <text class="detail-value detail-value-single-line">{{applyInfo.businessLicenseCode}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">法定代表人：</text>
        <text class="detail-value">{{applyInfo.legalRepresentative}}</text>
      </view>
      <view class="detail-item" wx:if="{{applyInfo.businessAddress}}">
        <text class="detail-label">经营地址：</text>
        <text class="detail-value">{{applyInfo.businessAddress}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">经营范围：</text>
        <text class="detail-value">{{applyInfo.businessScope}}</text>
      </view>
      <view class="detail-item" wx:if="{{applyInfo.registrationDate}}">
        <text class="detail-label">注册日期：</text>
        <text class="detail-value">{{applyInfo.registrationDate}}</text>
      </view>
    </view>

    <!-- 审核操作区域 -->
    <view class="audit-actions" wx:if="{{canAudit && applyInfo.status === 'pending'}}">
      <view class="action-buttons">
        <view class="action-btn reject" bindtap="handleReject">拒绝</view>
        <view class="action-btn approve" bindtap="handleApprove">通过</view>
      </view>
    </view>
  </view>
</view>
</custom-nav-bar>

.page {
  padding: 20rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.form-section {
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #eee;
}

.form-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.form-input {
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #f9f9f9;
}

.form-textarea {
  width: 100%;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #f9f9f9;
  min-height: 120rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

.status-selector {
  display: flex;
  gap: 20rpx;
}

.status-option {
  flex: 1;
  padding: 12rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  background-color: #f9f9f9;
}

.status-option.active {
  background-color: #40B2E6;
  color: #fff;
  border-color: #40B2E6;
}

.uploader {
  display: flex;
  gap: 20rpx;
}

.uploader-item {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  overflow: hidden;
  border: 1rpx solid #ddd;
}

.uploader-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.uploader-delete {
  position: absolute;
  top: 0;
  right: 0;
  width: 32rpx;
  height: 32rpx;
  background-color: rgba(0, 0, 0, 0.5);
  color: #fff;
  text-align: center;
  line-height: 32rpx;
  font-size: 24rpx;
  border-bottom-left-radius: 8rpx;
}

.uploader-add {
  width: 120rpx;
  height: 120rpx;
  border: 2rpx dashed #ddd;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #999;
  background-color: #f9f9f9;
}

.section-title.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.add-btn {
  font-size: 24rpx;
  color: #40B2E6;
  font-weight: normal;
  border: 1rpx solid #40B2E6;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.event-year-item {
  border: 1rpx solid #eee;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  background-color: #fafafa;
}

.year-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  border-bottom: 1rpx dashed #ddd;
  padding-bottom: 12rpx;
}

.year-input {
  flex: 1;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.delete-icon {
  font-size: 24rpx;
  color: #ff4d4f;
  margin-left: 20rpx;
}

.event-detail-list {
  padding-left: 20rpx;
}

.event-detail-item {
  position: relative;
  margin-bottom: 16rpx;
  padding-right: 60rpx;
}

.event-textarea {
  width: 100%;
  border: 1rpx solid #ddd;
  border-radius: 6rpx;
  padding: 12rpx;
  font-size: 26rpx;
  color: #555;
  background-color: #fff;
  min-height: 80rpx;
  box-sizing: border-box;
}

.delete-event {
  position: absolute;
  top: 50%;
  right: 10rpx;
  transform: translateY(-50%);
  width: 36rpx;
  height: 36rpx;
  background-color: #ff4d4f;
  color: #fff;
  text-align: center;
  line-height: 32rpx;
  font-size: 32rpx;
  border-radius: 50%;
}

.add-event-btn {
  font-size: 24rpx;
  color: #40B2E6;
  text-align: center;
  padding: 10rpx;
  border: 1rpx dashed #40B2E6;
  border-radius: 6rpx;
  margin-top: 10rpx;
}

.submit-section {
  margin-top: 40rpx;
  margin-bottom: 40rpx;
}

.submit-button {
  width: 100%;
  height: 80rpx;
  background-color: #40B2E6;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
}

.submit-button::after {
  border: none;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #40B2E6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading text {
  font-size: 28rpx;
  color: #666;
}

/* 联系人选择相关 */
.contact-select-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #f9f9f9;
}

.contact-select-text.placeholder {
  color: #999;
}

.contact-select-arrow {
  font-size: 24rpx;
  color: #999;
}

.contact-clear-btn {
  font-size: 24rpx;
  color: #40B2E6;
  margin-top: 8rpx;
}

/* 选择联系人弹窗 */
.contact-member-picker {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
}

.contact-member-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.contact-member-content {
  position: absolute;
  left: 40rpx;
  right: 40rpx;
  bottom: 80rpx;
  max-height: 70vh;
  background-color: #fff;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
}

.contact-member-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #eee;
}

.contact-member-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.contact-member-close {
  font-size: 40rpx;
  color: #999;
}

.contact-member-search {
  display: flex;
  padding: 16rpx;
  gap: 16rpx;
}

.contact-member-search-input {
  flex: 1;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
}

.contact-member-search-btn {
  padding: 16rpx 24rpx;
  background-color: #40B2E6;
  color: #fff;
  font-size: 28rpx;
  border-radius: 8rpx;
}

.contact-member-list {
  flex: 1;
  max-height: 400rpx;
  padding: 0 16rpx 16rpx;
}

.contact-member-loading,
.contact-member-empty {
  padding: 40rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
}

.contact-member-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.contact-member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background-color: #f0f0f0;
}

.contact-member-info {
  flex: 1;
}

.contact-member-name {
  font-size: 30rpx;
  color: #333;
  display: block;
}

.contact-member-role {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}
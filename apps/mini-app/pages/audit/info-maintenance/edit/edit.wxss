.page {
  padding: 20rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.form-section {
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #eee;
}

.form-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.form-input {
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #f9f9f9;
}

.form-textarea {
  width: 100%;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #f9f9f9;
  min-height: 120rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

.status-selector {
  display: flex;
  gap: 20rpx;
}

.status-option {
  flex: 1;
  padding: 12rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  background-color: #f9f9f9;
}

.status-option.active {
  background-color: #40B2E6;
  color: #fff;
  border-color: #40B2E6;
}

.uploader {
  display: flex;
  gap: 20rpx;
}

.uploader-item {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  overflow: hidden;
  border: 1rpx solid #ddd;
}

.uploader-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.uploader-delete {
  position: absolute;
  top: 0;
  right: 0;
  width: 32rpx;
  height: 32rpx;
  background-color: rgba(0, 0, 0, 0.5);
  color: #fff;
  text-align: center;
  line-height: 32rpx;
  font-size: 24rpx;
  border-bottom-left-radius: 8rpx;
}

.uploader-add {
  width: 120rpx;
  height: 120rpx;
  border: 2rpx dashed #ddd;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #999;
  background-color: #f9f9f9;
}

.submit-section {
  margin-top: 40rpx;
  margin-bottom: 40rpx;
}

.submit-button {
  width: 100%;
  height: 80rpx;
  background-color: #40B2E6;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
}

.submit-button::after {
  border: none;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #40B2E6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading text {
  font-size: 28rpx;
  color: #666;
}
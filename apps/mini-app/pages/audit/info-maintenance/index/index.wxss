/* pages/audit/info-maintenance/index/index.wxss */

.page {
  background-color: #f7f8fa;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding-bottom: 40rpx;
}

.group_5 {
  width: 702rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  margin: 32rpx auto 0;
  padding: 32rpx 32rpx 32rpx 32rpx;
  box-sizing: border-box;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.text_14 {
  color: #333333;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  display: block;
}

.label_text {
  color: #666666;
  font-size: 26rpx;
  margin-bottom: 12rpx;
  display: block;
}

.text-wrapper_8 {
  height: 88rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
  border: 1rpx solid #eeeeee;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.text_15 {
  flex: 1;
  color: #333333;
  font-size: 28rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-wrapper_8::after {
  content: '';
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-top: 12rpx solid #999999;
  margin-left: 16rpx;
}

/* 校促会选择器弹窗 */
.platform-picker {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10000;
}

.picker-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(4px);
}

.picker-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 75vh;
  padding-bottom: env(safe-area-inset-bottom);
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
  border-bottom: 1rpx solid #f2f2f2;
}

.picker-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.picker-cancel {
  font-size: 28rpx;
  color: #999;
  padding: 10rpx;
}

.picker-list {
  max-height: 60vh;
  overflow-y: auto;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 40rpx;
  border-bottom: 1rpx solid #f9f9f9;
}

.picker-item:active {
  background-color: #f5f5f5;
}

.item-name {
  font-size: 30rpx;
  color: #333333;
}

.item-check {
  font-size: 32rpx;
  color: #4A8BF5;
  font-weight: 600;
}

.picker-empty {
  padding: 100rpx 0;
  text-align: center;
  color: #999999;
}

.content-section {
  width: 702rpx;
  margin: 24rpx auto 0;
  box-sizing: border-box;
}

/* 详细信息卡片 */
.detail-card {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 顶部 Header */
.detail-header {
  position: relative;
  width: 100%;
  height: 380rpx;
  margin-bottom: 30rpx;
  overflow: visible;
}

.detail-header::after {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.4) 100%);
  border-radius: 40rpx 40rpx 40rpx 40rpx;
  z-index: 1;
}

.header-bg {
  width: 100%;
  height: 100%;
  border-radius: 40rpx 40rpx 40rpx 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.header-content {
  position: absolute;
  bottom: -1rpx;
  left: 40rpx;
  right: 40rpx;
  display: flex;
  align-items: flex-end;
  z-index: 2;
}

.header-left {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-container {
  width: 100rpx;
  height: 100rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 6rpx;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.headquarters-logo {
  width: 100%;
  height: 100%;
  border-radius: 20rpx;
}

.headquarters-basic {
  margin-left: 20rpx;
  padding-bottom: 30rpx;
  flex: 1;
}

.headquarters-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
  display: block;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.info-group-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  background: #4A8BF5;
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.info-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f9f9f9;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  width: 200rpx;
  font-size: 26rpx;
  color: #888888;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  word-break: break-all;
}

.info-value.status-box {
  display: flex;
  align-items: center;
}

.info-value.multi-line {
  line-height: 1.5;
  color: #555555;
}

/* 状态标签 */
.status-tag {
  display: inline-flex;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-approved {
  background-color: #e6f7ff;
  color: #1890ff;
  border: 1rpx solid #91d5ff;
}

.status-rejected {
  background-color: #fff1f0;
  color: #f5222d;
  border: 1rpx solid #ffa39e;
}

.tag-active {
  background-color: #f6ffed;
  color: #52c41a;
  border: 1rpx solid #b7eb8f;
}

.tag-disabled {
  background-color: #f5f5f5;
  color: #8c8c8c;
  border: 1rpx solid #d9d9d9;
}

/* 顶部关键指标 */
.metrics-row {
  display: flex;
  justify-content: space-between;
  background: linear-gradient(135deg, #4A8BF5, #67A7FF);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  color: #FFFFFF;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(74, 139, 245, 0.2);
}

.metric-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.metric-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 10%;
  height: 80%;
  width: 1rpx;
  background-color: rgba(255, 255, 255, 0.3);
}

.metric-label {
  font-size: 24rpx;
  opacity: 0.9;
  margin-bottom: 8rpx;
}

.metric-value {
  font-size: 36rpx;
  font-weight: 700;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #4A8BF5;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  margin-top: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.error-icon {
  font-size: 100rpx;
  margin-bottom: 32rpx;
}

.error-text {
  font-size: 30rpx;
  color: #999999;
}

.button-section {
  margin-top: 40rpx;
  margin-bottom: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.primary-button {
  width: 100%;
  height: 80rpx;
  background-color: #4A8BF5;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
}

.secondary-button {
  width: 100%;
  height: 80rpx;
  background-color: #ffffff;
  color: #4A8BF5;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 12rpx;
  border: 1rpx solid #4A8BF5;
}

.primary-button::after,
.secondary-button::after {
  border: none;
}

/* 隐私设置弹窗 */
.privacy-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10000;
}

.modal-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(4px);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background-color: #fff;
  border-radius: 24rpx;
  width: 85%;
  max-width: 600rpx;
  max-height: 80vh;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
  border-bottom: 1rpx solid #f2f2f2;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}

.modal-body {
  padding: 40rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.privacy-description {
  margin-bottom: 32rpx;
  padding: 20rpx;
  background-color: #f5f7fa;
  border-radius: 12rpx;
  border-left: 4rpx solid #4A8BF5;
}

.description-text {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.description-detail {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 4rpx;
}

.privacy-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.privacy-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f9f9f9;
}

.privacy-item:last-child {
  border-bottom: none;
}

.privacy-field-name {
  font-size: 28rpx;
  color: #333333;
  flex: 1;
}

.privacy-switch {
  transform: scale(1.2);
  margin-left: 20rpx;
}

.empty-state {
  text-align: center;
  padding: 60rpx 0;
  color: #999999;
  font-size: 28rpx;
}
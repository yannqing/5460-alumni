  left: 0;
  right: 0;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 80vh;
  overflow: hidden;
}

.add-member-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.add-member-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.add-member-modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
  cursor: pointer;
}

.add-member-modal-body {
  flex: 1;
  padding: 20rpx 30rpx;
  display: flex;
  flex-direction: column;
  min-height: 0;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

/* 成员职务输入样式 */
.add-member-role-input {
  margin-bottom: 20rpx;
  flex-shrink: 0;
}

.add-member-role-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.add-member-role-label.required::before {
  content: '*';
  color: #ff4d4f;
  margin-right: 8rpx;
}

.add-member-role-field {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  background-color: #fafafa;
  box-sizing: border-box;
}

.add-member-modal-body .loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.add-member-modal-body .member-list {
  flex: 1;
  min-height: 0;
  width: 100%;
  box-sizing: border-box;
  overflow-x: hidden;
  overflow-y: auto;
}

.add-member-modal-body .member-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  cursor: pointer;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.add-member-modal-body .member-item:active {
  background-color: #f5f5f5;
}

.add-member-modal-body .member-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.add-member-modal-body .member-avatar image {
  width: 100%;
  height: 100%;
}

.add-member-modal-body .member-info {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.add-member-modal-body .member-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.add-member-modal-body .member-role {
  font-size: 24rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.add-member-modal-body .member-checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.add-member-modal-body .member-checkbox.checked {
  background-color: #1890ff;
  border-color: #1890ff;
  color: #fff;
}

.add-member-modal-body .member-checkbox.checked text {
  font-size: 24rpx;
  font-weight: 600;
}

.add-member-modal-body .empty-state {
  padding: 60rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.add-member-modal-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.add-member-btn-cancel,
.add-member-btn-confirm {
  flex: 1;
  text-align: center;
  padding: 30rpx;
  font-size: 32rpx;
  cursor: pointer;
}

.add-member-btn-cancel {
  color: #666;
  border-right: 1rpx solid #f0f0f0;
}

.add-member-btn-confirm {
  color: #1890ff;
  font-weight: 600;
}

/* ========== 组织架构树形预览样式（从左到右布局） ========== */
.template-tree-preview {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #f8f9ff 0%, #f0f5ff 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid #e6e9f0;
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.tree-scroll-container {
  width: 100%;
  flex: 1;
  min-height: 400rpx;
}

.tree-container {
  display: inline-flex;
  flex-direction: column;
  padding: 20rpx 10rpx;
  min-width: fit-content;
  min-height: fit-content;
}

/* 一级节点行（从左到右布局） */
.tree-node-row {
  display: inline-flex;
  flex-direction: row;
  align-items: flex-start;
  margin-bottom: 24rpx;
  position: relative;
  white-space: nowrap;
}

/* 有子节点的节点右侧的水平线 */
.tree-node.has-children::after {
  content: '';
  position: absolute;
  right: -24rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 24rpx;
  height: 2rpx;
  background-color: #c0c4cc;
}

/* 子节点列（垂直排列） */
.tree-children-row {
  display: inline-flex;
  flex-direction: column;
  justify-content: center;
  gap: 16rpx;
  margin-left: 24rpx;
  padding-left: 24rpx;
  position: relative;
  white-space: nowrap;
}

/* 子节点列左侧的垂直连接线 */
.tree-children-row::before {
  content: '';
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 2rpx;
  background-color: #c0c4cc;
}

/* 分支容器（水平排列：节点 + 子节点） */
.tree-branch {
  display: inline-flex;
  flex-direction: row;
  align-items: flex-start;
  position: relative;
  padding-left: 24rpx;
  white-space: nowrap;
}

/* 分支左侧的水平连接线 */
.tree-branch::before {
  content: '';
  position: absolute;
  left: 0;
  top: 24rpx;
  width: 24rpx;
  height: 2rpx;
  background-color: #c0c4cc;
}

/* 移除不需要的垂直连接线样式 */
.tree-branch::after {
  display: none;
}

/* 子节点容器（垂直排列） */
.tree-sub-children {
  display: inline-flex;
  flex-direction: column;
  gap: 16rpx;
  margin-left: 24rpx;
  padding-left: 24rpx;
  position: relative;
  white-space: nowrap;
}

/* 子节点容器左侧的垂直连接线 */
.tree-sub-children::before {
  content: '';
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 2rpx;
  background-color: #c0c4cc;
}

/* 节点样式 */
.tree-node {
  display: flex;
  flex-direction: row;
  align-items: center;
  position: relative;
  cursor: pointer;
  flex-shrink: 0;
}

.tree-node:active {
  opacity: 0.8;
}

.node-content {
  padding: 18rpx 32rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  text-align: center;
  white-space: nowrap;
  color: #fff;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  position: relative;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.node-name {
  font-size: 24rpx;
}

.node-member-count {
  font-size: 20rpx;
  opacity: 0.85;
}

/* 不同层级的颜色 */
.tree-node.level-1 .node-content {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  font-size: 28rpx;
  padding: 20rpx 40rpx;
}

.tree-node.level-2 .node-content {
  background: linear-gradient(135deg, #1890FF 0%, #40a9ff 100%);
}

.tree-node.level-3 .node-content {
  background: linear-gradient(135deg, #13c2c2 0%, #36cfc9 100%);
}

.tree-node.level-4 .node-content {
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
}

.tree-node.level-5 .node-content {
  background: linear-gradient(135deg, #faad14 0%, #ffc53d 100%);
  color: #333;
}

/* ========== 节点详情弹窗样式 ========== */
.node-detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1005;
}

.node-detail-modal-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.node-detail-modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.node-detail-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.node-detail-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.node-detail-modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
  cursor: pointer;
}

.node-detail-modal-body {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  padding: 0 30rpx 30rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 节点基本信息 */
.node-info-section {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.node-info-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;

/* pages/audit/schooloffice/organization/organization.wxss */
/* 与校友会审核页 list 一致：.page 布局，固定 group_5，仅 group_7 内 scroll-list 滚动 */
.page {
  background-color: transparent;
  position: relative;
  width: 750rpx;
  height: 100%;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}

/* 校促会选择卡片（与 list 一致：固定不滚动） */
.page .group_5 {
  width: 714rpx;
  min-height: auto;
  margin: 47rpx 0 0 18rpx;
  padding: 38rpx 43rpx 27rpx 43rpx;
  flex-shrink: 0;
}

.group_5 {
  background-color: #FFFFFF;
  border-radius: 28.99rpx;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  flex-shrink: 0;
}

.group_5 .text_14 {
  width: auto;
  height: 40rpx;
  overflow-wrap: break-word;
  color: rgba(0,0,0,1);
  font-size: 29rpx;
  letter-spacing: 0rpx;
  font-family: PingFangSC-Semibold, -apple-system, sans-serif;
  font-weight: 600;
  text-align: left;
  white-space: nowrap;
  line-height: 40rpx;
}

.group_5 .label_text {
  width: auto;
  height: 36rpx;
  overflow-wrap: break-word;
  color: rgba(0,0,0,0.6);
  font-size: 25rpx;
  font-family: PingFangSC-Regular, -apple-system, sans-serif;
  font-weight: normal;
  text-align: left;
  white-space: nowrap;
  line-height: 36rpx;
  margin-top: 16rpx;
  display: block;
}

.group_5 .text-wrapper_8 {
  height: 80rpx;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  border: 1rpx solid #E0E0E0;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  margin-top: 16rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  position: relative;
}

.group_5 .text_15 {
  flex: 1;
  height: 36rpx;
  overflow-wrap: break-word;
  color: rgba(0,0,0,0.85);
  font-size: 28rpx;
  font-family: PingFangSC-Regular, -apple-system, sans-serif;
  font-weight: normal;
  text-align: left;
  white-space: nowrap;
  line-height: 36rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

.group_5 .text-wrapper_8::after {
  content: '▼';
  color: #999;
  font-size: 20rpx;
  margin-left: 10rpx;
}

/* 校促会选择器弹窗（与校友会审核页一致） */
.school-office-picker {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10000;
}

.school-office-picker .picker-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.school-office-picker .picker-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  border-radius: 20rpx 20rpx 0 0;
  max-height: 70vh;
  overflow: hidden;
}

.school-office-picker .picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.school-office-picker .picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.school-office-picker .picker-cancel {
  font-size: 28rpx;
  color: #999;
}

.school-office-picker .picker-list {
  max-height: calc(50vh + 40px);
  overflow-y: auto;
  padding: 0 30rpx;
}

.school-office-picker .picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.school-office-picker .item-name {
  font-size: 28rpx;
  color: #333;
}

.school-office-picker .item-check {
  font-size: 32rpx;
  color: #52c41a;
  font-weight: 600;
}

.school-office-picker .picker-empty {
  padding: 60rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

/* 角色列表卡片（与 list 的 group_7 一致，样式按设计稿 group_15/group_19） */
.group_7 {
  width: 714rpx;
  flex: 1;
  background-color: #FFFFFF;
  border-radius: 28.99rpx;
  display: flex;
  flex-direction: column;
  margin: 34rpx 0 20rpx 18rpx;
  padding: 38rpx 25rpx 20rpx 25rpx;
  box-sizing: border-box;
  overflow: hidden;
  position: relative;
  z-index: 1;
}

.scroll-list {
  flex: 1;
  width: 100%;
  height: 0;
  min-height: 0;
  scrollbar-width: none;
  -ms-overflow-style: none;
  display: flex;
  flex-direction: column;
}
.scroll-list::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}

/* 设计稿 group_19：标题行；标题与列表左对齐（与内容区左缘一致），按钮右缘与列表编辑/删除右缘对齐 */
.group_19 {
  position: relative;
  width: 100%;
  height: 58rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin: -10rpx 0 0 15rpx;
  padding: 0;
  box-sizing: border-box;
  flex-shrink: 0;
}

/* 设计稿 text_25：校促会角色列表 */
.group_19 .text_25 {
  width: 205rpx;
  height: 40rpx;
  overflow-wrap: break-word;
  color: rgba(0,0,0,1);
  font-size: 29rpx;
  letter-spacing: 0rpx;
  font-family: PingFangSC-Semibold, -apple-system, sans-serif;
  font-weight: 600;
  text-align: left;
  white-space: nowrap;
  line-height: 40rpx;
  margin-top: 9rpx;
  flex-shrink: 0;
}

/* +新增顶级架构按钮 */
.group_19 .text-wrapper_13 {
  position: absolute;
  right: 24rpx;
  top: 0;
  background-color: rgba(24,144,255,1);
  border-radius: 7rpx;
  height: 58rpx;
  min-width: fit-content;
  width: auto;
  padding: 0 24rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 25rpx;
  letter-spacing: 0rpx;
  font-family: PingFangSC-Regular, -apple-system, sans-serif;
  font-weight: normal;
  color: rgba(255,255,255,1);
  line-height: 36rpx;
  flex-shrink: 0;
  white-space: nowrap;
}

/* 角色列表内容：与标题保持统一垂直间距，与图中一致 */
.group_7 .role-list {
  margin-top: 20rpx;
  padding-bottom: 40rpx;
}

.role-item {
  background-color: #f9f9f9;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #f0f0f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 树形层级样式 */
.role-item.level-1 {
  margin-left: 0;
  background-color: #f0f7ff;
  border-color: #91caff;
}

.role-item.level-2 {
  margin-left: 40rpx;
  background-color: #f6ffed;
  border-color: #b7eb8f;
}

.role-item.level-3 {
  margin-left: 80rpx;
  background-color: #fff7e6;
  border-color: #ffd591;
}

.role-item.level-4 {
  margin-left: 120rpx;
  background-color: #f9f0ff;
  border-color: #d3adf7;
}

.role-item.level-5 {
  margin-left: 160rpx;
  background-color: #fff0f6;
  border-color: #ffadd2;
}

/* 角色左侧区域（包含展开图标和名称） */
.role-left {
  display: flex;
  align-items: center;
  flex: 1;
}

/* 展开/收缩图标 */
.expand-icon {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  cursor: pointer;
}

.expand-icon .arrow {
  font-size: 20rpx;
  color: #666;
  transition: transform 0.2s ease;
  display: inline-block;
}

.expand-icon.expanded .arrow {
  transform: rotate(90deg);
}

/* 成员列表展开/收缩图标 */
.expand-icon.members-icon {
  margin-left: 10rpx;
  margin-right: 0;
}

.expand-icon.members-icon .arrow {
  font-size: 18rpx;
  color: #1890ff;
}

.expand-icon.members-icon.expanded .arrow {
  transform: rotate(180deg);
}

/* 占位符（无子节点时保持对齐） */
.expand-placeholder {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}

.role-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

/* 操作按钮容器 */
.role-actions {
  display: flex;
  align-items: center;
}

.edit-btn {
  font-size: 24rpx;
  color: #1890ff;
  background-color: #e6f7ff;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid #91d5ff;
  cursor: pointer;
  margin-left: 20rpx;
}

.edit-btn:hover {
  background-color: #bae7ff;
}

.delete-btn {
  font-size: 24rpx;
  color: #ff4d4f;
  background-color: #fff1f0;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid #ffccc7;
  cursor: pointer;
  margin-left: 20rpx;
}

.delete-btn:hover {
  background-color: #ffe8e6;
}

/* 添加成员按钮 */
.add-member-btn {
  font-size: 24rpx;
  color: #52c41a;
  background-color: #f6ffed;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid #b7eb8f;
  cursor: pointer;
  margin-left: 20rpx;
}

.add-member-btn:hover {
  background-color: #d9f7be;
}

/* 成员列表样式 */
.members-container {
  margin-bottom: 20rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  border: 1rpx solid #f0f0f0;
}

.members-container.level-1 {
  margin-left: 0;
  background-color: #f0f7ff;
  border-color: #91caff;
}

.members-container.level-2 {
  margin-left: 40rpx;
  background-color: #f0f7ff;
  border-color: #91caff;
}

.members-container.level-3 {
  margin-left: 80rpx;
  background-color: #f0f7ff;
  border-color: #91caff;
}

.members-container.level-4 {
  margin-left: 120rpx;
  background-color: #f0f7ff;
  border-color: #91caff;
}

.members-container.level-5 {
  margin-left: 160rpx;
  background-color: #f0f7ff;
  border-color: #91caff;
}

.members-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #666;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid rgba(0,0,0,0.05);
}

.member-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(0,0,0,0.05);
}

.member-item:last-child {
  border-bottom: none;
}

.member-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.member-avatar image {
  width: 100%;
  height: 100%;
}

.member-avatar.placeholder {
  background-color: #e6f7ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #1890ff;
}

.member-info {
  flex: 1;
}

.member-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.member-role {
  font-size: 22rpx;
  color: #666;
}

/* 成员操作按钮 */
.member-actions {
  display: flex;
  align-items: center;
}

.delete-member-btn {
  font-size: 22rpx;
  color: #ff4d4f;
  background-color: #fff1f0;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  border: 1rpx solid #ffccc7;
  cursor: pointer;
}

.delete-member-btn:hover {
  background-color: #ffe8e6;
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 编辑弹窗样式 */
.edit-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1001;
}

.edit-modal-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.edit-modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 80vh;
  overflow: hidden;
}

.edit-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.edit-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.edit-modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
  cursor: pointer;
}

.edit-modal-body {
  padding: 30rpx;
  max-height: 50vh;
  overflow-y: auto;
}

.edit-form-item {
  margin-bottom: 30rpx;
}

.edit-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}

.edit-label.required::before {
  content: '*';
  color: #ff4d4f;
  margin-right: 8rpx;
}

.edit-input {
  border: 1rpx solid #eee;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  background-color: #fafafa;
}

.status-switch {
  display: flex;
  align-items: center;
}

.status-text {
  font-size: 28rpx;
  color: #666;
  margin-left: 16rpx;
}

.edit-modal-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.edit-btn-cancel,
.edit-btn-confirm {
  flex: 1;
  text-align: center;
  padding: 30rpx;
  font-size: 32rpx;
  cursor: pointer;
}

.edit-btn-cancel {
  color: #666;
  border-right: 1rpx solid #f0f0f0;
}

.edit-btn-confirm {
  color: #1890ff;
  font-weight: 600;
}

/* 移动层级弹窗样式 */
.move-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1002;
}

.move-modal-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.move-modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.move-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.move-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.move-modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
  cursor: pointer;
}

.move-modal-tip {
  padding: 16rpx 30rpx;
  background-color: #fffbe6;
  border-bottom: 1rpx solid #ffe58f;
}

.move-modal-tip text {
  font-size: 24rpx;
  color: #d48806;
}

.move-modal-body {
  flex: 1;
  max-height: 50vh;
  padding: 20rpx 0;
}

.parent-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  cursor: pointer;
}

.parent-item:active {
  background-color: #f5f5f5;
}

.parent-item.root-item {
  background-color: #f0f7ff;
}

.parent-item.root-item .parent-name {
  color: #1890ff;
  font-weight: 600;
}

.parent-item.current-parent {
  background-color: #f6ffed;
}

.parent-indent {
  flex-shrink: 0;
}

.parent-name {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.current-tag {
  font-size: 22rpx;
  color: #52c41a;
  background-color: #f6ffed;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  border: 1rpx solid #b7eb8f;
  margin-left: 16rpx;
}

.move-empty {
  padding: 60rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.move-modal-footer {
  border-top: 1rpx solid #f0f0f0;
  padding: 20rpx 30rpx;
}

.move-btn-cancel {
  text-align: center;
  padding: 20rpx;
  font-size: 32rpx;
  color: #666;
  background-color: #f5f5f5;
  border-radius: 8rpx;
}

/* 标题行样式 */
.form-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;

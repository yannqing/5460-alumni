<!--pages/my-favorites/my-favorites.wxml-->
<!-- 自定义导航栏 -->
<custom-nav-bar showBack="{{true}}" useAuditStyle="{{true}}" auditTitle="我的收藏">
<!-- 消息通知组件 -->
<message-notification />

<view class="page">
  <view class="group_7">
    <scroll-view
      class="scroll-list"
      scroll-y
      enable-back-to-top
      show-scrollbar="{{false}}"
      bindscrolltolower="onScrollToLower"
      lower-threshold="80"
    >
      <view class="shop-list">
        <view class="shop-card" wx:for="{{favoriteShops}}" wx:key="id" bindtap="viewShopDetail" data-id="{{item.id}}">
          <image class="shop-cover" src="{{item.cover}}" mode="aspectFill"></image>
          <view class="shop-content">
            <view class="shop-header">
              <text class="shop-name">{{item.name}}</text>
              <view wx:if="{{item.isCertified}}" class="certified-badge">校友商铺</view>
            </view>
            <view class="shop-desc">{{item.businessCategoryText}}</view>
            <view class="shop-desc">{{item.contactPhoneText}}</view>
          </view>
        </view>
      </view>

      <view wx:if="{{favoriteShops.length === 0}}" class="empty-state">
        <text class="empty-text">暂无收藏</text>
      </view>
      <view wx:if="{{favoriteShops.length > 0 && loadingMore}}" class="empty-state">
        <text class="empty-text">加载中...</text>
      </view>
      <view wx:if="{{favoriteShops.length > 0 && !hasMore}}" class="empty-state">
      </view>
    </scroll-view>
  </view>
</view>
</custom-nav-bar>



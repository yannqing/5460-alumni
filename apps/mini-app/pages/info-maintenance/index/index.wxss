/* pages/info-maintenance/index/index.wxss */
.page {
  background-color: transparent;
  width: 750rpx;
  min-height: calc(100vh - 190.22rpx);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 选择校友会区域（现代化下拉框样式，放在左上角） */
.alumni-selector-wrap {
  flex-shrink: 0;
  padding: 24rpx 18rpx 0;
}

.alumni-selector {
  display: inline-flex;
  align-items: center;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  min-width: 280rpx;
  max-width: 600rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.selector-text {
  font-size: 28rpx;
  color: #333;
  margin-right: 16rpx;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.selector-arrow {
  font-size: 18rpx;
  color: #999;
}

.selector-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.group_7 {
  width: 714rpx;
  flex-shrink: 0;
  background-color: #FFFFFF;
  border-radius: 28.99rpx;
  margin: 34rpx 0 20rpx 18rpx;
  padding: 38rpx 43rpx 27rpx 43rpx;
  box-sizing: border-box;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.detail-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  flex-shrink: 0;
  position: relative;
}

.group_7 .text_20 {
  font-size: 29rpx;
  font-weight: 600;
  color: rgba(0,0,0,1);
  line-height: 40rpx;
}

.edit-button {
  position: absolute;
  right: 0;
  background-color: #1890ff;
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 25rpx;
  min-width: 120rpx;
  text-align: center;
  border: none;
}
.edit-button::after { border: none; }

.alumni-logo {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 24rpx;
}

.logo-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  object-fit: cover;
}

.alumni-detail {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.detail-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 28rpx;
}

.detail-item:last-child { border-bottom: none; }

.detail-label {
  color: #666;
  flex: 1;
}

.detail-value {
  color: #333;
  flex: 2;
  text-align: right;
}

/* 校友会简介特殊样式 */
.detail-item-profile {
  flex-direction: column;
  align-items: flex-start;
}

.detail-value-profile {
  text-align: left;
  width: 100%;
  margin-top: 12rpx;
  line-height: 1.6;
  color: #333;
  word-break: break-all;
  white-space: pre-wrap;
}

.detail-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1890ff;
  padding: 24rpx 0 8rpx 0;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 8rpx;
}

.empty-block {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 20rpx;
  flex: 1;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
  text-align: center;
}

.alumni-association-picker {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 10000;
}

.picker-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0,0,0,0.5);
}

.picker-content {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  background-color: #fff;
  border-radius: 20rpx 20rpx 0 0;
  max-height: 70vh;
  overflow: hidden;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-title { font-size: 32rpx; font-weight: 600; color: #333; }
.picker-cancel { font-size: 28rpx; color: #999; }

.picker-list {
  max-height: calc(50vh + 40px);
  overflow-y: auto;
  padding: 0 30rpx;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-item.selected {
  background-color: #f6ffed;
}

.picker-item-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.picker-item-logo {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background-color: #f5f5f5;
  flex-shrink: 0;
}

.picker-item-logo-placeholder {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background: linear-gradient(135deg, #3759C7 0%, #5273D2 100%);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.picker-item-logo-placeholder text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}

.picker-item-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.item-name { font-size: 28rpx; color: #333; }

.item-location {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.item-check { font-size: 32rpx; color: #52c41a; font-weight: 600; }

.picker-empty {
  padding: 60rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

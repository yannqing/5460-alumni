<!--pages/coupon/detail/detail.wxml-->
<!-- 自定义导航栏 -->
<custom-nav-bar showBack="{{true}}" useAuditStyle="{{true}}" auditTitle="优惠券详情">
  <view class="page">
    <scroll-view class="scroll-content" scroll-y enable-back-to-top show-scrollbar="{{false}}">
      <view class="coupon-detail-page">
        <!-- 加载中 -->
        <view wx:if="{{loading}}" class="loading-container">
          <text class="loading-text">加载中...</text>
        </view>

        <view wx:elif="{{couponInfo}}">
          <view class="group_tabs">
            <view class="coupon-main-card">
              <view class="coupon-card">
                <view class="coupon-left-section">
                  <view class="coupon-discount-big">
                    <text wx:if="{{couponInfo.discountValue}}">{{couponInfo.discountValue}}</text>
                    <text wx:else>优惠券</text>
                  </view>
                  <view class="coupon-label-text">券详情</view>
                </view>
                <view class="coupon-divider-vertical"></view>
                <view class="coupon-right-section">
                  <view class="coupon-title-row">
                    <view class="coupon-title-main">{{couponInfo.couponName}}</view>
                    <view class="coupon-status-tag status-{{couponInfo.status}}" wx:if="{{couponInfo.status}}">
                      {{couponInfo.status === 1 ? '未使用' : couponInfo.status === 2 ? '已使用' : couponInfo.status === 3 ? '已过期' : '已作废'}}
                    </view>
                  </view>
                  <view class="coupon-code-display">
                    <text class="code-label">核销码：</text>
                    <text class="code-value">{{couponInfo.verificationCode || '暂无'}}</text>
                  </view>
                  <view class="coupon-time-text">有效期至 {{formattedValidEndTime}}</view>
                </view>
              </view>
            </view>

            <view wx:if="{{couponInfo.status === 2}}" class="qr-code-card">
              <view class="consumed-tip">
                <text class="consumed-text">已消费</text>
              </view>
            </view>
            <view wx:else class="qr-code-card">
              <view class="qr-code-wrapper">
                <image
                  wx:if="{{qrCodeImage}}"
                  class="qr-code-image"
                  src="{{qrCodeImage}}"
                  mode="aspectFit"
                ></image>
                <view wx:else class="qr-code-placeholder">
                  <text class="placeholder-text">二维码加载中...</text>
                </view>
              </view>
              <view class="refresh-btn-wrapper">
                <view class="refresh-btn" bindtap="refreshCode">
                  <text class="refresh-text">刷新核销码</text>
                </view>
              </view>
            </view>
          </view>

          <!-- 优惠券基本信息卡片 -->
          <view class="card coupon-info-card">
            <view class="card-title">基础信息</view>
            <view class="coupon-desc-display" wx:if="{{couponInfo.couponDesc || couponInfo.coupon_desc || (couponInfo.coupon && (couponInfo.coupon.couponDesc || couponInfo.coupon.coupon_desc))}}">
              <text class="desc-label">优惠券描述：</text>
              <text class="desc-value">{{couponInfo.couponDesc || couponInfo.coupon_desc || (couponInfo.coupon && (couponInfo.coupon.couponDesc || couponInfo.coupon.coupon_desc)) || '暂无'}}</text>
            </view>
            <view class="coupon-validity-row">
              <text class="validity-label">有效期：</text>
              <text class="validity-value">{{formattedValidStartTime}} 至 {{formattedValidEndTime}}</text>
            </view>
            <view class="coupon-validity-row" wx:if="{{couponInfo.verificationExpireTime}}">
              <text class="validity-label">核销码过期：</text>
              <text class="validity-value">{{formattedVerificationExpireTime}}</text>
            </view>
            <view class="coupon-validity-row">
              <text class="validity-label">状态：</text>
              <text class="validity-value">{{couponInfo.status === 1 ? '未使用' : couponInfo.status === 2 ? '已使用' : couponInfo.status === 3 ? '已过期' : '已作废'}}</text>
            </view>
          </view>

          <!-- 优惠券详细信息卡片 -->
          <view class="card detail-info-card">
            <view class="card-title">优惠券信息</view>
            <view class="info-row">
              <text class="info-label">优惠券类型：</text>
              <text class="info-value">{{couponInfo.couponType === 1 ? '折扣券' : couponInfo.couponType === 2 ? '满减券' : couponInfo.couponType === 3 ? '礼品券' : '未知'}}</text>
            </view>
            <view class="info-row" wx:if="{{couponInfo.discountValue}}">
              <text class="info-label">优惠值：</text>
              <text class="info-value">{{couponInfo.discountValue}}</text>
            </view>
            <view class="info-row" wx:if="{{couponInfo.minSpend}}">
              <text class="info-label">最低消费：</text>
              <text class="info-value">¥{{couponInfo.minSpend}}</text>
            </view>
          </view>
        </view>
        <view wx:else class="empty-state">
          <text class="empty-placeholder">暂无优惠券详情</text>
        </view>
      </view>
    </scroll-view>
  </view>
</custom-nav-bar>

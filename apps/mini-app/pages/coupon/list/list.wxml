<!--pages/coupon/list/list.wxml-->
<!-- 自定义导航栏 -->
<custom-nav-bar showBack="{{true}}" useAuditStyle="{{true}}" auditTitle="我的券包">
<!-- 消息通知组件 -->
<message-notification />

<view class="page">
  <!-- 分类导航栏卡片 -->
  <view class="group_tabs">
    <view class="tabs">
      <view class="tab-item {{activeTab === index ? 'active' : ''}}" wx:for="{{tabs}}" wx:key="*this" bindtap="switchTab" data-index="{{index}}">
        {{item}}
      </view>
    </view>
  </view>

  <!-- 优惠券列表卡片 -->
  <view class="group_7">
    <scroll-view class="scroll-list" scroll-y enable-back-to-top show-scrollbar="{{false}}">
      <view class="coupon-list">
        <coupon-card
          wx:for="{{couponList}}"
          wx:key="userCouponId"
          coupon="{{item}}"
          couponBgUrl="{{couponCardBgUrl}}"
          showAction="{{false}}"
          bind:cardtap="viewDetail"
        />

        <view wx:if="{{couponList.length === 0}}" class="empty-state">
          <text class="empty-placeholder">暂无优惠券</text>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
</custom-nav-bar>
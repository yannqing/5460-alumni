/* components/merchant-card/merchant-card.wxss */

.merchant-card {
  position: relative;
  background-color: transparent;
  padding: 0;
  margin-bottom: 0;
}

.merchant-card::after {
  content: '';
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: 0;
  height: 1rpx;
  background: rgba(17, 19, 19, 0.05);
}

.merchant-card.is-last::after {
  display: none;
}

.card-header {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 30rpx;
}

.card-logo {
  width: 96rpx;
  height: 96rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.card-info {
  flex: 1;
  min-width: 0;
}

.card-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
  width: 100%;
  overflow: hidden;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
  min-width: 0;
}

.badges-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.cert-badge {
  padding: 4rpx 12rpx;
  background-color: rgb(226, 175, 22);
  color: #ffffff;
  font-size: 20rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.card-category-tag {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 2rpx 10rpx;
  background-color: #f0f5ff;
  border-radius: 6rpx;
  font-size: 22rpx;
  color: #3F61CA;
  flex-shrink: 0;
}

.subtitle-icon {
  width: 22rpx;
  height: 22rpx;
  flex-shrink: 0;
}

.card-distance {
  font-size: 22rpx;
  color: #999;
  flex-shrink: 0;
  margin-left: auto;
}

.card-meta-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  font-size: 24rpx;
  line-height: 1.4;
  margin-top: 4rpx;
}

.meta-label {
  color: #999999;
  flex-shrink: 0;
}

.meta-value {
  color: #333333;
  font-weight: 500;
}

.meta-highlight {
  color: #ff8a00;
  font-weight: 500;
}

.meta-divider {
  margin: 0 10rpx;
  color: #cccccc;
}

/* 优惠券列表 */
.coupon-list {
  padding: 0 30rpx 20rpx 146rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.coupon-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
}

.coupon-tag {
  width: 36rpx;
  height: 36rpx;
  background-color: #FF8C00;
  color: #ffffff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 4rpx;
  flex-shrink: 0;
}

.coupon-discount {
  color: #FF8C00;
  font-weight: 600;
  flex-shrink: 0;
}

.coupon-name {
  color: #666666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-width: 0;
  flex: 1;
}

/* 活动列表 */
.activity-list {
  padding: 0 30rpx 20rpx 146rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.activity-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
}

.activity-tag {
  width: 36rpx;
  height: 36rpx;
  color: #ffffff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 4rpx;
  flex-shrink: 0;
}

.activity-tag.tag-coupon {
  background-color: #FF8C00;
}

.activity-tag.tag-topic {
  background-color: #4a90e2;
}

.activity-title {
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-width: 0;
  flex: 1;
}
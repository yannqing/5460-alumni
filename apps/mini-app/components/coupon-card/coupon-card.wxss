.coupon-card {
  position: relative;
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #40B2E6, #6BC5ED);
  background-repeat: no-repeat;
  background-position: center;
  background-size: 100% 100%;
  border-radius: 16rpx;
  overflow: hidden;
  min-height: 180rpx;
  border: none !important;
  box-shadow: none !important;
}

.coupon-status-tag {
  position: absolute;
  right: 30rpx;
  top: 20rpx;
  padding: 6rpx 16rpx;
  color: #ffffff;
  font-size: 19rpx;
  font-family: PingFangSC-Semibold;
  font-weight: 600;
  border-radius: 999rpx;
  background-color: #6386F2;
  z-index: 10;
}

.coupon-status-tag.status-1 {
  background-color: #6386F2;
}

.coupon-status-tag.status-2 {
  background-color: #6386F2;
}

.coupon-status-tag.status-3 {
  background-color: #6386F2;
}

.coupon-status-tag.status-4 {
  background-color: #6386F2;
}

.coupon-left-section {
  flex-shrink: 0;
  width: 180rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  color: #fff;
}

.coupon-type-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.2;
}

.coupon-divider-vertical {
  width: 2rpx;
  height: 120rpx;
  background: repeating-linear-gradient(
    to bottom,
    transparent,
    transparent 8rpx,
    rgba(255, 255, 255, 0.5) 8rpx,
    rgba(255, 255, 255, 0.5) 16rpx
  );
  flex-shrink: 0;
}

.coupon-right-section {
  flex: 1;
  padding: 30rpx 24rpx;
  color: #000;
  min-width: 0;
}

.coupon-title-main {
  font-size: 28rpx;
  font-family: PingFangSC-Semibold;
  font-weight: 600;
  color: #000;
  margin-left: 40rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.coupon-merchant-name {
  font-size: 19rpx;
  color: rgba(0, 0, 0, 0.85);
  margin-bottom: 16rpx;
}

.coupon-meta {
  display: flex;
  justify-content: flex-start;
  align-items: center;
  margin-bottom: 6rpx;
  font-size: 17rpx;
  color: rgba(0, 0, 0, 0.8);
}

.coupon-time-text {
  flex: 1;
  margin-left: 40rpx;
  text-align: left;
  font-size: 20rpx;
  font-family: PingFangSC-Semibold;
  font-weight: 600;
}

.coupon-stock-row {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  margin-bottom: 12rpx;
  padding-right: 10rpx;
}

.coupon-stock-text {
  white-space: nowrap;
  margin-left: 0;
  font-size: 17rpx;
  font-family: PingFangSC-Heavy;
  font-weight: 800;
}

.coupon-stock-bar {
  width: 100%;
  height: 8rpx;
  background-color: rgba(255, 255, 255, 0.3);
  border-radius: 4rpx;
  overflow: hidden;
}

.stock-progress-bar {
  height: 100%;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 4rpx;
  transition: width 0.3s;
}

.coupon-action-btn {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  padding: 12rpx 32rpx;
  background-color: rgba(255, 255, 255, 0.3);
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #fff;
  white-space: nowrap;
}
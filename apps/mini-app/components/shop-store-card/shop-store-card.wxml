<view wx:if="{{shop}}" class="store-card" bindtap="handleTap">
  <view class="store-card__header">
    <text class="store-card__name">{{displayName}}</text>
    <view class="store-card__navigate" catchtap="handleNavigateTap">
      <text class="store-card__navigate-text">›</text>
    </view>
  </view>
  <view class="store-card__content">
    <view class="store-card__address">
      <text class="store-card__address-text">{{displayAddress}}</text>
    </view>
    <view wx:if="{{distanceText}}" class="store-card__distance">
      <text class="store-card__distance-text">{{distanceText}}</text>
    </view>
    <view wx:if="{{businessHoursText}}" class="store-card__business-hours">
      <text class="store-card__business-hours-text">{{businessHoursText}}</text>
    </view>
  </view>
</view>

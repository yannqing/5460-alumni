<view class="role-list-section">
  <!-- 骨架屏 -->
  <view wx:if="{{loading}}" class="skeleton-role-list">
    <view class="role-item skeleton-item" wx:for="[1,2,3]" wx:key="*this">
      <view class="role-header">
        <view class="role-name-container">
          <text class="expand-icon">▶</text>
          <view class="skeleton-role-name"></view>
        </view>
        <view class="skeleton-role-count"></view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{displayList.length === 0}}" class="empty-container">
    <text class="empty-text">{{emptyText}}</text>
  </view>

  <!-- 组织树：使用递归组件（微信小程序不支持 template 递归） -->
  <view wx:else class="org-tree">
    <org-tree-node
      wx:for="{{displayList}}"
      wx:key="uniqueId"
      node="{{item}}"
      depth="{{0}}"
      iconIndent="{{iconIndent}}"
      iconArrowDown="{{iconArrowDown}}"
      iconArrowRight="{{iconArrowRight}}"
      isEditMode="{{isEditMode}}"
      isLocalPlatform="{{isLocalPlatform}}"
      canEdit="{{canEdit}}"
      editingMemberId="{{editingMemberId}}"
      newMemberRoleId="{{newMemberRoleId}}"
      inputValues="{{inputValues}}"
      inputWidths="{{inputWidths}}"
      roleNameValues="{{roleNameValues}}"
      roleNameWidths="{{roleNameWidths}}"
      bind:toggleexpand="onToggleExpand"
      bind:memberclick="onMemberClick"
      bind:starteditmember="onStartEditMember"
      bind:membernameinput="onMemberNameInput"
      bind:memberrolenameinput="onMemberRoleNameInput"
      bind:memberinputfocus="onMemberInputFocus"
      bind:savemembername="onSaveMemberName"
      bind:addmemberclick="onAddMemberClick"
      bind:newmembernameinput="onNewMemberNameInput"
      bind:newmemberrolenameinput="onNewMemberRoleNameInput"
      bind:savenewmember="onSaveNewMember"
    />
  </view>
</view>
